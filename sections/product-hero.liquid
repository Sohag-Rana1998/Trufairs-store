      gap: 12px;
    }

    .product-hero__thumbnails {
      gap: 8px;
    }

    .thumbnail-item {
      width: 55px;
      height: 55px;
    }
  }

  /* Reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .product-hero__badge,
    .product-hero__headline,
    .product-hero__subheadline,
    .product-hero__description,
    .product-hero__price-block,
    .product-hero__countdown,
    .product-hero__cta-wrapper,
    .product-hero__trust-badges,
    .product-hero__social-proof,
    .product-hero__image-column {
      animation: none;
    }

    .product-hero__discount-badge,
    .product-hero__scroll-indicator,
    .feature-callout__dot {
      animation: none;
    }

    .product-hero__cta-button,
    .product-hero__product-image,
    .thumbnail-item,
    .feature-callout__content {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Countdown Timer
    const countdownElements = document.querySelectorAll('[data-countdown]');
    
    countdownElements.forEach(function(countdown) {
      const targetDate = new Date(countdown.dataset.countdown).getTime();
      
      function updateCountdown() {
        const now = new Date().getTime();
        const distance = targetDate - now;
        
        if (distance < 0) {
          countdown.style.display = 'none';
          return;
        }
        
        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);
        
        const daysEl = countdown.querySelector('[data-days]');
        const hoursEl = countdown.querySelector('[data-hours]');
        const minutesEl = countdown.querySelector('[data-minutes]');
        const secondsEl = countdown.querySelector('[data-seconds]');
        
        if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      }
      
      updateCountdown();
      setInterval(updateCountdown, 1000);
    });

    // Add to Cart Functionality
    const productForm = document.getElementById('product-hero-form-{{ section.id }}');
    if (productForm) {
      productForm.addEventListener('submit', function(e) {
        {% comment %} e.preventDefault(); {% endcomment %}
        
        const formData = new FormData(this);
        const submitButton = this.querySelector('button[type="submit"]');
        const originalText = submitButton.querySelector('.cta-text').textContent;
        
        // Disable button and show loading state
        submitButton.disabled = true;
        submitButton.querySelector('.cta-text').textContent = 'Adding...';
        
        {% comment %} fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(data => {
          // Success - show added message
          submitButton.querySelector('.cta-text').textContent = 'Added to Cart!';
          
          // Trigger cart drawer/notification if available
          if (typeof window.theme !== 'undefined' && window.theme.cart) {
            window.theme.cart.refresh();
          }
          
          // Dispatch custom event for cart update
          document.dispatchEvent(new CustomEvent('cart:updated'));
          
          // Reset button after 2 seconds
          setTimeout(() => {
            submitButton.disabled = false;
            submitButton.querySelector('.cta-text').textContent = originalText;
          }, 2000);
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
          submitButton.querySelector('.cta-text').textContent = 'Error - Try Again';
          submitButton.disabled = false;
          
          setTimeout(() => {
            submitButton.querySelector('.cta-text').textContent = originalText;
          }, 2000);
        }); {% endcomment %}
      });
    }

    {% comment %} // Thumbnail Gallery
    const thumbnails = document.querySelectorAll('.thumbnail-item');
    const mainImage = document.querySelector('.product-hero__product-image');
    
    thumbnails.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        // Remove active class from all thumbnails
        thumbnails.forEach(t => t.classList.remove('thumbnail-item--active'));
        // Add active class to clicked thumbnail
        this.classList.add('thumbnail-item--active');
        
        // Update main image
        const newSrc = this.querySelector('img').src.replace('width=100', 'width=800');
        if (mainImage) {
          mainImage.style.opacity = '0';
          setTimeout(() => {
            mainImage.src = newSrc;
            mainImage.style.opacity = '1';
          }, 200);
        }
      });
    }); {% endcomment %}

    // Smooth scroll for scroll indicator
    const scrollIndicator = document.querySelector('.product-hero__scroll-indicator');
    if (scrollIndicator) {
      scrollIndicator.addEventListener('click', function() {
        const heroSection = document.querySelector('.product-hero');
        const nextSection = heroSection.nextElementSibling;
        if (nextSection) {
          nextSection.scrollIntoView({ behavior: 'smooth' });
        }
      });
    }
  });
</script>

