/* ===================== SEE MORE VARIANTS BUTTON ===================== */
.pdp-swatch-see-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  border: 2px dashed #ccc;
  border-radius: var(--pdp-radius);
  background: #f9f9f9;
  cursor: pointer;
  padding: 6px;
  width: 95px;
  min-height: 100px;
  transition: border-color 0.2s ease, background 0.2s ease;
  font-size: 12px;
  font-weight: 700;
  color: #333;
  text-align: center;
  line-height: 1.3;
}
.pdp-swatch-see-more:hover {
  border-color: #111;
  background: #f0f0f0;
}
.pdp-swatch-see-more svg {
  width: 20px;
  height: 20px;
  color: #555;
}

/* Hidden swatches (beyond first 8) */
.pdp-swatch--hidden {
  display: none !important;
}


/* ───────────────────────────────────────────────
   Main video slide overlay play/pause button
─────────────────────────────────────────────── */
.pdp-video-overlay {
  position: absolute;
  border-radius: 50%;
  background: rgba(0,0,0,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
  cursor: pointer;
  transition: background 0.25s ease, opacity 0.35s ease;
  pointer-events: auto;           /* only this layer is clickable */
}

.pdp-video-overlay:hover {
  background: rgba(0,0,0,0.5);
  
}

.pdp-video-overlay.playing {
  background: rgba(0,0,0,0.15);
  opacity: 0;
}

.pdp-video-overlay.pause  {
  opacity: 1;
  background: rgba(0,0,0,0.4);
}

/* Play / Pause icon */
.pdp-play-pause-icon {
  width: 90px;
  height: 90px;
  background: rgba(255,255,255,0.92);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 32px rgba(0,0,0,0.35);
  transition: transform 0.2s ease;
}

.pdp-video-overlay:hover .pdp-play-pause-icon {
  transform: scale(1.08);
}

.pdp-play-icon,
.pdp-pause-icon {
  width: 0;
  height: 0;
  border: none;
}

.pdp-play-icon {
  border-left: 28px solid #111;
  border-top: 18px solid transparent;
  border-bottom: 18px solid transparent;
  margin-left: 6px;
}

.pdp-pause-icon {
  width: 24px;
  height: 36px;
  background: linear-gradient(
    to right,
    #111 0%,
    #111 40%,
    transparent 40%,
    transparent 60%,
    #111 60%,
    #111 100%
  );
  border-radius: 4px;
}

{% comment %} /* Hide default controls */
.pdp-media-video {
  pointer-events: none;           /* prevents native controls from being clickable */
} {% endcomment %}

/* Optional: make video fill nicely */
.pdp-main-swiper .swiper-slide video.pdp-media-video {
