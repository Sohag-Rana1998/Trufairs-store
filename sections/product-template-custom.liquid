  font-weight:800 !important;
}
.pdp-dynamic-checkout .shopify-payment-button__button--unbranded{
  background:#5b3df5 !important;
  color:#fff !important;
}

.pdp-payment{ margin-top:2px; }
 
.pdp-payment-icons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
}
.pdp-payment-icon{ height:22px; }

.pdp-trust{
