<script>
(function(){
  'use strict';

  var SECTION_ID = {{ section.id | json }};
  var INITIAL_VARIANT_ID = {{ current_variant.id | json }};
  var PRODUCT_VARIANTS = {{ product.variants | json }};
  var VARIANT_FEATURED_MEDIA_ID = {
  {% for v in product.variants %}
    "{{ v.id }}": {% if v.featured_media %}{{ v.featured_media.id | json }}{% else %}null{% endif %}{% unless forloop.last %},{% endunless %}
  {% endfor %}
  };

  var VARIANT_COVER_IMAGES = {
  {% for v in product.variants %}
    "{{ v.id }}": {% if v.featured_media and v.featured_media.media_type == 'image' %}{{ v.featured_media | image_url: width: 1400 | json }}{% elsif v.featured_image %}{{ v.featured_image | image_url: width: 1400 | json }}{% else %}null{% endif %}{% unless forloop.last %},{% endunless %}
  {% endfor %}
  };

  /*
   * Variant media map.
   * A list.file_reference metafield preserves Shopify-admin image alt text.
   * Legacy URL lists remain supported, but their alt text must use a fallback.
   */
  var PRODUCT_TITLE = {{ product.title | json }};
  var VARIANT_MEDIA = {
  {% for v in product.variants %}
    {% assign vmf = v.metafields.custom.images %}
    "{{ v.id }}": [
      {% if vmf != blank %}
        {% if vmf.type contains 'list.file_reference' %}
          {% for it in vmf.value %}
            {% assign item_type = it.media_type | default: 'image' %}
            {% assign item_url = blank %}
            {% assign item_thumb = blank %}
            {% assign item_zoom = blank %}
            {% assign item_alt = it.alt | default: product.title %}
            {% assign item_width = it.width | default: 2000 %}
            {% assign item_height = it.height | default: 2000 %}

            {% if item_type == 'image' %}
              {% assign item_url = it | image_url: width: 1400 %}
              {% assign item_thumb = it | image_url: width: 200 %}
              {% assign item_zoom = it | image_url: width: 2000 %}
            {% elsif item_type == 'video' %}
              {% assign item_url = it.sources.first.url %}
              {% if it.preview_image %}
                {% assign item_thumb = it.preview_image | image_url: width: 200 %}
              {% endif %}
            {% elsif item_type == 'external_video' %}
              {% assign item_url = it.external_id %}
              {% if it.preview_image %}
                {% assign item_thumb = it.preview_image | image_url: width: 200 %}
              {% endif %}
            {% elsif item_type == 'model' %}
              {% assign item_url = it.sources.first.url %}
              {% if it.preview_image %}
                {% assign item_thumb = it.preview_image | image_url: width: 200 %}
              {% endif %}
            {% else %}
              {% assign item_url = it | file_url %}
            {% endif %}

            {
              "type": {{ item_type | json }},
              "url": {{ item_url | json }},
              "thumbUrl": {{ item_thumb | json }},
              "zoomUrl": {{ item_zoom | default: item_url | json }},
              "alt": {{ item_alt | json }},
              "width": {{ item_width | json }},
              "height": {{ item_height | json }}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% elsif vmf.type contains 'list.' %}
          {% for it in vmf.value %}
            {
              "type": "auto",
              "url": {{ it | strip | json }},
              "thumbUrl": "",
              "zoomUrl": {{ it | strip | json }},
              "alt": {{ product.title | append: ' - Media ' | append: forloop.index | json }},
              "width": 2000,
              "height": 2000
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% else %}
          {% assign parts = vmf.value | split: ',' %}
          {% for it in parts %}
            {
              "type": "auto",
              "url": {{ it | strip | json }},
              "thumbUrl": "",
              "zoomUrl": {{ it | strip | json }},
              "alt": {{ product.title | append: ' - Media ' | append: forloop.index | json }},
              "width": 2000,
              "height": 2000
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% endif %}
      {% endif %}
    ]{% unless forloop.last %},{% endunless %}
  {% endfor %}
  };

  var selectedOptions = {};
  {% for option in product.options_with_values %}
    selectedOptions[{{ forloop.index0 }}] = {{ option.selected_value | json }};
  {% endfor %}

  var mainSwiper = null;
  var thumbsSwiper = null;
  var currentSlideIndex = 0;
  var sectionRoot = document.querySelector('.pdp-wrapper');
  var gallery = sectionRoot ? sectionRoot.querySelector('.pdp-gallery') : document.querySelector('.pdp-gallery');
  var DEFAULT_ATC_TEXT = {% if b_atc and b_atc.settings.button_text != blank %}{{ b_atc.settings.button_text | json }}{% else %}"ADD TO CART"{% endif %};
  var SOLD_OUT_ATC_TEXT = 'Sold Out';
  window.PDP_DEFAULT_ATC_TEXT = DEFAULT_ATC_TEXT;

  function q(selector, root){ return (root || sectionRoot || document).querySelector(selector); }
  function qa(selector, root){ return Array.prototype.slice.call((root || sectionRoot || document).querySelectorAll(selector)); }

  function escapeAttr(str){
    return String(str == null ? '' : str)
      .replace(/&/g,'&amp;')
      .replace(/"/g,'&quot;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;');
  }

  function detectMediaType(url){
    if (!url) return 'image';
    var lc = String(url).trim().toLowerCase().split('?')[0];
    if (lc.indexOf('youtube.com/') > -1 || lc.indexOf('youtu.be/') > -1 || lc.indexOf('vimeo.com/') > -1) return 'external_video';
    if (lc.endsWith('.mp4') || lc.endsWith('.webm') || lc.endsWith('.mov') || lc.endsWith('.m4v')) return 'video';
    if (lc.endsWith('.glb') || lc.endsWith('.gltf')) return 'model';
    return 'image';
  }

  function normalizeExternalVideoUrl(url, autoplay){
    if (!url) return url;
    var raw = String(url).trim();
    try {
      var parsed = new URL(raw, window.location.origin);
      var host = parsed.hostname.replace('www.','').toLowerCase();
      var id;
      var embed = raw;

      if (host === 'youtube.com' || host === 'm.youtube.com') {
        if (parsed.pathname === '/watch') {
          id = parsed.searchParams.get('v');
          if (id) embed = 'https://www.youtube.com/embed/' + encodeURIComponent(id);
        } else if (parsed.pathname.indexOf('/embed/') === 0) {
          embed = raw.split('?')[0];
        }
      } else if (host === 'youtu.be') {
        id = parsed.pathname.split('/').filter(Boolean)[0];
        if (id) embed = 'https://www.youtube.com/embed/' + encodeURIComponent(id);
      } else if (host === 'vimeo.com') {
        id = parsed.pathname.split('/').filter(Boolean)[0];
        if (id && /^\d+$/.test(id)) embed = 'https://player.vimeo.com/video/' + id;
      } else if (host === 'player.vimeo.com') {
        embed = raw.split('?')[0];
      }

      var out = new URL(embed, window.location.origin);
      out.searchParams.set('playsinline', '1');
      out.searchParams.set('enablejsapi', '1');
      out.searchParams.set('api', '1');
      if (autoplay) {
        out.searchParams.set('autoplay', '1');
        out.searchParams.set('muted', '1');
        out.searchParams.set('mute', '1');
      }
      return out.toString();
    } catch(e) {
      return raw;
    }
  }

  function getYouTubeId(url){
    try {
      var u = new URL(url, location.origin);
      if (u.hostname.indexOf('youtu.be') > -1) return (u.pathname.split('/').filter(Boolean)[0] || '');
      if (u.searchParams.get('v')) return u.searchParams.get('v');
      if (u.pathname.indexOf('/embed/') > -1) return u.pathname.split('/embed/')[1].split('/')[0];
    } catch(e) {}
    return '';
  }

  function setExternalThumbImages(root){
    var scope = root || gallery || document;
    qa('img.js-external-thumb[data-external-src]', scope).forEach(function(img){
      if (img._thumbDone) return;
      img._thumbDone = true;
      var url = img.getAttribute('data-external-src') || '';
      var yt = getYouTubeId(url);
      if (yt) {
        img.src = 'https://img.youtube.com/vi/' + yt + '/hqdefault.jpg';
        return;
      }
      if (String(url).toLowerCase().indexOf('vimeo.com') > -1) {
        fetch('https://vimeo.com/api/oembed.json?url=' + encodeURIComponent(url), { mode: 'cors' })
          .then(function(res){ return res.ok ? res.json() : null; })
          .then(function(data){
            if (data && data.thumbnail_url) img.src = data.thumbnail_url;
          })
          .catch(function(){
            var fb = gallery ? gallery.getAttribute('data-fallback-thumb') : '';
            if (fb) img.src = fb;
          });
        return;
      }
      var fallback = gallery ? gallery.getAttribute('data-fallback-thumb') : '';
      if (fallback) img.src = fallback;
    });
  }

  function initThumbVideos(root){
    qa('video.js-thumb-video', root || gallery || document).forEach(function(v){
      if (v._thumbInit) return;
      v._thumbInit = true;
      v.muted = true;
      v.playsInline = true;
      v.preload = 'metadata';
      v.controls = false;
      v.setAttribute('playsinline','');
      v.setAttribute('muted','');
      v.addEventListener('loadedmetadata', function(){
        try { v.currentTime = Math.min(0.05, (v.duration || 1) / 2); } catch(e) {}
      }, { once: true });
      v.addEventListener('play', function(){ try { v.pause(); } catch(e){} });
      try { v.load(); } catch(e) {}
    });
  }

  function normalizeEmbedsInGallery(){
    qa('.pdp-gallery .pdp-embed-iframe').forEach(function(iframe){
      var raw = iframe.getAttribute('data-raw-src') || iframe.getAttribute('src');
      if (!iframe.getAttribute('data-normalized-src')) {
        iframe.setAttribute('data-normalized-src', normalizeExternalVideoUrl(raw, false));
      }
      var normalized = iframe.getAttribute('data-normalized-src');
      if (normalized && iframe.getAttribute('src') !== normalized) iframe.setAttribute('src', normalized);
    });
  }

  function postMessageToIframe(iframe, command){
    if (!iframe || !iframe.contentWindow) return;
    try {
      iframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func: command, args: [] }), '*');
      iframe.contentWindow.postMessage(JSON.stringify({ method: command }), '*');
    } catch(e) {}
  }

  function stopExternalVideo(iframe){
    if (!iframe) return;
    postMessageToIframe(iframe, 'pauseVideo');
    postMessageToIframe(iframe, 'pause');
    var normalized = iframe.getAttribute('data-normalized-src') || normalizeExternalVideoUrl(iframe.getAttribute('data-raw-src') || iframe.src, false);
    iframe.setAttribute('data-normalized-src', normalized);
    if (iframe.getAttribute('src') !== normalized) iframe.setAttribute('src', normalized);
  }

  function prepExternalVideo(iframe){
    if (!iframe) return;
    var raw = iframe.getAttribute('data-raw-src') || iframe.getAttribute('src');
    var normalized = iframe.getAttribute('data-normalized-src') || normalizeExternalVideoUrl(raw, false);
    iframe.setAttribute('data-normalized-src', normalized);
    if (iframe.getAttribute('src') !== normalized) iframe.setAttribute('src', normalized);
  }

  function setVideoOverlayState(video, isPlaying){
    if (!video) return;
    var slide = video.closest('.product-main-slide, .swiper-slide');
    var overlay = slide ? slide.querySelector('.pdp-video-overlay') : null;
    if (!overlay) return;
    var playIcon = overlay.querySelector('.pdp-play-icon');
    var pauseIcon = overlay.querySelector('.pdp-pause-icon');
    overlay.dataset.state = isPlaying ? 'playing' : 'paused';
    overlay.classList.toggle('playing', !!isPlaying);
    if (playIcon) playIcon.style.display = isPlaying ? 'none' : 'block';
    if (pauseIcon) pauseIcon.style.display = isPlaying ? 'block' : 'none';
    overlay.style.opacity = isPlaying ? 0 : 1;
  }

  function playMp4Video(video){
    if (!video || typeof video.play !== 'function') return;
    video.muted = false;
    video.loop = true;
    video.playsInline = true;
    video.controls = true;
    video.setAttribute('playsinline','');
    var promise = video.play();
    if (promise !== undefined) {
      promise.then(function(){ setVideoOverlayState(video, true); }).catch(function(){
        video.setAttribute('controls','');
        setVideoOverlayState(video, false);
      });
    }
  }

  function stopMp4Video(video){
    if (!video || typeof video.pause !== 'function') return;
    try { video.pause(); } catch(e) {}
    setVideoOverlayState(video, false);
  }

  function stopMediaOnSlide(slide){
    if (!slide) return;
    qa('video', slide).forEach(function(video){ stopMp4Video(video); });
    qa('iframe.pdp-embed-iframe, iframe[src*="youtube"], iframe[src*="vimeo"]', slide).forEach(stopExternalVideo);

    var currentMedia = slide.querySelector('[data-product-media-type-model], model-viewer');
    if (currentMedia) {
      currentMedia.dispatchEvent(new CustomEvent('mediaHidden', { bubbles: true, cancelable: true }));
      currentMedia.dispatchEvent(new CustomEvent('shopify_model_viewer_ui_toggle_pause', { bubbles: true, cancelable: true }));
    }
  }

  function prepMediaOnSlide(slide){
    if (!slide) return;
    var video = slide.querySelector('video.pdp-media-video, video.product__video, video');
    if (video) stopMp4Video(video);

    qa('iframe.pdp-embed-iframe, iframe[src*="youtube"], iframe[src*="vimeo"]', slide).forEach(prepExternalVideo);

    var nextMedia = slide.querySelector('[data-product-media-type-model], model-viewer');
    if (nextMedia) {
      nextMedia.dispatchEvent(new CustomEvent('mediaVisible', { bubbles: true, cancelable: true }));
      var modelButton = slide.querySelector('.shopify-model-viewer-ui__button');
      var closeButton = slide.querySelector('.product-single__close-media');
      if (modelButton) modelButton.setAttribute('tabindex', '0');
      if (closeButton) closeButton.setAttribute('tabindex', '0');
    }
  }

  function stopAllMedia(){
    qa('.pdp-gallery .product-main-slide, .pdp-gallery .swiper-slide').forEach(stopMediaOnSlide);
  }

  function syncSelectedClass(swiper){
    if (!swiper || !swiper.slides) return;
    swiper.slides.forEach(function(slide){
      slide.classList.remove('is-selected');
      slide.setAttribute('tabindex', '-1');
    });
    var activeSlide = swiper.slides[swiper.activeIndex];
    if (activeSlide) {
      activeSlide.classList.add('is-selected');
      activeSlide.setAttribute('tabindex', '0');
    }
  }

  function assignSlideIndexes(){
    qa('#variant-images-wrapper .product-main-slide').forEach(function(slide, index){
      slide.dataset.index = String(index);
      if (!slide.hasAttribute('tabindex')) slide.setAttribute('tabindex', index === 0 ? '0' : '-1');
      qa('.photoswipe__image, .js-photoswipe__zoom', slide).forEach(function(el){
        el.setAttribute('data-index', String(index + 1));
      });
    });
    qa('#variant-thumbs-wrapper .swiper-slide').forEach(function(thumb, index){
      thumb.dataset.index = String(index);
    });
  }

  function initModelMedia(){
    var modelMedia = qa('.pdp-gallery [data-product-media-type-model]');
    if (modelMedia.length && window.theme && theme.ProductMedia && typeof theme.ProductMedia.init === 'function') {
      try { theme.ProductMedia.init(modelMedia, SECTION_ID); } catch(e) {}
    }
  }

  function customMediaListeners(){
    qa('.product-single__close-media').forEach(function(el){
      if (el._pdpCloseBound) return;
      el._pdpCloseBound = true;
      el.addEventListener('click', function(){
        var slide = q('.pdp-gallery .is-selected') || q('.pdp-gallery .swiper-slide-active');
        if (slide) stopMediaOnSlide(slide);
      });
    });

    qa('.pdp-gallery model-viewer').forEach(function(el){
      if (el._pdpModelBound) return;
      el._pdpModelBound = true;
      el.addEventListener('shopify_model_viewer_ui_toggle_play', mediaLoaded);
      el.addEventListener('shopify_model_viewer_ui_toggle_pause', mediaUnloaded);
    });
  }

  function mediaLoaded(){
    qa('.product-single__close-media').forEach(function(el){ el.classList.remove('hide'); });
    if (mainSwiper && typeof mainSwiper.allowTouchMove !== 'undefined') mainSwiper.allowTouchMove = false;
  }

  function mediaUnloaded(){
    qa('.product-single__close-media').forEach(function(el){ el.classList.add('hide'); });
    if (mainSwiper && typeof mainSwiper.allowTouchMove !== 'undefined') mainSwiper.allowTouchMove = true;
  }

  function initVideoOverlays(){
    qa('.pdp-video-overlay').forEach(function(overlay){
      if (overlay._videoListenerAdded) return;
      overlay._videoListenerAdded = true;
      var slide = overlay.closest('.product-main-slide, .swiper-slide');
      var video = slide ? slide.querySelector('video.pdp-media-video, video') : null;
      if (!video) return;
      overlay.addEventListener('click', function(evt){
        evt.preventDefault();
        evt.stopPropagation();
        if (video.paused || video.ended) {
          playMp4Video(video);
        } else {
          stopMp4Video(video);
        }
      });
      video.addEventListener('play', function(){ setVideoOverlayState(video, true); });
      video.addEventListener('pause', function(){ setVideoOverlayState(video, false); });
      video.addEventListener('ended', function(){ setVideoOverlayState(video, false); });
      setVideoOverlayState(video, !video.paused && !video.ended);
    });
  }

  function ensureModelViewerFallback(){
    var hasModelViewer = (typeof customElements !== 'undefined' && !!customElements.get('model-viewer'));
    if (hasModelViewer) return;
    qa('.pdp-model-wrap').forEach(function(el){
      var src = el.getAttribute('data-model-src');
      if (src && !el._fallbackRendered) {
        el._fallbackRendered = true;
        el.innerHTML = '<a href="' + escapeAttr(src) + '" target="_blank" rel="noopener">View 3D model</a>';
      }
    });
  }

  function initSwipers(){
    if (!gallery || typeof Swiper === 'undefined') return;
    assignSlideIndexes();
    stopAllMedia();

    if (mainSwiper && mainSwiper.destroy) {
      try { mainSwiper.destroy(true, true); } catch(e) {}
      mainSwiper = null;
    }
    if (thumbsSwiper && thumbsSwiper.destroy) {
      try { thumbsSwiper.destroy(true, true); } catch(e) {}
      thumbsSwiper = null;
    }

    var thumbsEl = q('.pdp-thumbs-swiper', gallery);
    var mainEl = q('.pdp-main-swiper .swiper', gallery);
    if (!mainEl) return;

    if (thumbsEl && qa('.swiper-slide', thumbsEl).length > 0) {
      thumbsSwiper = new Swiper(thumbsEl, {
        direction: 'vertical',
        slidesPerView: 'auto',
        spaceBetween: 20,
        freeMode: true,
        watchSlidesProgress: true,
        watchOverflow: true,
        breakpoints: {
          0: { direction: 'horizontal', spaceBetween: 20 },
          481: { direction: 'vertical', spaceBetween: 20 }
        }
      });
    }

    mainSwiper = new Swiper(mainEl, {
      spaceBetween: 0,
      watchOverflow: true,
      navigation: { nextEl: q('.pdp-next', gallery), prevEl: q('.pdp-prev', gallery) },
      thumbs: thumbsSwiper ? { swiper: thumbsSwiper } : undefined,
      on: {
        init: function(){
          currentSlideIndex = this.activeIndex || 0;
          syncSelectedClass(this);
          normalizeEmbedsInGallery();
          initModelMedia();
          ensureModelViewerFallback();
          customMediaListeners();
          initThumbVideos(gallery);
          setExternalThumbImages(gallery);
          initVideoOverlays();
          prepMediaOnSlide(this.slides[this.activeIndex]);
        },
        slideChangeTransitionStart: function(){
          var prevSlide = this.slides[currentSlideIndex];
          stopMediaOnSlide(prevSlide);
        },
        slideChangeTransitionEnd: function(){
          syncSelectedClass(this);
          prepMediaOnSlide(this.slides[this.activeIndex]);
          currentSlideIndex = this.activeIndex;
        }
      }
    });

    initPdpPhotoswipe();
  }

  function initPdpPhotoswipe(){
    if (!gallery || gallery.dataset.zoom === 'false') return;
    if (gallery._pdpZoomBound) return;
    gallery._pdpZoomBound = true;
    gallery.addEventListener('click', handleZoomClick);
  }

  function handleZoomClick(evt){
    var trigger = evt.target.closest('.js-photoswipe__zoom, .photoswipe__image');
    if (!trigger || !gallery || trigger.closest('.swiper-slide-duplicate')) return;
    evt.preventDefault();
    evt.stopPropagation();

    var images = qa('.flickity-viewport .photoswipe__image', gallery).filter(function(img){
      return !!img.offsetParent || img.closest('.swiper-slide');
    });
    if (!images.length) return;

    var items = images.map(function(el){
      return {
        msrc: el.currentSrc || el.src,
        src: el.getAttribute('data-photoswipe-src') || el.currentSrc || el.src,
        w: parseInt(el.getAttribute('data-photoswipe-width'), 10) || 2000,
        h: parseInt(el.getAttribute('data-photoswipe-height'), 10) || 2000,
        el: el
      };
    });

    var index = 0;
    var activeSlide = q('.is-selected', gallery) || q('.swiper-slide-active', gallery);
    if (activeSlide) {
      var activeImg = activeSlide.querySelector('.photoswipe__image');
      if (activeImg) {
        var found = images.indexOf(activeImg);
        if (found !== -1) index = found;
      }
    }

    var pswpElement = document.querySelector('.pswp');
    if (!pswpElement || typeof PhotoSwipe === 'undefined' || typeof PhotoSwipeUI_Default === 'undefined') return;

    var pswp = new PhotoSwipe(pswpElement, PhotoSwipeUI_Default, items, {
      allowPanToNext: false,
      captionEl: false,
      closeOnScroll: false,
      counterEl: false,
      history: false,
      index: index,
      pinchToClose: false,
      preloaderEl: false,
      scaleMode: 'zoom',
      shareEl: false,
      tapToToggleControls: false,
      getThumbBoundsFn: function(i){
        var pageYScroll = window.pageYOffset || document.documentElement.scrollTop;
        var rect = items[i].el.getBoundingClientRect();
        return { x: rect.left, y: rect.top + pageYScroll, w: rect.width };
      }
    });

    pswp.listen('afterChange', function(){
      var newIndex = pswp.getCurrentIndex();
      var image = images[newIndex];
      if (!image || !mainSwiper || typeof mainSwiper.slideTo !== 'function') return;
      var slide = image.closest('.product-main-slide, .swiper-slide');
      var slideIndex = qa('#variant-images-wrapper .product-main-slide', gallery).indexOf(slide);
      if (slideIndex > -1) mainSwiper.slideTo(slideIndex, 0);
    });
    pswp.init();
  }

  function normaliseMediaItem(media, index){
    if (!media) return null;

    if (typeof media === 'string') {
      media = {
        type: 'auto',
        url: media,
        thumbUrl: '',
        zoomUrl: media,
        alt: PRODUCT_TITLE + ' - Media ' + (index + 1),
        width: 2000,
        height: 2000
      };
    }

    var url = String(media.url || '').trim();
    if (!url) return null;

    var type = media.type || 'auto';
    if (type === 'auto') type = detectMediaType(url);
    if (['image', 'video', 'external_video', 'model'].indexOf(type) === -1) {
      type = detectMediaType(url);
    }

    return {
      type: type,
      url: url,
      thumbUrl: String(media.thumbUrl || '').trim(),
      zoomUrl: String(media.zoomUrl || url).trim(),
      alt: String(media.alt || PRODUCT_TITLE + ' - Media ' + (index + 1)).trim(),
      width: parseInt(media.width, 10) || 2000,
      height: parseInt(media.height, 10) || 2000
    };
  }

  function buildMainSlideHTML(media, i, coverImage){
    var item = normaliseMediaItem(media, i);
    if (!item) return '';

    var type = item.type;
    var safe = escapeAttr(item.url);
    var safeZoom = escapeAttr(item.zoomUrl || item.url);
    var safeAlt = escapeAttr(item.alt);
    var safePoster = escapeAttr(item.thumbUrl || coverImage || '');
    var idx = i + 1;

    if (type === 'video') {
      var mime = String(item.url).toLowerCase().indexOf('.webm') > -1 ? 'video/webm' : 'video/mp4';
      return '' +
        '<div class="swiper-slide product-main-slide" data-index="' + i + '" data-media-type="video" tabindex="-1">' +
          '<video class="pdp-media-video product__video" data-video-type="mp4" loop muted playsinline preload="metadata" aria-label="' + safeAlt + '"' + (safePoster ? ' poster="' + safePoster + '"' : '') + '>' +
            '<source src="' + safe + '" type="' + mime + '">' +
          '</video>' +
          '<div class="pdp-video-overlay" data-state="paused">' +
            '<div class="pdp-play-pause-icon"><div class="pdp-play-icon"></div><div class="pdp-pause-icon" style="display:none;"></div></div>' +
          '</div>' +
        '</div>';
    }

    if (type === 'model') {
      return '' +
        '<div class="swiper-slide product-main-slide" data-index="' + i + '" data-media-type="model" tabindex="-1">' +
          '<div class="pdp-model-wrap" data-product-media-type-model data-model-src="' + safe + '">' +
            '<model-viewer class="pdp-media-model" src="' + safe + '" camera-controls interaction-prompt="none" ar loading="lazy" aria-label="' + safeAlt + '" style="width:100%;height:100%;background:#f3f3f3;"></model-viewer>' +
            '<noscript><a href="' + safe + '" target="_blank" rel="noopener">View 3D model</a></noscript>' +
          '</div>' +
        '</div>';
    }

    if (type === 'external_video') {
      var embed = escapeAttr(normalizeExternalVideoUrl(item.url, false));
      return '' +
        '<div class="swiper-slide product-main-slide" data-index="' + i + '" data-media-type="external_video" tabindex="-1">' +
          '<div class="pdp-embed-wrap">' +
            '<iframe class="pdp-embed-iframe" data-raw-src="' + safe + '" data-normalized-src="' + embed + '" src="' + embed + '" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen title="' + safeAlt + '"></iframe>' +
          '</div>' +
        '</div>';
    }

    return '' +
      '<div class="swiper-slide product-main-slide" data-index="' + i + '" data-media-type="image" tabindex="-1">' +
        '<img class="photoswipe__image" src="' + safe + '" width="' + item.width + '" height="' + item.height + '" data-index="' + idx + '" data-photoswipe-src="' + safeZoom + '" data-photoswipe-width="' + item.width + '" data-photoswipe-height="' + item.height + '" loading="' + (i === 0 ? 'eager' : 'lazy') + '" fetchpriority="' + (i === 0 ? 'high' : 'auto') + '" decoding="async" alt="' + safeAlt + '">' +
        '<button type="button" class="btn btn--body btn--circle js-photoswipe__zoom product__photo-zoom" data-index="' + idx + '" aria-label="Zoom ' + safeAlt + '">' +
          '<svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-search" viewBox="0 0 64 64"><path d="M47.16 28.58A18.58 18.58 0 1 1 28.58 10a18.58 18.58 0 0 1 18.58 18.58ZM54 54 41.94 42"/></svg>' +
        '</button>' +
      '</div>';
  }

  function buildThumbSlideHTML(media, i, coverImage){
    var item = normaliseMediaItem(media, i);
    if (!item) return '';

    var type = item.type;
    var safe = escapeAttr(item.url);
    var safeAlt = escapeAttr(item.alt);
    var safeThumb = escapeAttr(item.thumbUrl || (type === 'image' ? item.url : '') || coverImage || '');

    if (type === 'video') {
      if (safeThumb) {
        return '<div class="swiper-slide" data-index="' + i + '" data-media-type="video"><div class="pdp-thumb-media"><img class="pdp-thumb-img" src="' + safeThumb + '" width="200" height="200" loading="lazy" decoding="async" alt="' + safeAlt + '"><span class="pdp-thumb-play" aria-hidden="true"></span></div></div>';
      }
      return '<div class="swiper-slide" data-index="' + i + '" data-media-type="video"><div class="pdp-thumb-media"><video class="pdp-thumb-video js-thumb-video" muted playsinline preload="metadata" tabindex="-1" aria-hidden="true" src="' + safe + '"></video><span class="pdp-thumb-play" aria-hidden="true"></span></div></div>';
    }

    if (type === 'external_video') {
      if (safeThumb) {
        return '<div class="swiper-slide" data-index="' + i + '" data-media-type="external_video"><div class="pdp-thumb-media"><img class="pdp-thumb-img" src="' + safeThumb + '" width="200" height="200" loading="lazy" decoding="async" alt="' + safeAlt + '"><span class="pdp-thumb-play" aria-hidden="true"></span></div></div>';
      }
      return '<div class="swiper-slide" data-index="' + i + '" data-media-type="external_video"><div class="pdp-thumb-media"><img class="pdp-thumb-img js-external-thumb" src="" data-external-src="' + safe + '" width="200" height="200" loading="lazy" decoding="async" alt="' + safeAlt + '"><span class="pdp-thumb-play" aria-hidden="true"></span></div></div>';
    }

    if (type === 'model') {
      if (safeThumb) {
        return '<div class="swiper-slide" data-index="' + i + '" data-media-type="model"><img class="pdp-thumb-img" src="' + safeThumb + '" width="200" height="200" loading="lazy" decoding="async" alt="' + safeAlt + '"></div>';
      }
      return '<div class="swiper-slide" data-index="' + i + '" data-media-type="model"><div class="pdp-thumb-generic" data-type="3d" role="img" aria-label="' + safeAlt + '"></div></div>';
    }

    return '<div class="swiper-slide" data-index="' + i + '" data-media-type="image"><img class="pdp-thumb-img" src="' + safeThumb + '" width="200" height="200" loading="lazy" decoding="async" alt="' + safeAlt + '"></div>';
  }

  function updateGallery(variant){
    if (!variant) return false;
    var items = VARIANT_MEDIA[String(variant.id)];
    if (!Array.isArray(items) || !items.length) return false;

    var wrap = q('#variant-images-wrapper');
    var thumbs = q('#variant-thumbs-wrapper');
    if (!wrap || !thumbs) return false;

    stopAllMedia();

    if (mainSwiper && typeof mainSwiper.destroy === 'function') {
      try { mainSwiper.destroy(true, true); } catch (error) { console.warn(error); }
      mainSwiper = null;
    }
    if (thumbsSwiper && typeof thumbsSwiper.destroy === 'function') {
      try { thumbsSwiper.destroy(true, true); } catch (error) { console.warn(error); }
      thumbsSwiper = null;
    }

    var variantCoverImage = VARIANT_COVER_IMAGES[String(variant.id)] || null;
    var mainHTML = [];
    var thumbHTML = [];

    items.forEach(function(media, i){
      var item = normaliseMediaItem(media, i);
      if (!item) return;
      mainHTML.push(buildMainSlideHTML(item, i, variantCoverImage));
      thumbHTML.push(buildThumbSlideHTML(item, i, variantCoverImage));
    });

    wrap.innerHTML = mainHTML.join('');
    thumbs.innerHTML = thumbHTML.join('');
    currentSlideIndex = 0;
    initSwipers();
    return true;
  }

  function goToVariantMedia(variant){
    if (!variant || !mainSwiper || typeof mainSwiper.slideTo !== 'function') return;
    var mediaId = VARIANT_FEATURED_MEDIA_ID[String(variant.id)];
    if (!mediaId && variant.featured_media && variant.featured_media.id) mediaId = variant.featured_media.id;
    if (!mediaId && variant.featured_image && variant.featured_image.id) mediaId = variant.featured_image.id;
    if (!mediaId) return;

    var slides = qa('#variant-images-wrapper .product-main-slide', gallery);
    var targetIndex = -1;
    slides.some(function(slide, i){
      if (String(slide.getAttribute('data-media-id')) === String(mediaId)) {
        targetIndex = i;
        return true;
      }
      return false;
    });
    if (targetIndex > -1) mainSwiper.slideTo(targetIndex, 0);
  }

  function cloneSelectedOptions(){
    var cloned = {};
    Object.keys(selectedOptions).forEach(function(key){ cloned[key] = selectedOptions[key]; });
    return cloned;
  }

  function findVariant(selection){
    var lookup = selection || selectedOptions;
    return PRODUCT_VARIANTS.find(function(v){
      return v.options && v.options.every(function(opt, i){ return lookup[i] === opt; });
    }) || null;
  }

  function findVariantBySku(sku){
    if (!sku) return null;
    var target = String(sku).trim().toLowerCase();
    return PRODUCT_VARIANTS.find(function(v){ return String(v.sku || '').trim().toLowerCase() === target; }) || null;
  }

  function findVariantById(id){
    if (!id) return null;
    return PRODUCT_VARIANTS.find(function(v){ return String(v.id) === String(id); }) || null;
  }

  function getFirstAvailableVariant(){
    return PRODUCT_VARIANTS.find(function(v){ return v.available; }) || PRODUCT_VARIANTS[0] || null;
  }

  function findFirstMatchingVariant(selection, uptoIndex, requireAvailable){
    return PRODUCT_VARIANTS.find(function(v){
      if (requireAvailable && !v.available) return false;
      for (var i = 0; i <= uptoIndex; i++) {
        if (selection[i] != null && v.options[i] !== selection[i]) return false;
      }
      return true;
    }) || null;
  }

  function resolveVariantAfterOptionChange(optionIndex, optionValue){
    var nextSelection = cloneSelectedOptions();
    nextSelection[optionIndex] = optionValue;

    var exactVariant = findVariant(nextSelection);
    if (exactVariant && exactVariant.available) return exactVariant;

    var availableVariantForPrefix = findFirstMatchingVariant(nextSelection, optionIndex, true);
    if (availableVariantForPrefix) return availableVariantForPrefix;

    if (exactVariant) return exactVariant;

    if (optionIndex > 0) {
      var availableVariantForPreviousPrefix = findFirstMatchingVariant(nextSelection, optionIndex - 1, true);
      if (availableVariantForPreviousPrefix) return availableVariantForPreviousPrefix;
    }

    return getFirstAvailableVariant();
  }

  function setSelectedOptionsFromVariant(variant){
    if (!variant || !variant.options) return;
    variant.options.forEach(function(opt, i){ selectedOptions[i] = opt; });
  }

  function syncActiveOptionButtons(){
    qa('.pdp-option-values').forEach(function(group){
      qa('[data-option-index]', group).forEach(function(btn){
        var i = parseInt(btn.getAttribute('data-option-index'), 10);
        var val = btn.getAttribute('data-option-value');
        btn.classList.toggle('active', selectedOptions[i] === val);
      });
    });
  }

  function updateVariantAvailabilityStyles(){
    qa('.pdp-option-group').forEach(function(group, optIdx){
      qa('[data-option-index]', group).forEach(function(btn){
        var value = btn.getAttribute('data-option-value');
        var hasMatchingVariant = PRODUCT_VARIANTS.some(function(variant){
          if (!variant.options || variant.options[optIdx] !== value) return false;
          for (var i = 0; i < optIdx; i++) {
            if (selectedOptions[i] && variant.options[i] !== selectedOptions[i]) return false;
          }
          return true;
        });
        var hasAvailableVariant = PRODUCT_VARIANTS.some(function(variant){
          if (!variant.available || !variant.options || variant.options[optIdx] !== value) return false;
          for (var i = 0; i < optIdx; i++) {
            if (selectedOptions[i] && variant.options[i] !== selectedOptions[i]) return false;
          }
          return true;
        });
        var isImpossible = !hasMatchingVariant;
        var isSoldOut = hasMatchingVariant && !hasAvailableVariant;
        btn.classList.toggle('is-unavailable', !hasAvailableVariant);
        btn.disabled = isImpossible;
        btn.setAttribute('aria-disabled', isImpossible ? 'true' : 'false');
        btn.setAttribute('data-option-state', isImpossible ? 'unavailable' : (isSoldOut ? 'soldout' : 'available'));
      });
    });
  }

  function updateUrlWithVariantSku(variant){
    if (!variant) return;
    var url = new URL(window.location.href);
    var sku = variant.sku ? String(variant.sku).trim() : '';
    if (sku) url.searchParams.set('sku', sku);
    else url.searchParams.delete('sku');
    history.replaceState({}, '', url.toString());
  }

  function dispatchVariantEvents(variant){
    if (!sectionRoot || !variant) return;
    var detail = { variant: variant };
    sectionRoot.dispatchEvent(new CustomEvent('variantChange.product-' + SECTION_ID, { bubbles: true, detail: detail }));
    sectionRoot.dispatchEvent(new CustomEvent('variantPriceChange.product-' + SECTION_ID, { bubbles: true, detail: detail }));
    sectionRoot.dispatchEvent(new CustomEvent('variantSKUChange.product-' + SECTION_ID, { bubbles: true, detail: detail }));
    if (variant.featured_media || VARIANT_FEATURED_MEDIA_ID[String(variant.id)]) {
      sectionRoot.dispatchEvent(new CustomEvent('variantImageChange.product-' + SECTION_ID, { bubbles: true, detail: detail }));
    }
  }

  function renderVariant(variant, shouldUpdateUrl){
    if (!variant) return;
    setSelectedOptionsFromVariant(variant);
    syncActiveOptionButtons();
    updateVariantAvailabilityStyles();

    var rebuilt = updateGallery(variant);
    if (!rebuilt) goToVariantMedia(variant);

    var priceEl = document.getElementById('pdp-price');
    var compareEl = document.getElementById('pdp-compare');
    var badgeEl = document.getElementById('pdp-save-badge');
    var stockEl = document.getElementById('pdp-stock-label');
    var stockDotEl = q('.pdp-stock .stock-dot');
    var atcBtn = document.getElementById('pdp-atc');
    var formEl = document.getElementById('pdp-product-form');

    if (priceEl) {
      priceEl.innerHTML = (window.theme && theme.Currency) ? theme.Currency.formatMoney(variant.price, theme.settings.moneyFormat) : ('$' + (variant.price / 100).toFixed(2));
      priceEl.setAttribute('content', (variant.price / 100).toFixed(2));
    }

    qa('#pdp-sku-val, #pdp-sku-val-mobile').forEach(function(el){ el.textContent = variant.sku || ''; });

    if (formEl) {
      qa('input[name="id"]', formEl).forEach(function(input){
        input.value = variant.id;
        input.dispatchEvent(new Event('change', { bubbles: true }));
      });
    }

    if (variant.compare_at_price && variant.compare_at_price > variant.price) {
      if (compareEl) {
        compareEl.innerHTML = (window.theme && theme.Currency) ? theme.Currency.formatMoney(variant.compare_at_price, theme.settings.moneyFormat) : ('$' + (variant.compare_at_price / 100).toFixed(2));
        compareEl.style.display = '';
      }
      if (badgeEl) {
        badgeEl.textContent = 'Save ' + Math.round((variant.compare_at_price - variant.price) * 100 / variant.compare_at_price) + '%';
        badgeEl.style.display = '';
      }
    } else {
      if (compareEl) compareEl.style.display = 'none';
      if (badgeEl) badgeEl.style.display = 'none';
    }

    if (stockEl) stockEl.textContent = variant.available ? 'In stock, ready to ship' : 'Out of stock';
    if (stockDotEl) {
      stockDotEl.classList.toggle('in', !!variant.available);
      stockDotEl.classList.toggle('out', !variant.available);
    }

    if (atcBtn) {
      atcBtn.disabled = !variant.available;
      atcBtn.classList.toggle('pdp-atc-btn--disabled', !variant.available);
      var txt = atcBtn.querySelector('.pdp-atc-btn-text');
      if (txt) txt.textContent = variant.available ? DEFAULT_ATC_TEXT : SOLD_OUT_ATC_TEXT;
    }

    qa('.pdp-dynamic-checkout').forEach(function(el){ el.style.display = variant.available ? '' : 'none'; });

    if (shouldUpdateUrl !== false) updateUrlWithVariantSku(variant);
    dispatchVariantEvents(variant);
  }

function initDefaultVariantSelection(){
  var url = new URL(window.location.href);
  var skuFromUrl = url.searchParams.get('sku');
  var variantIdFromUrl = url.searchParams.get('variant');
  var initialVariant = findVariantBySku(skuFromUrl) || findVariantById(variantIdFromUrl) || findVariantById(INITIAL_VARIANT_ID) || getFirstAvailableVariant();

  if (initialVariant) renderVariant(initialVariant, true);
}

  function bindOptionClicks(){
    if (document._pdpOptionClickBound) return;
    document._pdpOptionClickBound = true;
    document.addEventListener('click', function(e){
      var seeMoreBtn = e.target.closest('.pdp-swatch-see-more');
      if (seeMoreBtn) {
        var container = seeMoreBtn.closest('.pdp-option-values');
        if (container) {
          qa('.pdp-swatch--hidden', container).forEach(function(s){ s.classList.remove('pdp-swatch--hidden'); });
          seeMoreBtn.remove();
        }
        return;
      }

      var btn = e.target.closest('[data-option-index]');
      if (!btn || btn.disabled || btn.getAttribute('aria-disabled') === 'true') return;
      var i = parseInt(btn.dataset.optionIndex, 10);
      var val = btn.dataset.optionValue;
      var resolvedVariant = resolveVariantAfterOptionChange(i, val);
      if (resolvedVariant) renderVariant(resolvedVariant, true);
    });
  }

  function revealVariantsSection(){
    var variantsSection = document.getElementById('variants-section');
    if (!variantsSection) return;
    variantsSection.style.opacity = '1';
    variantsSection.style.transition = 'opacity 0.4s ease';
  }

  function start(){
    sectionRoot = document.querySelector('.pdp-wrapper');
    gallery = sectionRoot ? sectionRoot.querySelector('.pdp-gallery') : document.querySelector('.pdp-gallery');
    bindOptionClicks();
    initDefaultVariantSelection();
    if (typeof Swiper === 'undefined') {
      window.addEventListener('load', function(){ if (typeof Swiper !== 'undefined') initSwipers(); });
    } else {
      initSwipers();
    }
    initThumbVideos(gallery);
    setExternalThumbImages(gallery);
    updateVariantAvailabilityStyles();
    initVideoOverlays();
    revealVariantsSection();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start);
  } else {
    start();
  }

  document.addEventListener('shopify:section:unload', function(evt){
    if (!evt || evt.detail.sectionId !== SECTION_ID) return;
    stopAllMedia();
    if (window.theme && theme.ProductMedia && typeof theme.ProductMedia.removeSectionModels === 'function') {
      try { theme.ProductMedia.removeSectionModels(SECTION_ID); } catch(e) {}
    }
    if (mainSwiper && mainSwiper.destroy) mainSwiper.destroy(true, true);
    if (thumbsSwiper && thumbsSwiper.destroy) thumbsSwiper.destroy(true, true);
  });
})();
</script>

<!-- AJAX ADD TO CART + CART DRAWER EVENTS (with spinner) -->
<script>
  function pdpSetAtcLoading(button, isLoading) {
    if (!button) return;
    button.classList.toggle('is-loading', !!isLoading);
    button.disabled = !!isLoading || button.classList.contains('pdp-atc-btn--disabled');
  }

  window.pdpAddToCart = function(buttonEl){
    var button = buttonEl || document.getElementById('pdp-atc');
    if (!button || button.disabled) return;

    var variantIdEl = document.getElementById('pdp-variant-id');
    var qtyEl = document.getElementById('pdp-qty');

    var variantId = variantIdEl ? variantIdEl.value : null;
    var quantity = qtyEl ? parseInt(qtyEl.value, 10) : 1;
    if (!quantity || quantity < 1) quantity = 1;

    if (!variantId) return;

    var addText = button.querySelector('.pdp-atc-btn-text');
    var loadingText = null;

    pdpSetAtcLoading(button, true);

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: quantity })
    })
    .then(function(res){
      return res.json().then(function(data){
        if (!res.ok) {
          var msg = (data && (data.description || data.message)) ? (data.description || data.message) : 'Add to cart failed';
          throw new Error(msg);
        }
        return data;
      });
    })
    .then(function(data) {
      document.dispatchEvent(new CustomEvent('ajaxProduct:added', {
        bubbles: true,
        detail: { product: data, addToCartBtn: button, quantity: quantity }
      }));

      const altEvents = ['cart:item-added', 'cart:updated', 'product:added-to-cart'];
      altEvents.forEach(eventName => {
        document.dispatchEvent(new CustomEvent(eventName, {
          bubbles: true,
          detail: { product: data, variant: data, quantity: quantity, addToCartBtn: button }
        }));
      });

      if (window.theme && typeof window.theme.cartCount === 'function') {
        window.theme.cartCount();
      }

      if (addText) {
        addText.textContent = 'Added!';
      }
      if (loadingText) loadingText.style.display = 'none';

      setTimeout(function() {
        if (window.theme && window.theme.CartDrawer && typeof window.theme.CartDrawer.open === 'function') {
          window.theme.CartDrawer.open();
        }
      }, 100);

      setTimeout(function() {
        if (addText && !button.classList.contains('pdp-atc-btn--disabled')) addText.textContent = window.PDP_DEFAULT_ATC_TEXT || 'ADD TO CART';
      }, 1500);

    })
    .catch(function(err){
      console.error(err);
      alert(err && err.message ? err.message : 'Unable to add to cart.');
    })
    .finally(function(){
      pdpSetAtcLoading(button, false);
    });
  };

  // Qty buttons
  document.addEventListener('click', function(e){
    var minus = e.target.closest('.pdp-qty-minus');
    var plus  = e.target.closest('.pdp-qty-plus');
    if (!minus && !plus) return;

    var input = document.getElementById('pdp-qty');
    if (!input) return;

    var val = parseInt(input.value, 10);
    if (!val || val < 1) val = 1;

    if (minus) val = Math.max(1, val - 1);
    if (plus) val = Math.min(99, val + 1);

    input.value = val;
  });
</script>

 



