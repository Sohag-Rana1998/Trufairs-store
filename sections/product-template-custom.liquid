  }
}

/* ===================== OUT OF STOCK VARIANT STYLING ===================== */
/* Image swatch - out of stock */
.pdp-swatch.is-unavailable {
    opacity: 0.65;
    position: relative;
    display: none;
}
.pdp-swatch.is-unavailable img {
  filter: grayscale(30%);
}
.pdp-swatch.is-unavailable .swatch-label {
  text-decoration: line-through;
  color: #999;
}
.pdp-swatch.is-unavailable::after {
    content: '';
    position: absolute;
    top: 45%;
    left: 8%;
    width: 100%;
    height: 1.5px;
    background: rgb(0 0 0);
    transform: translateY(-50%) rotate(
315deg);
    pointer-events: none;
    border-radius: 2px;
}

button.pdp-size-btn.is-unavailable.active {
    border: 1px solid black;
}

html:not(.no-js):not(.tab-outline) :focus {
    outline: black;
}

/* Size button - out of stock */
.pdp-size-btn.is-unavailable {
  opacity: 0.55;
  text-decoration: line-through;
  color: #aaa;
  border-color: #ddd;
  cursor: not-allowed;
  position: relative;
}
.pdp-size-btn.is-unavailable:hover {
  border-color: #ddd;
  background: #fff;
}


