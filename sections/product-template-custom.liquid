{% comment %}
  ============================================================
  PRODUCT TEMPLATE — Full featured, schema-block driven
  UPDATED:
    1) Metafield media renders ALL items on first load (list.* + comma string supported)
    2) Mixed media supported from metafield URLs: image / video / external / 3D model
    3) Variant options: option name contains ":-" => Amazon-style image tiles + label; else buttons
    4) SEO + speed best practices (microdata + JSON-LD + preconnect + defer)
    5) Video thumbnails: show REAL video preview using <video> (no autoplay, no play-on-click)
    6) Image-tile variants: if > 8 options, show only 8 + "See more variants" button
    7) Out-of-stock variants marked with line-through styling
    8) One semantic product H1 positioned with CSS Grid (no JavaScript movement)
  ============================================================
{% endcomment %}
{{ 'product-tem.css' | asset_url | stylesheet_tag }}


<style>
:root{
  --pdp-border:#e0e0e0;
  --pdp-radius:6px;
  --pdp-transition:0.2s ease;
  --pdp-accent:#111;
  --pdp-price-color:#F48520;
}

.pdp-wrapper{
  display:grid;
  grid-template-columns:1fr 1fr;
   column-gap: 30px;  
  row-gap: 0; 
  max-width:1540px;
  margin:0 auto;
  padding:32px 20px;
  color:#222;
}
.pdp-prev,
.pdp-next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  cursor: pointer;
}
.product-title  {
  word-wrap:break-word;
  margin-bottom:0px;
  font-weight:600;
  font-size:1.5rem !important;
} 
.pdp-prev { left: 10px; }
.pdp-next { right: 10px; }
.pdp-gallery{
  display:flex;
  gap:12px;
  position:sticky;
  top:100px;
  align-self:start;
  max-width:700px;
}
.pdp-thumbs-swiper {
    width: 80px;
    height: 608px;
    flex-shrink: 0;
    overflow: SCROLL !IMPORTANT;
    scrollbar-width: none;
}

.pdp-shipping-line {
    display: flex;
    align-items: center;
    gap: 4px;
}

.pdp-shipping-line svg{
width:24px;
height:24px;
}

.pdp-thumbs-swiper .swiper-slide{
  height:80px !important;
  width:80px;
  border:2px solid var(--pdp-border);
  border-radius:var(--pdp-radius);
  overflow:hidden;
  cursor:pointer;
  transition:border-color var(--pdp-transition), opacity var(--pdp-transition);
  opacity:0.6;
  background:#fff;
}

.pdp-thumbs-swiper .swiper-slide-thumb-active{
  border-color:var(--pdp-accent);
  opacity:1;
}

.pdp-thumb-media{ position:relative; width:100%; height:100%; }
.pdp-thumb-img{ width:100%; height:100%; object-fit:cover; display:block; }

.pdp-thumb-video{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  pointer-events:none;
  background:#000;
}

.pdp-thumb-play{
  position:absolute;
  inset:0;
  display:grid;
  place-items:center;
  pointer-events:none;
}
.pdp-thumb-play::before{
  content:"";
  width:28px; height:28px;
  border-radius:50%;
  background:rgba(0,0,0,.55);
  display:block;
}
.pdp-thumb-play::after{
  content:"";
  position:absolute;
  width:0; height:0;
  border-left:9px solid #fff;
  border-top:6px solid transparent;
  border-bottom:6px solid transparent;
  margin-left:2px;
}

.pdp-thumb-generic{
  width:100%;
  height:100%;
  background:#f3f3f3;
  position:relative;
}
.pdp-thumb-generic::after{
  content:attr(data-type);
  position:absolute;
  inset:auto 6px 6px 6px;
  font-size:10px;
  color:#666;
  text-transform:uppercase;
  letter-spacing:.08em;
}

.pdp-main-area {
    flex: 1;
    min-width: 0;
    POSITION: RELATIVE;
    overflow: hidden;
}

.pdp-main-swiper{
  width:100%;
  max-width:700px;
  aspect-ratio:1/1;
  background:#f3f3f3;
  border-radius:var(--pdp-radius);
  position:relative;
  overflow:hidden;
  cursor:zoom-in;
}

.flickity-viewport{ width:100%; height:100%; overflow:hidden; position:relative; }
.flickity-viewport .swiper{ width:100%; height:100%; }

.pdp-main-swiper .swiper-slide{
  width:100% !important;
  max-width:800px;
  display:flex;
  align-items:center;
  justify-content:center;
}

.pdp-main-swiper .swiper-slide img,
.pdp-main-swiper .swiper-slide video{
  width:100%;
  height:100%;
  max-width:100%;
  max-height:100%;
  object-fit:contain;
  display:block;
}

.pdp-embed-wrap{ width:100%; height:100%; background:#000; }
.pdp-embed-wrap iframe{ width:100%; height:100%; border:0; display:block; }
 
 
.pdp-main-swiper .swiper-button-next::after,
.pdp-main-swiper .swiper-button-prev::after{
  font-size:13px;
  font-weight:700;
}
 
.swiper-button-prev.pdp-prev, .swiper-button-next.pdp-next  {
    background: #cbc8c8 !important;
}
@media (max-width: 480px){

.pdp-main-swiper .swiper-slide{
 
 max-width: 350px !important;
 
}
 
.pdp-thumbs-swiper {
    height: auto !important;
    display: flex !important;
    width:100% !important;
      gap:20px !important;
}
   .swiper-vertical>.swiper-wrapper {
    flex-direction: row !important;
}
.pdp-gallery {
    display: flex;
    flex-direction: column-reverse;
  
}
div#variant-thumbs-wrapper {
    max-width: 350px;
}
 
.swiper-vertical.swiper-free-mode.swiper-watch-progress.swiper-backface-hidden.swiper-thumbs {
   overflow: scroll;
    max-width: 350px;
}

 
}
.product__photo-zoom{
  position:absolute;
  bottom:12px;
  right:12px;
  z-index:10;
  background:rgba(255,255,255,0.9);
  border:none;
  border-radius:50%;
  width:36px;
  height:36px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  box-shadow:0 2px 8px rgba(0,0,0,.15);
  padding:0;
}
.product__photo-zoom .icon-search{ width:18px; height:18px; stroke:#333; stroke-width:2; fill:none; }

.pdp-info{ display:flex; flex-direction:column; gap:14px; }
 
 
.pdp-sku{ font-size:12px; color:#999; }

.pdp-stock{ display:flex; align-items:center; gap:7px; font-size:13px; font-weight:500;margin-top: 5px; }
.stock-dot{ width:9px; height:9px; border-radius:50%; flex-shrink:0; }
.stock-dot.in{ background:#2db37a; }
.stock-dot.out{ background:#e63535; }

.pdp-price-row{ display:flex; align-items:center; flex-wrap:wrap; gap:8px; }
.pdp-price{ font-size:28px; font-weight:700; color:var(--pdp-price-color); }
.pdp-compare{ font-size:18px; color:#aaa; text-decoration:line-through; }
.pdp-badge{ font-size:12px; background:#ffeaea; color:#e63535; padding:3px 8px; border-radius:3px; font-weight:600; }
.pdp-free-ship{ font-size:13px; color:#2db37a; font-weight:500; }

.pdp-variants-section {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding-bottom: 15px;
}
.pdp-option-label {
    font-size: 16px;
    letter-spacing: .1em;
    font-weight: 700;
    color: #000000;
    margin-bottom: 8px;
}
.pdp-option-values{ display:flex; flex-wrap:wrap; gap:8px; }

.pdp-swatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border: 2px solid var(--pdp-border);
    background: #fff;
    cursor: pointer;
    padding: 6px;
    width: 95px;
    transition: border-color var(--pdp-transition), transform .1s;
}
.pdp-swatch:hover{ transform:translateY(-1px); }
.pdp-swatch img{ width:70px; height:70px; object-fit:cover; border-radius:6px; display:block; }
.pdp-swatch .swatch-label{ font-size:12px; color:#555; font-weight:600; text-align:center; line-height:1.2; }
.pdp-swatch.active{ border-color:var(--pdp-accent); }

.pdp-size-btn{
  padding:8px 14px;
  border:1.5px solid var(--pdp-border);
  background:#fff;
  font-size:13px;
  cursor:pointer;
  font-weight:500;
  transition:border-color var(--pdp-transition), background var(--pdp-transition);
  white-space:nowrap;
}
.pdp-size-btn:hover{ border-color:#999; }
.pdp-size-btn.active{ border-color:var(--pdp-accent); background:#f8f8f8; font-weight:700; }

@media (max-width: 900px){
  .pdp-wrapper{ grid-template-columns:1fr; gap:24px; padding:16px; }
  .pdp-gallery{ position:static; }
  .pdp-thumbs-swiper{ display:none; }
}
@media (max-width: 480px){
  .pdp-price{ font-size:22px; }
 
}

/* ===================== RIGHT SIDE REDESIGN ===================== */
.pdp-info-card{
  background:#fff;
  border:1px solid #eee;
  border-radius:16px;
  padding:20px;
  box-shadow:0 10px 28px rgba(0,0,0,.06);
  display:flex;
  flex-direction:column;
 
}

.pdp-section {
    padding-top: 12px;
    border-top: 1px solid #f0f0f0;
