{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_media = current_variant.featured_media | default: product.featured_media %}

{%- comment -%}
  Metafield normalization (fixes: only 1 image on first load)
  custom.images may be:
    - single_line_text_field: "url1,url2"
    - list.* : list.url / list.single_line_text_field / list.file_reference
{%- endcomment -%}
{% assign mf = current_variant.metafields.custom.images %}
{% assign init_media_items = blank %}
{% assign init_media_is_file_list = false %}

{% if mf != blank %}
  {% if mf.type contains 'list.' %}
    {% assign init_media_items = mf.value %}
    {% if mf.type contains 'file_reference' %}
      {% assign init_media_is_file_list = true %}
    {% endif %}
  {% else %}
    {% assign init_media_items = mf.value | split: ',' %}
  {% endif %}
{% endif %}

{%- comment -%} Fallback thumb (used only if needed) {%- endcomment -%}
{% assign fallback_thumb = blank %}
{% if featured_media and featured_media.media_type == 'image' %}
  {% assign fallback_thumb = featured_media | image_url: width: 200 %}
{% elsif product.featured_media %}
  {% assign fallback_thumb = product.featured_media | image_url: width: 200 %}
{% endif %}

{%- comment -%}
  Alt text merge: product.metafields.custom.alt_tags (comma separated, multi-line text)
  is mapped in order onto the image URLs coming from the variant metafield custom.images,
  skipping any video/embed/3D entries so the same alt-tag list lines up across variants.
  Variant title is appended as the final part of each alt text.
{%- endcomment -%}
{% assign pdp_alt_tags_mf = product.metafields.custom.alt_tags %}
{% assign pdp_alt_tags = blank %}
{% if pdp_alt_tags_mf != blank %}
  {% assign pdp_alt_tags = pdp_alt_tags_mf.value | split: ',' %}
{% endif %}
{% assign pdp_variant_title_suffix = blank %}
{% if current_variant.title != blank and current_variant.title != 'Default Title' %}
  {% assign pdp_variant_title_suffix = current_variant.title %}
{% endif %}

<link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
<link rel="dns-prefetch" href="https://cdnjs.cloudflare.com">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.css">

<div class="pdp-wrapper">
  <!-- ===================== RIGHT: INFO PANEL (REDESIGNED) ===================== -->
  {%- assign b_vendor   = section.blocks | where: "type", "vendor" | first -%}
  {%- assign b_title    = section.blocks | where: "type", "title" | first -%}
  {%- assign b_sku      = section.blocks | where: "type", "sku" | first -%}
  {%- assign b_rating   = section.blocks | where: "type", "rating" | first -%}
  {%- assign b_stock    = section.blocks | where: "type", "stock_badge" | first -%}
  {%- assign b_price    = section.blocks | where: "type", "price" | first -%}
  {%- assign b_coupon   = section.blocks | where: "type", "coupon_banner" | first -%}
  {%- assign b_variants = section.blocks | where: "type", "variant_options" | first -%}
  {%- assign b_delivery = section.blocks | where: "type", "delivery_check" | first -%}
  {%- assign b_delivery_date = section.blocks | where: "type", "delivery_date" | first -%}
  {%- assign b_ship     = section.blocks | where: "type", "shipping_info" | first -%}
  {%- assign b_qty      = section.blocks | where: "type", "quantity_selector" | first -%}
  {%- assign b_atc      = section.blocks | where: "type", "add_to_cart" | first -%}
  {%- assign b_pay      = section.blocks | where: "type", "payment_icons" | first -%}
  {%- assign v_product      = section.blocks | where: "type", "verified_product" | first -%}
  
  {%- assign b_description = section.blocks | where: "type", "description"  | first -%}
  {%- assign b_tab = section.blocks | where: "type", "tab"  | first-%}
  {%- assign b_tab1 = section.blocks | where: "type", "tab1"  | first-%}
  {%- assign b_contact = section.blocks | where: "type", "contact" | first-%}

<!-- SHARED PDP HEAD: one semantic H1, positioned by CSS Grid -->
<div class="pdp-head pdp-head-shared">
  <div class="pdp-head-top">
    {% if b_vendor %}
      <div class="product-single__vendor">
        {%- assign vendor_handle = product.vendor | handleize -%}
        {%- if collections[vendor_handle] != empty -%}
          <a href="{{ routes.collections_url }}/{{ collections[vendor_handle].handle }}">
            {{ collections[vendor_handle].title }}
          </a>
        {%- else -%}
          {{ product.vendor | link_to_vendor }}
        {%- endif -%}
      </div>
    {% endif %}

    {% if b_sku %}
      <div class="pdp-sku">
        SKU: <span id="pdp-sku-val">{{ current_variant.sku }}</span>
      </div>
    {% endif %}
  </div>

  {% if b_title %}
     <div class="product-heading">
    <div class="pdp-title-grid-item">
      <h1
        class="product-title"
        id="pdp-product-title-{{ section.id }}"
        {{ b_title.shopify_attributes }}
      >
        {{ product.title }}
      </h1>
    </div>
  
   {% if product.metafields.custom.verified_aprroved.value   %}
  <span style="font-style:italic; font-size:1.2rem !important;">
    (Trufairs Verified Pick)
  </span>
{% else %}
  <span style="font-style:italic; font-size:1.2rem !important;">
    (Trufairs Trusted Pick)
  </span>
{% endif %}
</div>
    {% if product.metafields.custom.verified_subtitle %}
    <p style="font-size:14px;margin-bottom:5px;"> {{ product.metafields.custom.verified_subtitle }}</p>

    {% else %}

  <p style="font-size:14px;margin-bottom:5px;">    Customer-validated for quality, value, and everyday reliability.</p>
    {% endif %}
  {% endif %}
 
  <div class="pdp-verified-row">
    {% if product.metafields.custom.verified_aprroved %}
      <button type="button" class="custom-drawer-trigger" id="openDrawer">
           <img title="This item is trufairs verified" class="verified-white-logo" style="max-width:30px;"  src="https://cdn.shopify.com/s/files/1/0859/6992/8495/files/Verified_Logo_Main.png?v=1777415405" height="30" width="30">
        This item is Trufairs Verified
    </button>
    {% else %}
      <button type="button" class="custom-drawer-trigger" id="openDrawer">
           <img title="This item is trufairs verified" class="verified-white-logo" style="max-width:30px;"  src="https://cdn.shopify.com/s/files/1/0859/6992/8495/files/Trufairs_Trusted_Icon_Transparent.png?v=1762834274" height="30" width="30">
        This item is Trufairs Trusted
      </button>
    {% endif %}

    {% render 'review-widget' %}
  </div>

  {%- assign proof_count = product.metafields.custom.proof_count -%}
  {%- assign proof_hours = product.metafields.custom.proof_hours -%}
  {% if proof_count != blank and proof_hours != blank %}
    <div class="pdp-proof">
      <span class="pdp-proof-ic" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
          <path d="M13 2 3 14h8l-1 8 11-14h-8l0-6Z" fill="currentColor"/>
        </svg>
      </span>
      <strong>{{ proof_count }}</strong>&nbsp;Bought this in&nbsp;<strong>{{ proof_hours }}</strong>&nbsp;hours
    </div>
  {% endif %}
</div>


  <!-- ===================== LEFT: GALLERY ===================== -->
<div class="pdp-gallery"
       data-zoom="true"
       data-has-slideshow="true"
       data-fallback-thumb="{{ fallback_thumb | escape }}">

    <!-- Thumbnails -->
    <div class="swiper pdp-thumbs-swiper">
      <div class="swiper-wrapper" id="variant-thumbs-wrapper">

        {% if init_media_items != blank %}

          {% assign pdp_thumb_alt_index = 0 %}
          {% for item in init_media_items %}
            {% assign u = item %}
            {% assign media_alt = blank %}
            {% if init_media_is_file_list %}
              {% assign u = item | file_url %}
              {% assign media_alt = item.alt %}
            {% endif %}
            {% assign u = u | strip %}
            {% assign u_lc = u | downcase %}
            {% assign pdp_is_video_entry = false %}
            {% if u_lc contains '.mp4' or u_lc contains '.webm' or u_lc contains '.mov' or u_lc contains 'youtube.com/' or u_lc contains 'youtu.be/' or u_lc contains 'vimeo.com/' or u_lc contains '.glb' or u_lc contains '.gltf' %}
              {% assign pdp_is_video_entry = true %}
            {% endif %}
            {% if media_alt == blank %}
              {% if pdp_is_video_entry %}
                {% assign media_alt = product.title | append: ' - Media ' | append: forloop.index %}
              {% else %}
                {% assign pdp_thumb_alt_index = pdp_thumb_alt_index | plus: 1 %}
                {% assign pdp_alt_raw = pdp_alt_tags[pdp_thumb_alt_index | minus: 1] %}
                {% if pdp_alt_raw != blank %}
                  {% assign media_alt = pdp_alt_raw | strip %}
                  {% if pdp_variant_title_suffix != blank %}
                    {% assign media_alt = media_alt | append: ' - ' | append: pdp_variant_title_suffix %}
                  {% endif %}
                {% else %}
                  {% assign media_alt = product.title | append: ' - Media ' | append: forloop.index %}
                {% endif %}
              {% endif %}
            {% endif %}

            <div class="swiper-slide">
              {% if u_lc contains '.mp4' or u_lc contains '.webm' or u_lc contains '.mov' %}
                <div class="pdp-thumb-media">
                  {% if forloop.first and featured_media and featured_media.media_type == 'image' %}
                    <img class="pdp-thumb-img"
                         src="{{ featured_media | image_url: width: 200 }}"
                         loading="lazy"
                         decoding="async"
                         alt="{{ media_alt | escape }}">
                  {% else %}
                    <video
                      class="pdp-thumb-video js-thumb-video"
                      muted
                      playsinline
                      preload="metadata"
                      tabindex="-1"
                      aria-hidden="true"
                      src="{{ u }}">
                    </video>
                  {% endif %}
                  <span class="pdp-thumb-play" aria-hidden="true"></span>
                </div>

              {% elsif u_lc contains 'youtube.com/' or u_lc contains 'youtu.be/' or u_lc contains 'vimeo.com/' %}
                <div class="pdp-thumb-media">
                  {% if forloop.first and featured_media and featured_media.media_type == 'image' %}
                    <img class="pdp-thumb-img"
                         src="{{ featured_media | image_url: width: 200 }}"
                         loading="lazy"
                         decoding="async"
                         alt="{{ media_alt | escape }}">
                  {% else %}
                    <img class="pdp-thumb-img js-external-thumb"
                         src=""
                         data-external-src="{{ u | escape }}"
                         loading="lazy"
                         decoding="async"
                         alt="{{ media_alt | escape }}">
                  {% endif %}
                  <span class="pdp-thumb-play" aria-hidden="true"></span>
                </div>

              {% elsif u_lc contains '.glb' or u_lc contains '.gltf' %}
                <div class="pdp-thumb-generic" data-type="3d"></div>

              {% else %}
                <img class="pdp-thumb-img"
                     src="{{ u }}"
                     loading="lazy"
                     decoding="async"
                     alt="{{ media_alt | escape }}">
              {% endif %}
            </div>
          {% endfor %}

        {% else %}

          {% for media in product.media %}
            <div class="swiper-slide" data-media-id="{{ media.id }}" data-media-type="{{ media.media_type }}" data-index="{{ forloop.index0 }}">
              {% if media.media_type == 'image' %}
                <img class="pdp-thumb-img"
                     src="{{ media | image_url: width: 200 }}"
                     loading="lazy"
                     decoding="async"
                     alt="{{ media.alt | default: product.title | escape }}">
              {% else %}
                <img class="pdp-thumb-img"
                     src="{{ media.preview_image | image_url: width: 200 }}"
                     loading="lazy"
                     decoding="async"
                     alt="{{ media.alt | default: product.title | escape }}">
              {% endif %}
            </div>
          {% endfor %}

        {% endif %}

      </div>
    </div>

    <!-- MAIN AREA -->
    <div class="pdp-main-area">
      <div class="pdp-main-swiper">

        <!-- Flickity viewport required for theme zoom -->
        <div class="flickity-viewport">
          <div class="swiper">
            {% if product.metafields.custom.verified_aprroved %}

   <span class="trufairs-featured-picks__badge-2 verified-icon">
        <img
                title="This item is trufairs verified"
                class="verified-white-logo"
                style="max-width:35px;"
                src="https://cdn.shopify.com/s/files/1/0859/6992/8495/files/Verified_Logo_Main.png?v=1777415405"
                height="35"
                width="35"
                  alt="trufairs-verified-product-badge"
              >
                    Verified Pick
                  </span>

            {% else %}
   <span class="trufairs-featured-picks__badge-2 verified-icon">
        <img
                title="This item is trufairs verified"
                class="verified-white-logo"
                style="max-width:35px;"
                src="https://cdn.shopify.com/s/files/1/0859/6992/8495/files/Trufairs_Trusted_Icon_Transparent.png?v=1762834274"
                height="35"
                width="35"
                alt="trufairs-trusted-product-badge"
              >
                    Trusted Pick
                  </span>
   {% endif %}
            <div class="swiper-wrapper" id="variant-images-wrapper">

              {% if init_media_items != blank %}

                {% assign pdp_main_alt_index = 0 %}
                {% for item in init_media_items %}
                  {% assign u = item %}
                  {% assign media_alt = blank %}
                  {% if init_media_is_file_list %}
                    {% assign u = item | file_url %}
                    {% assign media_alt = item.alt %}
                  {% endif %}
                  {% assign u = u | strip %}
                  {% assign u_lc = u | downcase %}
                  {% assign pdp_is_video_entry = false %}
                  {% if u_lc contains '.mp4' or u_lc contains '.webm' or u_lc contains '.mov' or u_lc contains 'youtube.com/' or u_lc contains 'youtu.be/' or u_lc contains 'vimeo.com/' or u_lc contains '.glb' or u_lc contains '.gltf' %}
                    {% assign pdp_is_video_entry = true %}
                  {% endif %}
                  {% if media_alt == blank %}
                    {% if pdp_is_video_entry %}
                      {% assign media_alt = product.title | append: ' - Media ' | append: forloop.index %}
                    {% else %}
                      {% assign pdp_main_alt_index = pdp_main_alt_index | plus: 1 %}
                      {% assign pdp_alt_raw = pdp_alt_tags[pdp_main_alt_index | minus: 1] %}
                      {% if pdp_alt_raw != blank %}
                        {% assign media_alt = pdp_alt_raw | strip %}
                        {% if pdp_variant_title_suffix != blank %}
                          {% assign media_alt = media_alt | append: ' - ' | append: pdp_variant_title_suffix %}
                        {% endif %}
                      {% else %}
                        {% assign media_alt = product.title | append: ' - Media ' | append: forloop.index %}
                      {% endif %}
                    {% endif %}
                  {% endif %}

                  <div class="swiper-slide product-main-slide" data-index="{{ forloop.index0 }}" tabindex="{% if forloop.first %}0{% else %}-1{% endif %}">

                    {% if u_lc contains '.mp4' or u_lc contains '.webm' or u_lc contains '.mov' %}
                      <video
                        class="pdp-media-video product__video"
                        data-video-type="mp4"
                        playsinline
                        muted
                        loop
                        preload="metadata"
                        {% if forloop.first and featured_media and featured_media.media_type == 'image' %}
                          poster="{{ featured_media | image_url: width: 1400 }}"
                        {% endif %}
                      >
                        <source src="{{ u }}" type="{% if u_lc contains '.webm' %}video/webm{% else %}video/mp4{% endif %}">
                      </video>
  <div class="pdp-video-overlay" data-state="paused">
        <div class="pdp-play-pause-icon">
          <div class="pdp-play-icon"></div>
          <div class="pdp-pause-icon" style="display:none;"></div>
        </div>
      </div>
                    {% elsif u_lc contains '.glb' or u_lc contains '.gltf' %}
                      <div class="pdp-model-wrap" data-product-media-type-model data-model-src="{{ u | escape }}">
                        <model-viewer class="pdp-media-model"
                                      src="{{ u }}"
                                      camera-controls
                                      interaction-prompt="none"
                                      ar
                                      loading="lazy"
                                      style="width:100%;height:100%;background:#f3f3f3;">
                        </model-viewer>
                        <noscript><a href="{{ u }}" target="_blank" rel="noopener">View 3D model</a></noscript>
                      </div>

                    {% elsif u_lc contains 'youtube.com/' or u_lc contains 'youtu.be/' or u_lc contains 'vimeo.com/' %}
                      <div class="pdp-embed-wrap">
                        <iframe class="pdp-embed-iframe"
                                data-raw-src="{{ u | escape }}"
                                src="{{ u }}"
                                loading="lazy"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen
                                title="{{ product.title | escape }} video">
                        </iframe>
                      </div>

                    {% else %}
                      <img class="photoswipe__image"
                           src="{{ u }}"
                           data-index="{{ forloop.index }}"
                           data-photoswipe-src="{{ u }}"
                           data-photoswipe-width="2000"
                           data-photoswipe-height="2000"
                           loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                           fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
                           decoding="async"
                           alt="{{ media_alt | escape }}">

                      <button type="button"
                              class="btn btn--body btn--circle js-photoswipe__zoom product__photo-zoom"
                              data-index="{{ forloop.index }}">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-search" viewBox="0 0 64 64"><path d="M47.16 28.58A18.58 18.58 0 1 1 28.58 10a18.58 18.58 0 0 1 18.58 18.58ZM54 54 41.94 42"/></svg>
                      </button>
                    {% endif %}

                  </div>
                {% endfor %}

              {% else %}

                {% for media in product.media %}
                  <div class="swiper-slide product-main-slide" data-media-id="{{ media.id }}" data-media-type="{{ media.media_type }}" data-index="{{ forloop.index0 }}" tabindex="{% if forloop.first %}0{% else %}-1{% endif %}">

                    {% if media.media_type == 'image' %}
                      <img class="photoswipe__image"
                           src="{{ media | image_url: width: 1400 }}"
                           data-index="{{ forloop.index }}"
                           data-photoswipe-src="{{ media | image_url: width: 2000 }}"
                           data-photoswipe-width="{{ media.width }}"
                           data-photoswipe-height="{{ media.height }}"
                           loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                           fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
                           decoding="async"
                           alt="{{ media.alt | default: product.title | escape }}">

                      <button type="button"
                              class="btn btn--body btn--circle js-photoswipe__zoom product__photo-zoom"
                              data-index="{{ forloop.index }}">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-search" viewBox="0 0 64 64"><path d="M47.16 28.58A18.58 18.58 0 1 1 28.58 10a18.58 18.58 0 0 1 18.58 18.58ZM54 54 41.94 42"/></svg>
                      </button>

