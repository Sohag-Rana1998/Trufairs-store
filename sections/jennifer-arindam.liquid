        },
        {
          "type": "feature_item",
          "settings": {
            "icon1_type": "vision",
            "feature_title": "Our Vision",
            "feature_description": "Jennifer and Arindam aim to transform homes into sanctuaries of elegance and well-being, offering luxury decor that inspires joy, nurtures comfort, and reflects individuality."
