      "default": "Buy Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "default": "/collections/all"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#ff8c42"
    },
    {
      "type": "color",
      "id": "cta_border_color",
      "label": "Button border color",
      "default": "#ff8c42"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "Button background color",
      "default": "transparent"
