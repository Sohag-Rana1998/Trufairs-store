        },
        {
          "type": "image_picker",
          "id": "custom_icon1",
          "label": "Custom icon1 image",
          "info": "Only used when 'Custom Image' is selected above"
        },
        {
          "type": "text",
          "id": "feature_title",
          "label": "Feature title",
          "default": "Our Mission"
        },
        {
          "type": "textarea",
          "id": "feature_description",
          "label": "Feature description",
          "default": "Jennifer and Arindam blend healthcare expertise with entrepreneurial passion to curate luxurious, wellness-inspired home decor that enhances spaces and enriches daily life."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Founders",
      "blocks": [
        {
          "type": "feature_item",
          "settings": {
            "icon1_type": "mission",
            "feature_title": "Our Mission",
            "feature_description": "Jennifer and Arindam blend healthcare expertise with entrepreneurial passion to curate luxurious, wellness-inspired home decor that enhances spaces and enriches daily life."
