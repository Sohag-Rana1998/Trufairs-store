      "id": "founder1_bio",
      "label": "Founder 1 bio",
      "default": "Jennifer blends healthcare expertise with design, creating comfort-driven curated spaces."
    },
    {
      "type": "header",
      "content": "Founder 2 Settings"
    },
    {
      "type": "image_picker",
      "id": "founder2_image",
      "label": "Founder 2 image"
    },
    {
      "type": "text",
      "id": "founder2_name",
      "label": "Founder 2 name",
      "default": "Arindam"
    },
    {
      "type": "text",
      "id": "founder2_title",
      "label": "Founder 2 title",
      "default": "Co-Founder"
    },
    {
      "type": "textarea",
      "id": "founder2_bio",
      "label": "Founder 2 bio",
      "default": "Arindam fuses wellness expertise with entrepreneurship, enriching homes through luxury."
    },
    {
      "type": "header",
      "content": "Founder Card Styling"
