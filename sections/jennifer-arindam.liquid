    {
      "type": "color",
      "id": "founder_name_color",
      "label": "Founder name color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "founder_title_color",
      "label": "Founder title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "founder_bio_color",
      "label": "Founder bio color",
      "default": "#ffffff"
    }
