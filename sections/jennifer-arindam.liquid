                    {% elsif block.settings.icon1_type == 'custom' and block.settings.custom_icon1 != blank %}
                      <img src="{{ block.settings.custom_icon1 | img_url: '48x48' }}" alt="{{ block.settings.feature_title }}" class="custom-icon1">
                    {% endif %}
                  </div>
                  <div class="feature-content1">
                    {% if block.settings.feature_title != blank %}
                      <h3 style="color: {{ section.settings.feature_title_color }};">{{ block.settings.feature_title }}</h3>
                    {% endif %}
                    {% if block.settings.feature_description != blank %}
                      <p style="color: {{ section.settings.feature_text_color }};">{{ block.settings.feature_description }}</p>
                    {% endif %}
                  </div>
                </div>
            {% endcase %}
          {% endfor %}
        </div>
        
        {% if section.settings.show_cta_button and section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_link | default: '/collections/all' }}" 
             class="cta-button" 
             style="
               color: {{ section.settings.cta_text_color }};
               border-color: {{ section.settings.cta_border_color }};
               background-color: {{ section.settings.cta_bg_color }};
             ">
            {{ section.settings.cta_text }}
            <svg class="arrow-icon1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12,5 19,12 12,19"></polyline>
            </svg>
          </a>
        {% endif %}
      </div>
      
      <div class="founder-cards desktop-founder-card">
        {% if section.settings.founder1_image != blank %}
          <div class="founder-card jennifer-card">
            <div class="founder-image">
              <img src="{{ section.settings.founder1_image | img_url: '600x400' }}" 
                   alt="{{ section.settings.founder1_name }}" 
                   loading="lazy">
            </div>
            <div class="founder-info">
              {% if section.settings.founder1_name != blank %}
                <h4 style="color: {{ section.settings.founder_name_color }};">{{ section.settings.founder1_name }}</h4>
              {% endif %}
              {% if section.settings.founder1_title != blank %}
                <p class="title" style="color: {{ section.settings.founder_title_color }};">{{ section.settings.founder1_title }}</p>
              {% endif %}
              {% if section.settings.founder1_bio != blank %}
                <p class="bio" style="color: {{ section.settings.founder_bio_color }};">{{ section.settings.founder1_bio }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
        
        {% if section.settings.founder2_image != blank %}
          <div class="founder-card arindam-card">
            <div class="founder-image">
              <img src="{{ section.settings.founder2_image | img_url: '600x400' }}" 
                   alt="{{ section.settings.founder2_name }}" 
                   loading="lazy">
            </div>
            <div class="founder-info">
              {% if section.settings.founder2_name != blank %}
                <h4 style="color: {{ section.settings.founder_name_color }};">{{ section.settings.founder2_name }}</h4>
              {% endif %}
              {% if section.settings.founder2_title != blank %}
                <p class="title" style="color: {{ section.settings.founder_title_color }};">{{ section.settings.founder2_title }}</p>
              {% endif %}
              {% if section.settings.founder2_bio != blank %}
                <p class="bio" style="color: {{ section.settings.founder_bio_color }};">{{ section.settings.founder2_bio }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .container, .page-width {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Updated layout: flex with fixed widths */
  .content-wrapper {
    display: flex;
    gap: 30px;
    align-items: center;
  }

  /* Left text content 35% width */
  .text-content {
    flex: 0 0 33%;
    max-width: 33%;
  }

  /* Right image container 65% width with row layout */
.founder-cards {
    flex: 0 0 62%;
    display: flex;
    flex-direction: row;
    gap: 30px;
    margin-left: auto;
    justify-content: flex-end;
}

  /* Each founder card flexes evenly */
.founder-card {
    flex: 1 1 0;
    height: 500px;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    max-width: 350px;
}
  .text-content .tagline {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }


  .description {
    font-size: 16px;
    line-height: normal;
    margin-bottom:15px;
  }

  .mission-vision {
    margin-bottom: 10px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 14px;
  }

  .icon1-wrapper {
    flex-shrink: 0;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon1-wrapper svg{
    width: 58px;
    height: 58px;
  }

  .icon1, .custom-icon1 {
    width: 24px;
    height: 24px;
  }

  .feature-content1 h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
  }

.feature-content1 p {
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
}

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid;
    border-radius: 30px;
    padding: 12px 24px;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  .arrow-icon1 {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .cta-button:hover .arrow-icon1 {
    transform: translateX(4px);
  }

  .founder-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .founder-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .founder-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
 
    z-index: 2;
  }

  .founder-info h4 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .founder-info .title {
    font-size: 14px;
    opacity: 0.8;
    margin-bottom: 8px;
  }

  .founder-info .bio {
    font-size: 14px;
    line-height: 1.4;
    opacity: 0.9;
  }

  

.founder-cards.mobile-founder-card {
    display: none;
}


.founder-info {
    padding: 12px;
    background: #ffffff29;
    margin: 10px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border: 1px solid #ffffffb0;
    border-radius: 10px;
}

 

  @media (max-width: 768px) {
    .about-section {
      padding: 60px 0 !important;
    }

.founder-cards {
     
    gap: 12px;
  
}

    
.founder-info {
    padding: 6px;
    margin: 8px;
}

.founder-info .bio {
    font-size: 11px !important;
}

.icon1-wrapper svg {
    width: 48px;
    height: 48px;
}

.founder-cards.mobile-founder-card {
    display: flex;
}

.founder-cards.desktop-founder-card {
    display: none;
}


    .content-wrapper {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }

    .feature-content1 {
    text-align: left;
}

      .founder-info .title {
    margin-bottom: 2px;
  }
    



    .text-content  {
      flex: 1 1 100%;
      max-width: 100%;
    }
    
    .founder-cards {
    width: 100%;
}
    
.founder-info {
    padding: 5px;
}

   .founder-card {
    height: 300px;
}
    
     
  }
 
</style>

{% schema %}
{
  "name": "About Founders Section",
  "tag": "section",
  "class": "about-founders-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fafafa"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Modern & Fancy"
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Tagline color",
      "default": "#ff8c42"
    },
    {
      "type": "textarea",
      "id": "main_heading",
      "label": "Main heading",
      "default": "Premium Furniture\nThat Lasts a Lifetime"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2d2d2d"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "At Trufairs, founded by Jennifer and Arindam in 2023, we believe luxury living is an art. Our mission is to transform spaces and elevate lifestyles with curated pieces that reflect modern, classic, or rustic styles, tailored to your taste."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Feature Items Styling"
    },
    {
      "type": "color",
      "id": "icon1_color",
