{% schema %}
{
  "name": "Video with Text Custom",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "video-left",
          "label": "Video on left"
        },
        {
          "value": "video-right",
          "label": "Video on right"
        }
      ],
      "default": "video-left"
    },
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"],
      "info": "YouTube or Vimeo URL"
    },
    {
      "type": "url",
      "id": "mp4_url",
      "label": "MP4 Video URL (optional)",
      "info": "Will be used if provided instead of YouTube/Vimeo"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Video Cover Image (Optional)"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Easy to Handle"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Trufairs Verified"
    },
    {
      "type": "text",
      "id": "top_heading",
      "label": "Top Heading",
      "default": "Easy to Handle"
    },
    {
      "type": "checkbox",
      "id": "top_heading_check",
      "label": "Top Label enable",
      "default": false
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text Content",
      "default": "<p>No burning-hot skillet handles here!</p><p>The <strong>quick-release</strong> handles allow for safe transfer of the AirSkillet and its contents to-and-from the air fryer basket.</p>"
    },
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "select",
      "id": "section_padding",
      "label": "Section Padding",
      "options": [
        {
          "value": "padding-top: 0; padding-bottom: 0;",
          "label": "None"
        },
        {
          "value": "padding-top: 2rem; padding-bottom: 2rem;",
          "label": "Small"
        },
        {
          "value": "padding-top: 4rem; padding-bottom: 4rem;",
          "label": "Medium"
        },
        {
          "value": "padding-top: 6rem; padding-bottom: 6rem;",
          "label": "Large"
        }
      ],
      "default": "padding-top: 4rem; padding-bottom: 4rem;"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Video with Text Custom"
    }
  ]
}
{% endschema %}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    {{ section.settings.section_padding }}
  }
  
  .video-text-container {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin: 0 auto;
   
    padding: 50px;
    background: white;
    border-radius: 25px;
  }
  
  .video-text-container.video-right {
    flex-direction: row-reverse;
  }
  
  .video-container {
    flex: 1;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    cursor: pointer;
  }
  
  .video-container video {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .video-container .video-wrapper {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
  }
  
  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  .video-thumbnail {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    background-size: cover;
    background-position: center;
  }
  
  .play-button-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    background-color: rgba(0, 0, 0, 0.7);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 2;
  }
  
  .play-button-overlay:hover {
    background-color: rgba(0, 0, 0, 0.9);
    transform: translate(-50%, -50%) scale(1.1);
  }
  
  .play-button-overlay::after {
    content: '';
    width: 0;
    height: 0;
    border-left: 25px solid white;
    border-top: 15px solid transparent;
    border-bottom: 15px solid transparent;
    margin-left: 5px;
  }
  
  .video-container.playing .play-button-overlay {
    display: none;
  }
  
  .text-container {
    flex: 1;
    padding: 2rem 0;
  }
  
  .text-container h2 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    font-weight: 700;
  }
  
  .text-container p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  
  

  .text-container strong {
    font-weight: 700;
  }
  
  @media screen and (max-width: 768px) {
    .video-text-container, .video-text-container.video-right {
      flex-direction: column;
    }
    
    .video-text-container {
      padding: 25px 15px;
    }
    
    .video-container, .text-container {
      width: 100%;
    }
    
    .text-container {
      padding: 2rem 0 0;
    }
    
    .text-container h2 {
      font-size: 1.6rem;
    }
  }
</style>

<div class="main-section-container container page-width">
  <div>
    {% if section.settings.top_heading_check %}
    <h2 style="text-align:center; font-weight:700;margin-bottom: 20px;">{{ section.settings.top_heading }}</h2>
    {% endif %}
  </div>
  
  <div class="video-text-container  {% if section.settings.layout == 'video-right' %}video-right{% endif %}">
    <div class="video-container" id="video-container-{{ section.id }}">
      {% if section.settings.mp4_url != blank %}
        <!-- Self-hosted MP4 Video with Play Button -->
        {% if section.settings.cover_image %}
          <div class="video-thumbnail" style="background-image: url('{{ section.settings.cover_image | img_url: 'master' }}');">
            <div class="play-button-overlay"></div>
          </div>
        {% endif %}
        <video id="video-{{ section.id }}" {% unless section.settings.cover_image %}autoplay{% endunless %} loop muted playsinline{% if section.settings.cover_image %} style="display: none;"{% endif %}>
          <source src="{{ section.settings.mp4_url }}" type="video/mp4">
          Your browser does not support the video tag.
        </video>
        
      {% elsif section.settings.video_url != blank %}
        <div class="video-wrapper" id="video-wrapper-{{ section.id }}">
          {% if section.settings.cover_image %}
            <div class="video-thumbnail" style="background-image: url('{{ section.settings.cover_image | img_url: 'master' }}');">
              <div class="play-button-overlay"></div>
            </div>
          {% endif %}
          
          {% if section.settings.video_url contains "youtube.com" or section.settings.video_url contains "youtu.be" %}
            {% assign youtube_id = '' %}
            {% if section.settings.video_url contains "youtube.com/watch?v=" %}
              {% assign youtube_id = section.settings.video_url | split: 'v=' | last | split: '&' | first %}
            {% elsif section.settings.video_url contains "youtube.com/embed/" %}
              {% assign youtube_id = section.settings.video_url | split: '/embed/' | last | split: '?' | first %}
            {% elsif section.settings.video_url contains "youtu.be/" %}
              {% assign youtube_id = section.settings.video_url | split: 'youtu.be/' | last | split: '?' | first %}
            {% endif %}
            
            {% if youtube_id != blank %}
              <iframe 
                id="youtube-{{ section.id }}"
                src="https://www.youtube.com/embed/{{ youtube_id }}?autoplay=0&loop=1&playlist={{ youtube_id }}&controls=1&rel=0&enablejsapi=1" 
                frameborder="0" 
                allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture" 
                allowfullscreen
                {% if section.settings.cover_image %}style="display: none;"{% endif %}>
              </iframe>
            {% endif %}
            
          {% elsif section.settings.video_url contains "vimeo.com" %}
            {% assign vimeo_id = '' %}
            {% if section.settings.video_url contains "vimeo.com/" %}
              {% assign vimeo_id = section.settings.video_url | split: 'vimeo.com/' | last | split: '?' | first %}
            {% endif %}
            
            {% if vimeo_id != blank %}
              <iframe 
                id="vimeo-{{ section.id }}"
                src="https://player.vimeo.com/video/{{ vimeo_id }}?autoplay=0&loop=1&title=0&byline=0&portrait=0&muted=1" 
                frameborder="0" 
                allow="autoplay; fullscreen; picture-in-picture" 
                allowfullscreen
                {% if section.settings.cover_image %}style="display: none;"{% endif %}>
              </iframe>
            {% endif %}
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="text-container">
      <h4>{{ section.settings.sub_heading }}</h4>
      <h2>{{ section.settings.heading }}</h2>
      <div class="text-content">
        {{ section.settings.text }}
      </div>
      <div class="button-container">
          <a
      href="/pages/trufairs-verified-trusted-products"
      title="Learn More"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-learn-more"
    >
      Learn More About Trufairs Verified
    </a>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const container = document.getElementById('video-container-{{ section.id }}');
    const playButton = container.querySelector('.play-button-overlay');
    const thumbnail = container.querySelector('.video-thumbnail');
    const video = document.getElementById('video-{{ section.id }}');
    const iframe = container.querySelector('iframe');
    
    if (playButton) {
      playButton.addEventListener('click', function() {
        container.classList.add('playing');
        
        if (thumbnail) {
          thumbnail.style.display = 'none';
        }
        
        if (video) {
          video.style.display = 'block';
          video.play();
        }
        
        if (iframe) {
          iframe.style.display = 'block';
          const src = iframe.src;
          iframe.src = src.replace('autoplay=0', 'autoplay=1');
        }
      });
    }
  })();
</script>
