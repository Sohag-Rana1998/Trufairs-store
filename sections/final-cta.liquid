{% style %}
  #shopify-section-{{ section.id }} .trufairs-final-cta {
    position: relative;
    overflow: hidden;
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__bg img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        90deg,
        rgba(0, 0, 0, {{ section.settings.overlay_left_opacity }}) 0%,
        rgba(0, 0, 0, {{ section.settings.overlay_right_opacity }}) 100%
      );
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__container {
    position: relative;
    z-index: 3;
    max-width: 1180px;
    margin: 0 auto;
  }

 
#shopify-section-template--24574676205871__final_cta_F4BCH6 .trufairs-final-cta__content {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
}
  #shopify-section-{{ section.id }} .trufairs-final-cta__eyebrow {
    margin: 0 0 14px;
    color: {{ section.settings.accent_color }};
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__heading {
    margin: 0 0 18px;
    color: {{ section.settings.heading_color }};
    font-size: clamp(36px, 5vw, 68px);
    line-height: 1.02;
    font-weight: 800;
    letter-spacing: -0.055em;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__text {
    max-width: 620px;
    margin: 0 0 30px;
    color: {{ section.settings.muted_text_color }};
    font-size: 18px;
    line-height: 1.7;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 15px 26px;
    border-radius: 999px;
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    font-size: 15px;
    font-weight: 800;
    text-decoration: none;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__button:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 15px 20px;
    color: {{ section.settings.secondary_link_color }};
    font-size: 15px;
    font-weight: 800;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__secondary:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__proof {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 34px;
      justify-content: center;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__proof-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  
 
    color: {{ section.settings.proof_text_color }};
 
    font-size: 16px;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .trufairs-final-cta__proof-item svg {
    width: 14px;
    height: 14px;
    flex: 0 0 14px;
       border: 1px solid black;
    border-radius: 3px;
  }
 
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .trufairs-final-cta {
      padding: {{ section.settings.mobile_padding_top }}px 16px {{ section.settings.mobile_padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .trufairs-final-cta__overlay {
      background:
        linear-gradient(
          180deg,
          rgba(0, 0, 0, {{ section.settings.mobile_overlay_top_opacity }}) 0%,
          rgba(0, 0, 0, {{ section.settings.mobile_overlay_bottom_opacity }}) 100%
        );
    }

    #shopify-section-{{ section.id }} .trufairs-final-cta__heading {
      font-size: 38px;
    }

    #shopify-section-{{ section.id }} .trufairs-final-cta__text {
      font-size: 16px;
      margin-bottom: 24px;
    }

    #shopify-section-{{ section.id }} .trufairs-final-cta__actions {
      align-items: stretch;
      flex-direction: column;
    }

    #shopify-section-{{ section.id }} .trufairs-final-cta__button,
    #shopify-section-{{ section.id }} .trufairs-final-cta__secondary {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .trufairs-final-cta__proof {
      gap: 10px;
      margin-top: 28px;
    }
  }
{% endstyle %}

<section class="trufairs-final-cta" aria-labelledby="trufairs-final-cta-heading-{{ section.id }}">
  {% if section.settings.background_image != blank %}
    <div class="trufairs-final-cta__bg" aria-hidden="true">
      <picture>
        {% if section.settings.mobile_background_image != blank %}
          <source
            media="(max-width: 749px)"
            srcset="
              {{ section.settings.mobile_background_image | image_url: width: 480 }} 480w,
              {{ section.settings.mobile_background_image | image_url: width: 750 }} 750w
            "
            sizes="100vw"
          >
        {% endif %}

        <img
          src="{{ section.settings.background_image | image_url: width: 1600 }}"
          srcset="
            {{ section.settings.background_image | image_url: width: 900 }} 900w,
            {{ section.settings.background_image | image_url: width: 1400 }} 1400w,
            {{ section.settings.background_image | image_url: width: 1800 }} 1800w
          "
          sizes="100vw"
          alt="{{ section.settings.background_image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.background_image.width }}"
          height="{{ section.settings.background_image.height }}"
        >
      </picture>
    </div>
    <div class="trufairs-final-cta__overlay"></div>
  {% endif %}

  <div class="trufairs-final-cta__container">
    <div class="trufairs-final-cta__content">
      {% if section.settings.eyebrow != blank %}
        <p class="trufairs-final-cta__eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 id="trufairs-final-cta-heading-{{ section.id }}" class="trufairs-final-cta__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="trufairs-final-cta__text">
          {{ section.settings.text }}
        </p>
      {% endif %}

      <div class="trufairs-final-cta__actions">
        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="trufairs-final-cta__button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
          <a href="{{ section.settings.secondary_link }}" class="trufairs-final-cta__secondary">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="trufairs-final-cta__proof" aria-label="Shopping benefits">
          {% for block in section.blocks %}
            {% if block.settings.text != blank %}
              <span class="trufairs-final-cta__proof-item" {{ block.shopify_attributes }}>
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M20 7L10 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {{ block.settings.text }}
              </span>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

