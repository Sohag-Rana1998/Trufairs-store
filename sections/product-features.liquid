  .pf-add-to-cart-form {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .pf-quantity-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pf-quantity-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--pf-text-secondary);
  }

  .pf-quantity-selector {
    display: flex;
    align-items: center;
    background: #F5F5F5;
    border-radius: 12px;
    border: 1px solid #E0E0E0;
    overflow: hidden;
  }

  .pf-quantity-btn {
    width: 40px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--pf-text-secondary);
    transition: all 0.2s ease;
  }

  .pf-quantity-btn:hover {
    background: #E8E8E8;
    color: var(--pf-text-primary);
  }

  .pf-quantity-input {
    width: 50px;
    height: 44px;
    border: none;
    background: transparent;
    text-align: center;
    font-size: 16px;
    font-weight: 600;
    color: var(--pf-text-primary);
    -moz-appearance: textfield;
  }

  .pf-quantity-input::-webkit-outer-spin-button,
  .pf-quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .pf-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 18px 36px;
    background: var(--pf-cta-bg);
    color: var(--pf-cta-text);
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 14px;
    border: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    box-shadow: 0 6px 20px rgba(232,106,51,0.35);
    position: relative;
    overflow: hidden;
    min-width: 240px;
  }

  .pf-cta-button:hover:not(:disabled) {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(232,106,51,0.45);
  }

  .pf-cta-button:disabled {
    background: #CCCCCC;
    box-shadow: none;
    cursor: not-allowed;
  }

  .pf-cta-button.is-loading .pf-btn-text,
  .pf-cta-button.is-loading .pf-btn-arrow {
    display: none;
  }

  .pf-cta-button.is-loading .pf-btn-loading {
    display: inline-flex !important;
    align-items: center;
    gap: 8px;
  }

  .pf-cta-button.is-success .pf-btn-text,
  .pf-cta-button.is-success .pf-btn-arrow,
  .pf-cta-button.is-success .pf-btn-loading {
    display: none;
  }

  .pf-cta-button.is-success .pf-btn-success {
    display: inline-flex !important;
    align-items: center;
    gap: 8px;
  }

  .pf-cta-button.is-success {
    background: linear-gradient(135deg, #4CAF50 0%, #43A047 100%);
    box-shadow: 0 6px 20px rgba(76,175,80,0.35);
  }

  .pf-buy-now-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 28px;
    background: transparent;
    color: var(--pf-accent);
    font-size: 14px;
    font-weight: 600;
    border: 2px solid var(--pf-accent);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .pf-buy-now-btn:hover:not(:disabled) {
    background: var(--pf-accent);
    color: #FFFFFF;
  }

  .pf-buy-now-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pf-payment-icons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(0,0,0,0.04);
  }

  .pf-payment-label {
    font-size: 12px;
    color: var(--pf-text-secondary);
  }

  .pf-payment-methods {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pf-payment-methods svg {
    height: 24px;
    width: auto;
  }

  .pf-toast {
    position: fixed;
    bottom: 30px;
    right: 30px;
    background: #FFFFFF;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.15);
    padding: 20px 24px;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: all 0.4s cubic-bezier(0.4,0,0.2,1);
    overflow: hidden;
    max-width: 360px;
  }

  .pf-toast.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .pf-toast-content {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .pf-toast-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
    border-radius: 50%;
    color: #4CAF50;
    flex-shrink: 0;
  }

  .pf-toast-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pf-toast-text strong {
    font-size: 16px;
    color: var(--pf-text-primary, #2D2D2D);
  }

  .pf-toast-text span {
    font-size: 13px;
    color: var(--pf-text-secondary, #666666);
  }

  .pf-toast-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 4px;
    background: linear-gradient(90deg, #4CAF50, #81C784);
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
  }

  .pf-toast.is-visible .pf-toast-progress {
    animation: toast-progress 2s linear forwards;
  }

  @keyframes pulse-star {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.2); }
  }

  @keyframes toast-progress {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @media screen and (max-width: 1100px) {
    .pf-layout--bento {
      grid-template-columns: 1fr;
    }

    .pf-product-showcase {
      position: relative;
      top: 0;
      max-width: 500px;
      margin: 0 auto;
    }

    .pf-features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 768px) {
    .product-features {
      padding: 30px 0;
    }

    .pf-container {
      padding: 0 20px;
    }

    .pf-product-image-wrapper {
      padding: 10px;
    }

    .pf-header {
      margin-bottom: 40px;
    }

    .pf-subheadline {
      font-size: 16px;
    }

    .pf-layout--grid .pf-features-grid,
    .pf-features-grid {
      grid-template-columns: 1fr;
    }

    .pf-feature-card {
      padding: 24px;
    }

    .pf-quick-stats {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .pf-stat-item {
      padding: 8px;
    }

    .pf-stat-value {
      font-size: 20px;
    }

    .pf-bottom-cta {
      padding: 30px 24px;
    }

    .pf-cta-content {
      flex-direction: column;
      text-align: center;
    }

    .pf-cta-actions {
      align-items: center;
      width: 100%;
    }

    .pf-cta-price {
      justify-content: center;
    }

    .pf-product-form,
    .pf-add-to-cart-form {
      flex-direction: column;
      width: 100%;
    }

    .pf-cta-button,
    .pf-buy-now-btn {
      width: 100%;
    }

    .pf-toast {
      bottom: 20px;
      right: 20px;
      left: 20px;
      max-width: none;
    }
  }

  @media screen and (max-width: 480px) {
    .pf-quick-stats {
      grid-template-columns: repeat(3, 1fr);
    }

    .pf-stat-value {
      font-size: 15px;
    }

    .pf-stat-label {
      font-size: 13px;
    }

    .pf-feature-icon {
      width: 52px;
      height: 52px;
    }

    .pf-feature-title {
      font-size: 16px;
    }

    .pf-price-current {
      font-size: 26px;
    }

    .pf-quantity-wrapper {
      width: 100%;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pf-eyebrow,
    .pf-headline,
    .pf-subheadline,
    .pf-product-showcase,
    .pf-feature-card,
    .pf-bottom-cta,
    .pf-floating-badge,
    .pf-eyebrow-icon,
    .pf-stock-dot {
      animation: none;
    }

    .pf-feature-card,
    .pf-feature-icon,
    .pf-product-image,
    .pf-cta-button,
    .pf-stat-item,
    .pf-toast {
      transition: none;
    }
  }
</style>

<script type="application/json" id="ProductFeaturesVariantImages-{{ section.id }}">
{
  {% for variant in product.variants %}
    {% liquid
      assign target_image_index = 4
      assign variant_image_url = blank
      assign variant_images_mf = variant.metafields.custom.images

      assign product_fallback_image_url = blank
      if product.featured_image
        assign product_fallback_image_url = product.featured_image | image_url: width: 800
      endif

      assign variant_fallback_image_url = blank
      if variant.featured_media and variant.featured_media.media_type == 'image'
        assign variant_fallback_image_url = variant.featured_media | image_url: width: 800
      elsif variant.featured_image
        assign variant_fallback_image_url = variant.featured_image | image_url: width: 800
      endif

      assign image_only_urls = ''
      assign image_only_count = 0

      if variant_images_mf != blank
        if variant_images_mf.type contains 'list.'
          for media_item in variant_images_mf.value
            assign media_url = media_item

            if variant_images_mf.type contains 'file_reference'
              assign media_url = media_item | file_url
            endif

            assign media_url_string = media_url | append: '' | strip
            assign media_url_downcase = media_url_string | downcase

            unless media_url_downcase contains '.mp4' or media_url_downcase contains '.webm' or media_url_downcase contains '.mov'
              assign image_only_count = image_only_count | plus: 1

              if image_only_urls == ''
                assign image_only_urls = media_url_string
              else
                assign image_only_urls = image_only_urls | append: '||' | append: media_url_string
              endif
            endunless
          endfor
        else
          assign variant_images_list = variant_images_mf.value | split: ','

          for media_url in variant_images_list
            assign media_url_string = media_url | strip
            assign media_url_downcase = media_url_string | downcase

            unless media_url_downcase contains '.mp4' or media_url_downcase contains '.webm' or media_url_downcase contains '.mov'
              assign image_only_count = image_only_count | plus: 1

              if image_only_urls == ''
                assign image_only_urls = media_url_string
              else
                assign image_only_urls = image_only_urls | append: '||' | append: media_url_string
              endif
            endunless
          endfor
        endif

        assign image_only_list = image_only_urls | split: '||'

        if image_only_count > 1
          assign variant_image_url = image_only_list[target_image_index] | strip

          if variant_image_url == blank
            assign variant_image_url = image_only_list | first | strip
          endif
        elsif image_only_count == 1
          assign variant_image_url = image_only_list | first | strip
        endif
      endif

      if variant_image_url == blank
        assign variant_image_url = variant_fallback_image_url
      endif

      if variant_image_url == blank
        assign variant_image_url = product_fallback_image_url
      endif
    %}

    "{{ variant.id }}": {{ variant_image_url | json }}{% unless forloop.last %},{% endunless %}
  {% endfor %}
}
</script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const section = document.getElementById('ProductFeatures-' + sectionId);

    if (!section) return;

    const form = section.querySelector('.pf-add-to-cart-form');
    const addToCartBtn = section.querySelector('.pf-add-to-cart-btn');
    const buyNowBtn = section.querySelector('.pf-buy-now-btn');
    const toast = document.getElementById('pf-toast-' + sectionId);
    const quantityInput = section.querySelector('.pf-quantity-input');
    const minusBtn = section.querySelector('.pf-quantity-btn--minus');
    const plusBtn = section.querySelector('.pf-quantity-btn--plus');

    const imageMapEl = document.getElementById('ProductFeaturesVariantImages-' + sectionId);
    const imageWrapper = section.querySelector('[data-pf-image-section]');
    const variantInput = document.getElementById('pdp-variant-id');

    let variantImageMap = {};

    if (imageMapEl) {
      try {
        variantImageMap = JSON.parse(imageMapEl.textContent || '{}');
      } catch (error) {
        variantImageMap = {};
      }
    }

    function updateProductFeaturesImage(variantId) {
      if (!imageWrapper) return;

      const imageEl = imageWrapper.querySelector('[data-pf-dynamic-image]');
      const imageUrl = variantImageMap[String(variantId)];

      if (!imageEl || !imageUrl) return;
      if (imageEl.getAttribute('src') === imageUrl) return;

      imageEl.classList.add('is-changing');

      const preloadedImage = new Image();

      preloadedImage.onload = function() {
        imageEl.setAttribute('src', imageUrl);
        imageEl.removeAttribute('srcset');
        imageEl.classList.remove('is-changing');
      };

      preloadedImage.onerror = function() {
        imageEl.classList.remove('is-changing');
      };

      preloadedImage.src = imageUrl;
    }

    if (variantInput) {
      variantInput.addEventListener('change', function() {
        updateProductFeaturesImage(variantInput.value);

        const pfVariantInput = section.querySelector('[data-variant-id]');
        if (pfVariantInput) {
          pfVariantInput.value = variantInput.value;
        }
      });

      updateProductFeaturesImage(variantInput.value);
    }

    if (minusBtn && plusBtn && quantityInput) {
      minusBtn.addEventListener('click', function() {
        const currentValue = parseInt(quantityInput.value, 10) || 1;

        if (currentValue > 1) {
          quantityInput.value = currentValue - 1;
        }
      });

      plusBtn.addEventListener('click', function() {
        const currentValue = parseInt(quantityInput.value, 10) || 1;
        const maxValue = parseInt(quantityInput.max, 10) || 99;

        if (currentValue < maxValue) {
          quantityInput.value = currentValue + 1;
        }
      });

      quantityInput.addEventListener('change', function() {
        let value = parseInt(this.value, 10) || 1;
        const min = parseInt(this.min, 10) || 1;
        const max = parseInt(this.max, 10) || 99;

        if (value < min) value = min;
        if (value > max) value = max;

        this.value = value;
      });
    }

    if (form) {
      form.addEventListener('submit', function(event) {
        event.preventDefault();

        if (!addToCartBtn || addToCartBtn.disabled) return;

        addToCartBtn.classList.add('is-loading');
        addToCartBtn.disabled = true;

        const formData = new FormData(form);

        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
          .then(function(response) {
            if (!response.ok) {
              throw new Error('Add to cart failed');
            }

            return response.json();
          })
          .then(function() {
            addToCartBtn.classList.remove('is-loading');
            addToCartBtn.classList.add('is-success');

            if (toast) {
              toast.classList.add('is-visible');
            }

            setTimeout(function() {
              window.location.href = '/cart';
            }, 2000);
          })
          .catch(function(error) {
            console.error(error);

            addToCartBtn.classList.remove('is-loading');
            addToCartBtn.disabled = false;

            alert('Sorry, there was an error adding this item to your cart. Please try again.');
          });
      });
    }

    if (buyNowBtn) {
      buyNowBtn.addEventListener('click', function() {
        if (this.disabled) return;

        const variantInputEl = section.querySelector('[data-variant-id]');
        const quantity = quantityInput ? quantityInput.value : 1;

        if (!variantInputEl) return;

        this.disabled = true;
        this.innerHTML = 'Processing...';

        fetch('/cart/clear.js', {
          method: 'POST'
        })
          .then(function() {
            return fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                id: variantInputEl.value,
                quantity: parseInt(quantity, 10) || 1
              })
            });
          })
          .then(function(response) {
            if (!response.ok) {
              throw new Error('Buy now failed');
            }

            return response.json();
          })
          .then(function() {
            window.location.href = '/checkout';
          })
          .catch(function(error) {
            console.error(error);

            buyNowBtn.disabled = false;
            buyNowBtn.innerHTML = 'Buy Now — Skip to Checkout';

            alert('Sorry, there was an error. Please try again.');
          });
      });
    }

    if (toast) {
      toast.addEventListener('click', function() {
        this.classList.remove('is-visible');
      });
    }
  });
</script>

{%- endif -%}

