  }

  .pf-cta-headline {
    font-size: 24px;
    font-weight: 700;
    color: var(--pf-text-primary);
    margin: 0 0 8px;
  }

  .pf-cta-subtext {
    font-size: 15px;
    color: var(--pf-text-secondary);
    margin: 0;
  }

  .pf-cta-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 16px;
  }

  .pf-cta-price {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .pf-price-current {
    font-size: 32px;
    font-weight: 700;
    color: var(--pf-text-primary);
    line-height: 1;
  }

  .pf-price-compare {
    font-size: 18px;
    color: #999999;
    text-decoration: line-through;
  }

  .pf-price-savings-badge {
    display: inline-block;
    padding: 6px 12px;
    background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
    color: #2E7D32;
    font-size: 13px;
    font-weight: 600;
    border-radius: 6px;
  }

