        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Explore picks"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Guided Shopping",
      "blocks": [
        {
          "type": "use_case",
          "settings": {
            "title": "Best mirrors for low-light makeup",
            "text": "Find mirrors selected for brightness, clarity, and everyday usability.",
            "tag": "Beauty & Home"
          }
        },
        {
          "type": "use_case",
          "settings": {
            "title": "Storage solutions for small spaces",
            "text": "Practical picks for keeping compact rooms organized without clutter.",
            "tag": "Small Spaces"
          }
        },
        {
          "type": "use_case",
          "settings": {
            "title": "Travel-ready essentials",
