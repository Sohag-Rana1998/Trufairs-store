{% liquid
  assign has_video = false

  for i in (1..3)
    assign video_key = 'video_' | append: i
    assign fallback_video_key = 'real_use_video_' | append: i | append: '_url'

    assign video_metafield = product.metafields.custom[video_key]
    assign fallback_video_metafield = product.metafields.custom[fallback_video_key]

    if video_metafield != blank or fallback_video_metafield.value != blank
      assign has_video = true
    endif
  endfor
%}

{% if has_video %}
<section class="ugcvt-{{ section.id }}" data-ugcvt-section>
  <div class="ugcvt__container">
    {% if section.settings.show_header %}
      <header class="ugcvt__header">
        {% if section.settings.title != blank %}
          <h2 class="ugcvt__title">{{ section.settings.title }}</h2>
        {% endif %}

        {% if section.settings.subtitle != blank %}
          <p class="ugcvt__subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
      </header>
    {% endif %}

    <div class="ugcvt__row" role="list">
      {% for i in (1..3) %}
        {% assign video_key = 'video_' | append: i %}
        {% assign cover_key = 'cover_' | append: i %}
        {% assign text_key = 'text_' | append: i %}
        {% assign fallback_video_key = 'real_use_video_' | append: i | append: '_url' %}

        {% assign video_metafield = product.metafields.custom[video_key] %}
        {% assign cover_metafield = product.metafields.custom[cover_key] %}
        {% assign text_metafield = product.metafields.custom[text_key] %}
        {% assign fallback_video_metafield = product.metafields.custom[fallback_video_key] %}

        {% assign video_source = blank %}
        {% assign video_poster = blank %}

        {% if video_metafield != blank %}
          {% if video_metafield.value.preview_image != blank %}
            {% assign video_poster = video_metafield.value.preview_image %}
          {% endif %}

          {% if video_metafield.value.sources != blank %}
            {% assign mp4_source = video_metafield.value.sources | where: 'format', 'mp4' | first %}

            {% if mp4_source != blank %}
              {% assign video_source = mp4_source.url %}
            {% else %}
              {% assign first_source = video_metafield.value.sources | first %}
              {% assign video_source = first_source.url %}
            {% endif %}
          {% else %}
            {% assign video_source = video_metafield.value %}
          {% endif %}
        {% endif %}

        {% if video_source == blank and fallback_video_metafield.value != blank %}
          {% assign video_source = fallback_video_metafield.value | strip %}
        {% endif %}

        {% if video_source != blank %}
          <article class="ugcvt__card" role="listitem" data-ugcvt-card data-index="{{ forloop.index0 }}">
            <div class="ugcvt__media" data-ugcvt-wrapper>
              <video
                class="ugcvt__video"
                playsinline
                {% if section.settings.show_controls %}controls{% endif %}
                preload="metadata"
                data-ugcvt-video
                data-src="{{ video_source | escape }}"
                {% if cover_metafield == blank and video_poster != blank %}
                  poster="{{ video_poster | image_url: width: 900 }}"
                {% endif %}
                aria-label="Product video {{ i }}"
              >
                <source src="{{ video_source | escape }}" type="video/mp4">
              </video>

              {% if cover_metafield != blank %}
                <div class="ugcvt__cover" data-ugcvt-cover>
                  <img
                    class="ugcvt__cover-img"
                    src="{{ cover_metafield.value | image_url: width: 900 }}"
                    alt="{{ product.title | escape }} video cover {{ i }}"
                    loading="lazy"
                  >
                </div>
              {% endif %}

              <button type="button" class="ugcvt__play" aria-label="Play video" data-ugcvt-play>
                <span class="ugcvt__play-ring" aria-hidden="true"></span>
                <svg class="ugcvt__play-ic" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </button>
            </div>

            {% if text_metafield != blank %}
              <div class="ugcvt__content">
                <p class="ugcvt__comment">{{ text_metafield.value }}</p>
              </div>
            {% endif %}
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .ugcvt-{{ section.id }} {
    --bg: {{ section.settings.section_bg }};
    --card: {{ section.settings.card_bg }};
    --text: {{ section.settings.text_color }};
    --head: {{ section.settings.heading_color }};
    --muted: {{ section.settings.muted_color }};
    --shadow: 0 18px 50px rgba(0,0,0,.10);
    --radius: 18px;

    background: var(--bg);
    padding: {{ section.settings.padding_y }}px 20px;
    overflow: hidden;
  }

  .ugcvt-{{ section.id }} .ugcvt__container {
    max-width: 1240px;
    margin: 0 auto;
  }

  .ugcvt-{{ section.id }} .ugcvt__header {
    text-align: center;
    margin-bottom: 34px;
  }

  .ugcvt-{{ section.id }} .ugcvt__title {
    color: var(--head);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 10px;
  }

  .ugcvt-{{ section.id }} .ugcvt__subtitle {
    color: var(--text);
    opacity: .9;
    max-width: 760px;
    margin: 0 auto;
    font-size: clamp(14px, 1.35vw, 18px);
    line-height: 1.65;
  }

  .ugcvt-{{ section.id }} .ugcvt__row {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: stretch;
    justify-content: center;
  }

  .ugcvt-{{ section.id }} .ugcvt__card {
    flex: 0 0 calc(33.333% - 12px);
    background: var(--card);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    border: 1px solid rgba(0,0,0,.06);
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .ugcvt-{{ section.id }} .ugcvt__media {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    background: #0b0b0b;
    overflow: hidden;
  }

  .ugcvt-{{ section.id }} .ugcvt__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: #000;
  }

  .ugcvt-{{ section.id }} .ugcvt__cover {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 1;
    pointer-events: none;
    transition: opacity .25s ease;
  }

  .ugcvt-{{ section.id }} .ugcvt__cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.02);
  }

  .ugcvt-{{ section.id }} .ugcvt__cover::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 55%, rgba(0,0,0,.12), rgba(0,0,0,.55));
    z-index: 1;
  }

  .ugcvt-{{ section.id }} .ugcvt__cover.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ugcvt-{{ section.id }} .ugcvt__play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 74px;
    height: 74px;
    border: 0;
    border-radius: 999px;
    background: rgba(255,255,255,.95);
    cursor: pointer;
    z-index: 3;
    display: grid;
    place-items: center;
    box-shadow: 0 18px 40px rgba(0,0,0,.35);
    transition: transform .18s ease, background .18s ease, opacity .2s ease, visibility .2s ease;
  }

  .ugcvt-{{ section.id }} .ugcvt__play:hover {
    transform: scale(1.06);
    background: #fff;
  }

  .ugcvt-{{ section.id }} .ugcvt__play:active {
    transform: scale(.98);
  }

  .ugcvt-{{ section.id }} .ugcvt__play.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .ugcvt-{{ section.id }} .ugcvt__play-ring {
    position: absolute;
    inset: -10px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.55);
    opacity: .75;
  }

  .ugcvt-{{ section.id }} .ugcvt__play-ic {
    width: 22px;
    height: 22px;
    transform: translateX(1px);
    fill: #101010;
  }

  .ugcvt-{{ section.id }} .ugcvt__content {
    padding: 16px 16px 18px;
  }

  .ugcvt-{{ section.id }} .ugcvt__comment {
    margin: 0;
    color: var(--head);
    font-style: italic;
    line-height: 1.55;
    font-size: 15px;
  }

  @media (max-width: 990px) {
    .ugcvt-{{ section.id }} .ugcvt__card {
      flex-basis: calc(50% - 9px);
    }
  }

  @media (max-width: 768px) {
    .ugcvt-{{ section.id }} {
      padding: {{ section.settings.padding_y_mobile }}px 0;
    }

    .ugcvt-{{ section.id }} .ugcvt__header {
      padding: 0 20px;
    }

    .ugcvt-{{ section.id }} .ugcvt__row {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      gap: 14px;
      padding: 0;
      margin-left: 15px;
      justify-content: flex-start;
    }

    .ugcvt-{{ section.id }} .ugcvt__row::-webkit-scrollbar {
      display: none;
    }

    .ugcvt-{{ section.id }} .ugcvt__card {
      flex: 0 0 84%;
      max-width: 420px;
      scroll-snap-align: start;
    }
  }
</style>

<script>
  (function() {
    const root = document.querySelector('.ugcvt-{{ section.id }}[data-ugcvt-section]');
    if (!root) return;

    function getElements(wrapper) {
      return {
        video: wrapper.querySelector('video[data-ugcvt-video]'),
        cover: wrapper.querySelector('[data-ugcvt-cover]'),
        playButton: wrapper.querySelector('[data-ugcvt-play]')
      };
    }

    function loadVideo(video) {
      if (!video) return;

      if (!video.src) {
        const src = video.getAttribute('data-src');

        if (src) {
          video.src = src;
        }
      }

      video.playsInline = true;
    }

    function pauseOthers(currentVideo) {
      const videos = root.querySelectorAll('video[data-ugcvt-video]');

      videos.forEach(function(video) {
        if (video !== currentVideo && !video.paused) {
          const wrapper = video.closest('[data-ugcvt-wrapper]');
          const playButton = wrapper ? wrapper.querySelector('[data-ugcvt-play]') : null;

          video.pause();

          if (playButton) {
            playButton.classList.remove('is-hidden');
            playButton.setAttribute('aria-label', 'Play video');
          }
        }
      });
    }

    function hideCoverAfterDelay(video, cover) {
      if (!cover) return;

      window.setTimeout(function() {
        if (!video.paused && !video.ended) {
          cover.classList.add('is-hidden');
        }
      }, 400);
    }

    function playVideo(wrapper, options = {}) {
      const elements = getElements(wrapper);
      const video = elements.video;
      const cover = elements.cover;
      const playButton = elements.playButton;

      if (!video) return;

      loadVideo(video);

      video.muted = Boolean(options.muted);

      if (playButton) {
        playButton.classList.add('is-hidden');
        playButton.setAttribute('aria-label', 'Pause video');
      }

      pauseOthers(video);

      const playPromise = video.play();

      if (playPromise && typeof playPromise.then === 'function') {
        playPromise
          .then(function() {
            if (video.readyState >= 2) {
              hideCoverAfterDelay(video, cover);
            } else {
              video.addEventListener('loadeddata', function() {
                hideCoverAfterDelay(video, cover);
              }, { once: true });
            }
          })
          .catch(function() {
            if (playButton) {
              playButton.classList.remove('is-hidden');
              playButton.setAttribute('aria-label', 'Play video');
            }

            if (cover) {
              cover.classList.remove('is-hidden');
            }
          });
      }
    }

    function pauseVideo(wrapper) {
      const elements = getElements(wrapper);
      const video = elements.video;
      const playButton = elements.playButton;

      if (!video) return;

      video.pause();

      if (playButton) {
        playButton.classList.remove('is-hidden');
        playButton.setAttribute('aria-label', 'Play video');
      }
    }

    root.addEventListener('click', function(event) {
      const playButton = event.target.closest('[data-ugcvt-play]');

      if (!playButton) return;

      event.preventDefault();

      const wrapper = playButton.closest('[data-ugcvt-wrapper]');
      if (!wrapper) return;

      const video = wrapper.querySelector('video[data-ugcvt-video]');
      if (!video) return;

      playButton.classList.add('is-hidden');

      if (video.paused || video.ended) {
        playVideo(wrapper, { muted: false });
      } else {
        pauseVideo(wrapper);
      }
    });

    root.querySelectorAll('[data-ugcvt-wrapper]').forEach(function(wrapper) {
      const elements = getElements(wrapper);
      const video = elements.video;
      const cover = elements.cover;
      const playButton = elements.playButton;

      if (!video) return;

      video.addEventListener('play', function() {
        if (playButton) {
          playButton.classList.add('is-hidden');
          playButton.setAttribute('aria-label', 'Pause video');
        }

        hideCoverAfterDelay(video, cover);
      });

      video.addEventListener('pause', function() {
        if (!video.ended && playButton) {
          playButton.classList.remove('is-hidden');
          playButton.setAttribute('aria-label', 'Play video');
        }
      });

      video.addEventListener('ended', function() {
        if (playButton) {
          playButton.classList.remove('is-hidden');
          playButton.setAttribute('aria-label', 'Play video');
        }
      });
    });

    const autoplayFirst = {{ section.settings.autoplay_first_video | json }};

    if (autoplayFirst) {
      const firstCard = root.querySelector('[data-ugcvt-card] [data-ugcvt-wrapper]');

      if (firstCard) {
        const observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (!entry.isIntersecting) return;

            playVideo(firstCard, { muted: true });
            observer.disconnect();
          });
        }, {
          threshold: 0.35,
          rootMargin: '150px 0px'
        });

        observer.observe(root);
      }
    }
  })();
</script>
{% endif %}

{% schema %}
{
  "name": "UGC videos metafields",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "See It In Action"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Quick clips that highlight the product in real use."
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay_first_video",
      "label": "Autoplay first video muted",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Section padding desktop",
      "min": 30,
      "max": 140,
      "step": 5,
      "default": 90
    },
    {
      "type": "range",
      "id": "padding_y_mobile",
      "label": "Section padding mobile",
      "min": 20,
      "max": 120,
      "step": 5,
      "default": 60
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#F9F6F1"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading text",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text",
      "default": "#5B5B5B"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#6B6B6B"
    }
  ],
  "presets": [
    {
      "name": "UGC videos metafields"
    }
  ]
}
{% endschema %}