      width: 16px !important;
      height: 16px !important;
    }
    
 .feature-content h3 {
    font-size: 12px !important;
    font-weight: 400 !important;
           letter-spacing: 1px !important;
  
}

    
    .main-message {
      margin-bottom: 0px !important;
    }
    
    .cta-section {
      margin-top: 30px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Promotional Banner",
  "tag": "section",
  "class": "promotional-banner-section",
  "settings": [
    {
      "type": "header",
      "content": "Banner Design"
    },
    {
      "type": "color",
      "id": "bg_color_start",
      "label": "Background Color Start",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "bg_color_end",
      "label": "Background Color End",
      "default": "#2d2d2d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Color",
      "default": "#ffd700"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    },
    {
      "type": "header",
      "content": "Main Message"
    },
    {
      "type": "checkbox",
      "id": "show_main_message",
      "label": "Show Main Message",
      "default": true
    },
    {
      "type": "text",
      "id": "main_message",
      "label": "Main Message",
      "default": "Use \"DISCOUNT10\" to get an extra 10% off your purchase!"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Button",
      "default": false
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {
              "value": "shipping",
              "label": "Shipping"
            },
            {
              "value": "return",
              "label": "Return"
            },
            {
              "value": "guarantee",
              "label": "Guarantee"
            },
            {
              "value": "payment",
              "label": "payment"
            }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On all orders over $50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promotional Banner",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "description": "On all orders"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "return",
            "title": "30-Day Return",
            "description": "Money back guarantee"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "guarantee",
            "title": "Worry-Free After Sale",
            "description": "Customer support"
          }
        }
      ]
    }
  ]
}
{% endschema %}