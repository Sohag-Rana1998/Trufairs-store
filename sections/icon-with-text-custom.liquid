<style>
  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }

  /* Hide scrollbar for webkit browsers */
  .features-flex::-webkit-scrollbar {
    display: none;
  }


.feature-icon svg {
    display: inline-block;
    vertical-align: middle;
    fill: #ff8b21 !important;
    stroke: #ff8b21 !important;
    width: 2rem;
    height: 2rem;
    transition: var(--anchor-transition);
}
  
  
  .cta-button:hover {
    transform: translateY(-3px) !important;
    box-shadow: 0 12px 35px rgba({{ section.settings.highlight_color | color_extract: 'red' }}, {{ section.settings.highlight_color | color_extract: 'green' }}, {{ section.settings.highlight_color | color_extract: 'blue' }}, 0.6) !important;
  }

  .main-message h2 {
      font-size: 18px !important;
      padding: 0 0px
    margin-bottom:20px;
    text-transform:uppercase;
    }

  .feature-item:hover .feature-icon {
    transform: scale(1.1);
    transition: transform 0.3s ease;
  }

  /* Mobile optimizations */
  @media (max-width: 850px) {
    .promotional-banner {
      padding: 10px 0 !important;
    }
    
    .main-message h2 {
      font-size: clamp(14px, 5vw, 20px) !important;
      padding: 0 10px;
      
    }
    
    .features-flex {
      gap: 15px !important;
      padding: 0px !important;
      justify-content: flex-start !important;
    }
    
    .feature-item {
      min-width: 100px !important;
      padding: 0px 0px !important;
          /* width: 47% !important; */
    }
    
     
    
    .feature-icon svg {
      width: 18px !important;
      height: 18px !important;
    }
    
    .feature-content h3 {
      font-size: 12px !important;
    }
    
    .feature-content p {
      font-size: 10px !important;
    }
    
    .container {
      padding: 0 15px !important;
    }


    
    .cta-button {
      font-size: 14px !important;
      padding: 12px 30px !important;
    }
  }

  /* Extra small mobile devices */
  @media (max-width: 480px) {
    .features-flex {
      gap: 5px !important;
      padding:  0px !important;
      justify-content: space-between !important;
    
    }

    .promotional-banner {
    padding: 5px 0 !important;
}
    
 .feature-item {
    min-width: 85px !important;
    padding: 0px 0px !important;
   gap:2px !important;
}
     
