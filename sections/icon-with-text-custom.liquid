<!-- sections/promotional-banner.liquid -->
<div class="promotional-banner" style="
  background: linear-gradient(135deg, {{ section.settings.bg_color_start }} 0%, {{ section.settings.bg_color_end }} 100%);
  color: {{ section.settings.text_color }};
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  text-align: center;
  position: relative;
  overflow: hidden;
">
  <!-- Background Pattern -->
  <div class="banner-pattern" style="
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.1;
   
  "></div>

  <div class="container" style="
    max-width: 1500px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  ">
    
    <!-- Main Discount Message -->
    {% if section.settings.show_main_message %}
    <div class="main-message" style="
      margin-bottom: 0px;
      animation: fadeInDown 1s ease-out;
    ">
      <h2 style="
        font-size: 18px;
        font-weight: 700;
        margin: 10px;
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        color: {{ section.settings.highlight_color }};
      ">
        {{ section.settings.main_message }}
      </h2>
    </div>
    {% endif %}

    <!-- Features Flexbox Container -->
    <div class="features-flex" style="
      display: flex;
      flex-wrap: wrap;
 
      align-items: center;
      gap: 10px;
      overflow-x: auto;
      justify-content: space-around !important;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      padding: 0px 0;
    ">
      
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'feature' %}
            <div class="feature-item" style="
              display: flex;
              flex-direction: row;
              align-items: center;
              gap: 10px;
                
              min-width: 120px;
              flex-shrink: 0;
              opacity: 0;
              animation: fadeInUp 0.8s ease-out {{ forloop.index | times: 0.2 }}s forwards;
              padding:0px;
              border-radius: 12px;
              transition: all 0.3s ease;
            " {{ block.shopify_attributes }}>
              
              <!-- Icon -->
              {% if block.settings.icon != blank %}
                <div class="feature-icon" style="
                
                  display: flex;
                  align-items: center;
                  justify-content: center;
                    flex-shrink: 0;
                  margin-bottom: 5px;
                ">
                  {% case block.settings.icon %}
                    {% when 'shipping' %}
