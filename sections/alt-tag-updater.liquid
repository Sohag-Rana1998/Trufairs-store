<style>
  .alt-tool * { box-sizing: border-box; }

  .alt-tool {
    max-width: {{ section.settings.max_width }}px;
    margin: {{ section.settings.padding_top }}px auto {{ section.settings.padding_bottom }}px;
    padding: 0 16px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: #1a1a2e;
  }

  /* Header */
  .alt-header {
    display: flex;
    align-items: center;
    gap: 16px;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
    color: #fff;
    border-radius: 16px;
    padding: 24px 28px;
    margin-bottom: 20px;
    box-shadow: 0 8px 32px rgba(15,52,96,0.3);
  }
  .alt-header-icon { font-size: 36px; flex-shrink: 0; }
  .alt-header-title { font-size: 22px; font-weight: 700; letter-spacing: -0.3px; margin-bottom: 4px; }
  .alt-header-sub { font-size: 13px; color: rgba(255,255,255,0.65); }

  /* Card */
  .alt-card {
    background: #fff;
    padding: 24px;
    margin-bottom: 16px;
    border-radius: 14px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04);
    border: 1px solid #f0f0f5;
  }
  .alt-card-title {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Forms */
  .alt-tool label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #4a4a68;
    margin-bottom: 6px;
  }
  .alt-tool input[type="text"],
  .alt-tool select,
  .alt-tool textarea {
    width: 100%;
    padding: 11px 14px;
    border: 1.5px solid #e0e0ee;
    border-radius: 10px;
    font-size: 14px;
    color: #1a1a2e;
    background: #fafafd;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
  }
  .alt-tool input[type="text"]:focus,
  .alt-tool select:focus,
  .alt-tool textarea:focus {
    border-color: #4361ee;
    box-shadow: 0 0 0 3px rgba(67,97,238,0.12);
    background: #fff;
  }
  .alt-tool textarea {
    resize: vertical;
    font-family: "SFMono-Regular", Consolas, monospace;
    font-size: 13px;
    line-height: 1.6;
    min-height: 180px;
  }
  .field-group { margin-bottom: 14px; }
  .field-group:last-child { margin-bottom: 0; }

  .search-row { display: flex; gap: 10px; }
  .search-row input { flex: 1; margin-bottom: 0; }

  .hint {
    font-size: 12px;
    color: #6b7280;
    margin-top: 6px;
    line-height: 1.5;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 11px 18px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    white-space: nowrap;
    transition: opacity 0.15s, transform 0.1s, box-shadow 0.15s;
  }
  .btn:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,0,0,0.15); }
  .btn:active:not(:disabled) { transform: translateY(0); }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none !important; }
  .btn-primary   { background: linear-gradient(135deg,#2e7d32,#43a047); color:#fff; box-shadow:0 2px 8px rgba(46,125,50,0.25); }
  .btn-secondary { background: linear-gradient(135deg,#1565c0,#1976d2); color:#fff; box-shadow:0 2px 8px rgba(21,101,192,0.25); }
  .btn-full { width: 100%; padding: 14px; font-size: 15px; border-radius: 12px; }

  /* Progress */
  .progress-wrap {
    width: 100%;
    height: 10px;
    background: #e8e8f0;
    border-radius: 999px;
    overflow: hidden;
    margin: 10px 0;
  }
  .progress-bar {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg,#4361ee,#7c3aed);
    transition: width 0.3s ease;
    width: 0%;
  }
  .progress-pct { font-size: 13px; font-weight: 700; color: #4361ee; text-align: right; margin-bottom: 4px; }

  /* Variant rows */
  .variant-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 10px;
    background: #f9f9fd;
    border: 1px solid #ececf5;
    margin-bottom: 8px;
    font-size: 14px;
  }
  .variant-row-name { flex: 1; font-weight: 600; color: #1a1a2e; }
  .variant-status {
    font-size: 13px;
    font-weight: 600;
    min-width: 90px;
    text-align: right;
  }
  .variant-status--pending  { color: #9ca3af; }
  .variant-status--running  { color: #1565c0; }
  .variant-status--done     { color: #2e7d32; }
  .variant-status--error    { color: #c62828; }
  .variant-status--skipped  { color: #e65100; }

  /* Log */
  .log-box {
    max-height: 220px;
    overflow-y: auto;
    border: 1px solid #efefef;
    border-radius: 10px;
    background: #fcfcfc;
    padding: 10px 12px;
    margin-top: 14px;
    font-size: 12px;
    line-height: 1.6;
    font-family: "SFMono-Regular", Consolas, monospace;
  }
  .log-item { padding: 2px 0; border-bottom: 1px dashed #eee; color: #555; }
  .log-item:last-child { border-bottom: none; }
  .log-item--success { color: #2e7d32; }
  .log-item--error   { color: #c62828; }
  .log-item--warn    { color: #e65100; }
  .log-item--info    { color: #1565c0; }

  /* Summary */
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px,1fr));
    gap: 12px;
    margin-bottom: 16px;
  }
  .summary-item {
    background: #f9f9fd;
    border: 1px solid #ececf5;
    border-radius: 10px;
    padding: 14px;
    text-align: center;
  }
  .summary-num { font-size: 28px; font-weight: 700; color: #4361ee; }
  .summary-label { font-size: 12px; color: #6b7280; margin-top: 4px; font-weight: 600; }

  .skipped-box {
    background: #fff8f1;
    border: 1px solid #fcd9b0;
    border-radius: 10px;
    padding: 14px;
    font-size: 13px;
    color: #92400e;
    line-height: 1.6;
    white-space: pre-wrap;
    font-family: "SFMono-Regular", Consolas, monospace;
    max-height: 200px;
    overflow-y: auto;
    margin-top: 12px;
  }

  /* Toast */
  #alt-toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .toast {
    padding: 13px 18px;
    border-radius: 10px;
    color: #fff;
    min-width: 260px;
    max-width: 380px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.16);
    font-size: 14px;
    font-weight: 500;
    animation: toastIn 0.25s ease;
    line-height: 1.4;
  }
  .toast.success { background: linear-gradient(135deg,#2e7d32,#43a047); }
  .toast.error   { background: linear-gradient(135deg,#c62828,#e53935); }
  .toast.info    { background: linear-gradient(135deg,#1565c0,#1976d2); }
  .toast.warning { background: linear-gradient(135deg,#e65100,#ef6c00); }
  @keyframes toastIn {
    from { opacity:0; transform:translateX(20px); }
    to   { opacity:1; transform:translateX(0); }
  }

  @media (max-width: 680px) {
    .alt-tool { margin: 16px auto; }
    .alt-header { padding: 18px; }
    .alt-header-title { font-size: 18px; }
    .search-row { flex-direction: column; }
    .summary-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<div class="alt-tool">

  <!-- HEADER -->
  <div class="alt-header">
    <div class="alt-header-icon">🏷️</div>
    <div>
      <div class="alt-header-title">{{ section.settings.section_title }}</div>
      <div class="alt-header-sub">{{ section.settings.section_subtitle }}</div>
    </div>
  </div>

  <!-- SEARCH -->
  <div class="alt-card">
    <div class="alt-card-title"><span>🔍</span> Search Product</div>
    <div class="search-row">
      <input type="text" id="altSearch" placeholder="Enter product name..." />
      <button class="btn btn-secondary" onclick="altSearchProduct()">Search</button>
    </div>
  </div>

  <!-- PRODUCT SELECT -->
  <div class="alt-card">
    <div class="alt-card-title"><span>📦</span> Select Product</div>
    <div class="field-group">
      <label>Product</label>
      <select id="altProducts" onchange="altOnProductChange()">
        <option value="">— search above —</option>
      </select>
    </div>
    <div class="field-group">
      <label>Variants to update</label>
      <div id="altVariantList" style="color:#9ca3af;font-size:13px;">Select a product first.</div>
    </div>
  </div>

  <!-- FILENAME + ALT INPUT -->
  <div class="alt-card">
    <div class="alt-card-title"><span>✏️</span> Filename &amp; Alt Tag List</div>
    <div class="field-group">
      <label>One entry per line — <code>filename.webp | Alt tag text</code></label>
      <textarea id="altPairsInput" placeholder="gothic-raven-crow-lamp-front.webp | Gothic raven crow lamp front view&#10;gothic-crow-lamp-detail.webp | Close-up resin feather detail on gothic crow lamp"></textarea>
      <div class="hint">
        • Line 1 maps to the 1st image URL in the metafield, line 2 to the 2nd, and so on.<br>
        • Videos (mp4, mov, webm, avi) are automatically skipped — they keep their position in the URL list.<br>
        • A variant-name suffix is added to each filename automatically to keep filenames unique across variants.<br>
        • If you provide fewer lines than images, remaining images are skipped and reported.
      </div>
    </div>
    <button class="btn btn-primary btn-full" id="altStartBtn" onclick="altStartUpdate()">
      🚀 Start Update
    </button>
  </div>

  <!-- PROGRESS -->
  <div class="alt-card" id="altProgressCard" style="display:none">
    <div class="alt-card-title"><span>📊</span> Progress</div>
    <div class="progress-pct" id="altOverallPct">0%</div>
    <div class="progress-wrap">
      <div class="progress-bar" id="altOverallBar"></div>
    </div>
    <div id="altVariantRows" style="margin-top:14px;"></div>
    <div class="log-box" id="altLogBox"></div>
  </div>

  <!-- SUMMARY -->
  <div class="alt-card" id="altSummaryCard" style="display:none">
    <div class="alt-card-title"><span>✅</span> Complete</div>
    <div class="summary-grid">
      <div class="summary-item">
        <div class="summary-num" id="sumVariants">0</div>
        <div class="summary-label">Variants processed</div>
      </div>
      <div class="summary-item">
        <div class="summary-num" id="sumUpdated">0</div>
        <div class="summary-label">Images updated</div>
      </div>
      <div class="summary-item">
        <div class="summary-num" id="sumVideos">0</div>
        <div class="summary-label">Videos skipped</div>
      </div>
      <div class="summary-item">
        <div class="summary-num" id="sumSkipped">0</div>
        <div class="summary-label">Images skipped<br>(no input line)</div>
      </div>
    </div>
    <div id="altSkippedDetail" style="display:none">
      <div style="font-size:13px;font-weight:700;color:#92400e;margin-bottom:6px;">⚠️ Images skipped (no filename/alt provided):</div>
      <div class="skipped-box" id="altSkippedBox"></div>
    </div>
  </div>

</div>

<div id="alt-toast-container"></div>

<script>
(function () {
  const API = {{ section.settings.api_url | default: 'http://localhost:5000' | json }};

  const VIDEO_EXTS = new Set(["mp4", "mov", "webm", "avi", "mkv", "flv", "wmv"]);

  let altProductData = []; // [{id, title, variants:[{id,title}]}]
  let altEventSource = null;

  /* ---- Helpers ---- */
  function showToast(msg, type = "info") {
    const c = document.getElementById("alt-toast-container");
    const t = document.createElement("div");
    t.className = `toast ${type}`;
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(() => t.remove(), 4500);
  }

  function escHtml(s) {
    return String(s || "")
      .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
      .replace(/"/g,"&quot;").replace(/'/g,"&#039;");
  }

  function addLog(msg, type = "") {
    const box = document.getElementById("altLogBox");
    const d = document.createElement("div");
    d.className = `log-item${type ? " log-item--" + type : ""}`;
    const t = new Date().toLocaleTimeString();
    d.textContent = `[${t}] ${msg}`;
    box.prepend(d);
  }

  function isVideoUrl(url) {
    try {
      const path = new URL(url).pathname;
      const ext = path.split(".").pop().toLowerCase().split("?")[0];
      return VIDEO_EXTS.has(ext);
    } catch {
      const ext = String(url).split(".").pop().toLowerCase().split("?")[0];
      return VIDEO_EXTS.has(ext);
    }
  }

  function parsePairs(raw) {
    return raw.split("\n")
      .map(l => l.trim())
      .filter(Boolean)
      .map(line => {
        const idx = line.indexOf("|");
        if (idx === -1) return { filename: line.trim(), altTag: "" };
        return {
          filename: line.slice(0, idx).trim(),
          altTag: line.slice(idx + 1).trim()
        };
      });
  }

  function setOverallProgress(pct) {
    document.getElementById("altOverallBar").style.width = `${Math.max(0, Math.min(100, pct))}%`;
    document.getElementById("altOverallPct").textContent = `${Math.round(pct)}%`;
  }

  function setVariantStatus(variantId, status, text) {
    const el = document.getElementById(`vstatus-${CSS.escape(variantId)}`);
    if (!el) return;
    el.className = `variant-status variant-status--${status}`;
    el.textContent = text;
  }

  /* ---- Search ---- */
  async function altSearchProduct() {
    const q = document.getElementById("altSearch").value.trim();
    if (!q) { showToast("Enter a product name to search", "error"); return; }
    showToast("Searching...", "info");
    try {
      const res = await fetch(`${API}/products?q=${encodeURIComponent(q)}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (!data.success || !data.products?.length) {
        showToast("No products found", "error"); return;
      }
      altProductData = data.products;
      const sel = document.getElementById("altProducts");
      sel.innerHTML = `<option value="">— select a product —</option>`;
      data.products.forEach(p => {
        const o = document.createElement("option");
        o.value = p.id;
        o.textContent = p.title;
        o.dataset.variants = JSON.stringify(p.variants?.edges || []);
        sel.appendChild(o);
      });
      showToast(`${data.products.length} product(s) found`, "success");
      altOnProductChange();
    } catch (err) {
      console.error(err);
      showToast("Search failed", "error");
    }
  }

  function altOnProductChange() {
    const sel = document.getElementById("altProducts");
    const opt = sel.selectedOptions[0];
    const container = document.getElementById("altVariantList");
    if (!opt || !opt.value) {
      container.innerHTML = `<span style="color:#9ca3af;font-size:13px;">Select a product first.</span>`;
      return;
    }
    const variants = JSON.parse(opt.dataset.variants || "[]");
    if (!variants.length) {
      container.innerHTML = `<span style="color:#9ca3af;font-size:13px;">No variants found.</span>`;
      return;
    }
    container.innerHTML = variants.map(v =>
      `<div class="variant-row">
        <div class="variant-row-name">${escHtml(v.node.title)}</div>
        <div class="variant-status variant-status--pending" id="vstatus-${escHtml(CSS.escape(v.node.id))}">Pending</div>
      </div>`
    ).join("");
  }

  /* ---- Main update ---- */
  async function altStartUpdate() {
    const productOpt = document.getElementById("altProducts").selectedOptions[0];
    if (!productOpt || !productOpt.value) {
      showToast("Select a product first", "error"); return;
    }
    const pairsRaw = document.getElementById("altPairsInput").value.trim();
    if (!pairsRaw) {
      showToast("Enter at least one filename | alt tag line", "error"); return;
    }

    const variants = JSON.parse(productOpt.dataset.variants || "[]")
      .map(v => ({ id: v.node.id, title: v.node.title }));

    if (!variants.length) {
      showToast("No variants on this product", "error"); return;
    }

    const pairs = parsePairs(pairsRaw);
    const productId = productOpt.value;

    // Reset UI
    document.getElementById("altProgressCard").style.display = "block";
    document.getElementById("altSummaryCard").style.display = "none";
    document.getElementById("altLogBox").innerHTML = "";
    setOverallProgress(0);
    document.getElementById("altStartBtn").disabled = true;

    // Re-render variant rows with pending state
    const variantRowsEl = document.getElementById("altVariantRows");
    variantRowsEl.innerHTML = variants.map(v =>
      `<div class="variant-row">
        <div class="variant-row-name">${escHtml(v.title)}</div>
        <div class="variant-status variant-status--pending" id="vstatus-${escHtml(v.id)}">Pending</div>
      </div>`
    ).join("");

    // Counters
    let totalUpdated = 0;
    let totalVideos = 0;
    let totalSkipped = 0;
    const skippedDetails = [];

    addLog(`Starting update for ${variants.length} variant(s)...`, "info");

    for (let vi = 0; vi < variants.length; vi++) {
      const variant = variants[vi];
      setVariantStatus(variant.id, "running", "⏳ Running...");
      addLog(`[${variant.title}] Starting...`, "info");

      try {
        const result = await processVariant(productId, variant, pairs);
        totalUpdated += result.updated;
        totalVideos  += result.videos;
        totalSkipped += result.skipped;

        if (result.skippedUrls.length) {
          skippedDetails.push(`▸ ${variant.title}:\n` +
            result.skippedUrls.map((u, i) => `  [pos ${u.pos}] ${u.url}`).join("\n")
          );
        }

        const label = `✅ ${result.updated} updated${result.skipped ? `, ${result.skipped} skipped` : ""}`;
        setVariantStatus(variant.id, "done", label);
        addLog(`[${variant.title}] Done — ${result.updated} updated, ${result.videos} videos kept, ${result.skipped} skipped`, "success");
      } catch (err) {
        setVariantStatus(variant.id, "error", "❌ Error");
        addLog(`[${variant.title}] Error: ${err.message}`, "error");
      }

      setOverallProgress(((vi + 1) / variants.length) * 100);
    }

    // Show summary
    document.getElementById("sumVariants").textContent = variants.length;
    document.getElementById("sumUpdated").textContent  = totalUpdated;
    document.getElementById("sumVideos").textContent   = totalVideos;
    document.getElementById("sumSkipped").textContent  = totalSkipped;

    if (skippedDetails.length) {
      document.getElementById("altSkippedDetail").style.display = "block";
      document.getElementById("altSkippedBox").textContent = skippedDetails.join("\n\n");
    } else {
      document.getElementById("altSkippedDetail").style.display = "none";
    }

    document.getElementById("altSummaryCard").style.display = "block";
    document.getElementById("altStartBtn").disabled = false;

    const msg = totalSkipped
      ? `Complete — ${totalUpdated} updated, ${totalSkipped} image(s) skipped (no input line provided)`
      : `All done — ${totalUpdated} image(s) updated across ${variants.length} variant(s)`;
    showToast(msg, totalSkipped ? "warning" : "success");
    addLog(msg, totalSkipped ? "warn" : "success");
  }

  /* ---- Process a single variant ---- */
  async function processVariant(productId, variant, pairs) {
    // 1. Fetch metafield URLs
    const metaRes = await fetch(
      `${API}/variant-metafield?variantId=${encodeURIComponent(variant.id)}&namespace=custom&key=images`
    );
    if (!metaRes.ok) throw new Error(`HTTP ${metaRes.status} fetching metafield`);
    const metaData = await metaRes.json();
    if (!metaData.success) throw new Error(metaData.error || "Failed to load metafield");

    const rawValue = metaData.value || "";
    const urls = rawValue.split(",").map(u => u.trim()).filter(Boolean);

    if (!urls.length) {
      addLog(`[${variant.title}] Metafield empty — skipping`, "warn");
      return { updated: 0, videos: 0, skipped: 0, skippedUrls: [] };
    }

    // 2. Classify each URL by position
    const classified = urls.map((url, idx) => ({
      pos: idx + 1,
      url,
      isVideo: isVideoUrl(url)
    }));

    // 3. Map images (in order) to input pairs
    let imageIndex = 0;
    const skippedUrls = [];
    const newUrls = [...urls]; // will be updated in-place by position

    const variantSlug = variant.title
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-|-$/g, "");

    let updatedCount = 0;
    let videoCount   = classified.filter(c => c.isVideo).length;

    for (const item of classified) {
      if (item.isVideo) continue; // keep position, skip processing

      const pair = pairs[imageIndex];
      imageIndex++;

      if (!pair) {
        // No more input lines — skip this image
        skippedUrls.push({ pos: item.pos, url: item.url });
        addLog(`[${variant.title}] pos ${item.pos}: no input line — skipped`, "warn");
        continue;
      }

      // Build unique filename: insert --variant-slug before extension
      const dotIdx = pair.filename.lastIndexOf(".");
      const uniqueFilename = dotIdx !== -1
        ? `${pair.filename.slice(0, dotIdx)}--${variantSlug}${pair.filename.slice(dotIdx)}`
        : `${pair.filename}--${variantSlug}`;

      addLog(`[${variant.title}] pos ${item.pos}: renaming → ${uniqueFilename}`, "info");

      // 4. Call backend to rename file + update alt tag → get new URL
      const updateRes = await fetch(`${API}/update-file-alt`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          fileUrl: item.url,
          filename: uniqueFilename,
          altTag: pair.altTag
        })
      });

      if (!updateRes.ok) throw new Error(`HTTP ${updateRes.status} updating file`);
      const updateData = await updateRes.json();
      if (!updateData.success) throw new Error(updateData.error || "File update failed");

      // 5. Replace old URL with new URL at same position
      newUrls[item.pos - 1] = updateData.newUrl;
      updatedCount++;
      addLog(`[${variant.title}] pos ${item.pos}: ✅ updated → ${updateData.newUrl}`, "success");
    }

    // 6. Write back metafield with new URLs (same order, same count)
    const newMetaValue = newUrls.join(",");
    const saveRes = await fetch(`${API}/update-variant-metafield-raw`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        variantId: variant.id,
        namespace: "custom",
        key: "images",
        value: newMetaValue
      })
    });
    if (!saveRes.ok) throw new Error(`HTTP ${saveRes.status} saving metafield`);
    const saveData = await saveRes.json();
    if (!saveData.success) throw new Error(saveData.error || "Metafield save failed");

    addLog(`[${variant.title}] Metafield updated (${newUrls.length} URLs)`, "success");

    return {
      updated: updatedCount,
      videos: videoCount,
      skipped: skippedUrls.length,
      skippedUrls
    };
  }

  /* ---- Expose globals ---- */
  window.altSearchProduct   = altSearchProduct;
  window.altOnProductChange = altOnProductChange;
  window.altStartUpdate     = altStartUpdate;
})();
</script>
{% endif %}
