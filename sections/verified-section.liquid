<div class="trust-section  page-width" style="
  padding: {{ section.settings.padding_top }}px {{ section.settings.padding_sides }}px {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.background_color }};
">

<div class="trust-section__container"  style="max-width: {{ section.settings.container_width }}px; margin: 0 auto;">
  <div  >
    
    {% if section.settings.image != blank %}
      <div class="trust-section__image">
        <img 
          src="{{ section.settings.image | img_url: '200x200' }}" 
          alt="{{ section.settings.image_alt }}"
         
          style="border-radius: {{ section.settings.image_border_radius }}px;"
        >
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="trust-section__heading" style="
        color: {{ section.settings.heading_color }};
        font-size: {{ section.settings.heading_size }}px;
        margin-top: 20px;
      ">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.content != blank %}
      <div class="trust-section__content" style="
        color: {{ section.settings.text_color }};
        font-size: {{ section.settings.text_size }}px;
        line-height: 1.6;
      ">
        {{ section.settings.content }}
      </div>
    {% endif %}

    {% if section.settings.tagline != blank %}
      <div class="trust-section__tagline" style="
        color: {{ section.settings.tagline_color }};
        font-size: {{ section.settings.tagline_size }}px;
        font-weight: 600;
         
      ">
        {{ section.settings.tagline }}
      </div>
    {% endif %}

  </div>

   <div  >
    
    {% if section.settings.image1 != blank %}
      <div class="trust-section__image">
        <img 
          src="{{ section.settings.image1 | img_url: '200x200' }}" 
          alt="{{ section.settings.image1_alt }}"
         
          style="border-radius: {{ section.settings.image_border_radius }}px;"
        >
      </div>
    {% endif %}

    {% if section.settings.heading1 != blank %}
      <h2 class="trust-section__heading" style="
        color: {{ section.settings.heading_color }};
        font-size: {{ section.settings.heading_size }}px;
        margin-top: 20px;
      ">
        {{ section.settings.heading1 }}
      </h2>
    {% endif %}

    {% if section.settings.content1 != blank %}
      <div class="trust-section__content" style="
        color: {{ section.settings.text_color }};
        font-size: {{ section.settings.text_size }}px;
        line-height: 1.6;
      ">
        {{ section.settings.content1 }}
      </div>
    {% endif %}

    {% if section.settings.tagline1 != blank %}
      <div class="trust-section__tagline" style="
        color: {{ section.settings.tagline_color }};
        font-size: {{ section.settings.tagline_size }}px;
        font-weight: 600;
         
      ">
        {{ section.settings.tagline1 }}
      </div>
    {% endif %}

  </div>
</div>
</div>
<style>
  .trust-section {
    width: 100%;
  }

  .trust-section__container {
    display: flex;
     justify-content: space-between;
     gap:20px;
  }

 

 .trust-section__container > div {
   width:48%;
    background: wheat;
    padding: 15px;
    border-radius: 15px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
}


  .trust-section__image img {
    width: 120px;
    height: 120px;
    object-fit: cover;
  }

  .trust-section__heading {
    font-weight: 700;
    margin-bottom: 15px;
  }

  .trust-section__content {
    margin-bottom: 10px;
  }

  .trust-section__content p {
    margin-bottom: 15px;
  }

  .trust-section__tagline {
    line-height: 1.4;
  }

  @media screen and (max-width: 768px) {
    .trust-section__heading {
      font-size: 24px !important;
    }
    
    .trust-section__content {
      font-size: 14px !important;
    }
    
    .trust-section__tagline {
      font-size: 16px !important;
    }


     .trust-section__container {
   flex-direction:column;
  }

 .trust-section__container > div{
  width:100%;
}
  }
</style>

{% schema %}
{
  "name": "Trust Verification",
  "tag": "section",
  "class": "trust-verification-section",
  "settings": [
