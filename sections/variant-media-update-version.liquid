 
 
 
    {%- liquid
  assign access_allowed = false
  assign required_tag = section.settings.required_tag | strip | downcase

  if section.settings.require_login == false
    assign access_allowed = true
  elsif customer
    if required_tag == blank
      assign access_allowed = true
    else
      for customer_tag in customer.tags
        assign normalized_customer_tag = customer_tag | strip | downcase

        if normalized_customer_tag == required_tag
          assign access_allowed = true
          break
        endif
      endfor
    endif
  endif
-%}

{% if access_allowed %}
   <style>
  .variant-media-uploader-section .app-container {
    max-width: {{ section.settings.max_width }}px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="app-container">

  <!-- HEADER -->
  <div class="app-header">
    <div class="app-header-icon">🛍️</div>
    <div>
      <div class="app-header-title">{{ section.settings.section_title }}</div>
      <div class="app-header-sub">{{ section.settings.section_subtitle }}</div>
    </div>
  </div>

  <!-- SEARCH -->
  <div class="card">
    <div class="card-title">
      <span class="card-icon">🔍</span>
      Search Product
    </div>
    <div class="search-row">
      <input type="text" id="search" placeholder="Enter product name..." />
      <button class="btn btn-secondary" onclick="searchProduct()">Search</button>
    </div>
  </div>

  <!-- PRODUCT & VARIANT -->
  <div class="card">
    <div class="card-title">
      <span class="card-icon">📦</span>
      Select Product &amp; Variant
    </div>
    <div class="field-group">
      <label>Product</label>
      <select id="products"></select>
    </div>
    <div class="field-group">
      <label>Variant</label>
      <select id="variants"></select>
    </div>
  </div>

  <!-- UPLOAD -->
  <div class="card">
    <div class="card-title">
      <span class="card-icon">📤</span>
      Upload Media
    </div>

    <div class="drop-zones-row">

      <!-- IMAGE DROP ZONE -->
      <div class="drop-zone-wrapper">
        <div class="drop-zone-label drop-zone-label--images">
          <span>🖼️</span> Images → Shopify
        </div>
        <div id="imageDropZone" class="drop-zone drop-zone--images">
          <input type="file" id="images" multiple accept="image/*" />
          <div class="drop-zone-content">
            <div class="drop-icon">📷</div>
            <div class="drop-title">Drag &amp; Drop Images</div>
            <div class="drop-subtitle">JPG, PNG, WebP, GIF, AVIF</div>
            <div class="drop-file-count" id="selectedImageCount">No files selected</div>
          </div>
        </div>
      </div>

      <!-- VIDEO DROP ZONE -->
      <div class="drop-zone-wrapper">
        <div class="drop-zone-label drop-zone-label--videos">
          <span>🎬</span> Videos → Bunny.net
        </div>
        <div id="videoDropZone" class="drop-zone drop-zone--videos">
          <input type="file" id="videos" multiple accept="video/*" />
          <div class="drop-zone-content">
            <div class="drop-icon">🎥</div>
            <div class="drop-title">Drag &amp; Drop Videos</div>
            <div class="drop-subtitle">MP4, MOV, WebM, AVI · Serial from filename (e.g. 3-name.mp4)</div>
            <div class="drop-file-count" id="selectedVideoCount">No files selected</div>
          </div>
        </div>
      </div>

    </div>

    <button class="btn btn-primary btn-upload" id="uploadBtn" onclick="uploadAll()">
      ⬆️ Upload All
    </button>
  </div>

  <!-- PROGRESS -->
  <div class="card" id="progressSection" style="display:none">
    <div class="card-title">
      <span class="card-icon">📊</span>
      Upload Progress
    </div>

    <!-- IMAGE PROGRESS -->
    <div id="imageProgressBlock" class="progress-block" style="display:none">
      <div class="progress-block-header">
        <div class="progress-block-title">🖼️ Images</div>
        <div class="progress-block-pct" id="imageProgressPercent">0%</div>
      </div>
      <div class="progress-wrap">
        <div class="progress-bar progress-bar--images" id="imageProgressBar"></div>
      </div>
      <div class="status-box status-box--images" id="imageProgressMessage">Waiting...</div>
    </div>

    <!-- VIDEO PROGRESS -->
    <div id="videoProgressBlock" class="progress-block" style="display:none">
      <div class="progress-block-header">
        <div class="progress-block-title">🎬 Videos</div>
        <div class="progress-block-pct" id="videoProgressPercent">0%</div>
      </div>
      <div class="progress-wrap">
        <div class="progress-bar progress-bar--videos" id="videoProgressBar"></div>
      </div>
      <div class="status-box status-box--videos" id="videoProgressMessage">Waiting...</div>
    </div>

    <div class="log-box" id="logBox"></div>
  </div>

  <!-- VERIFICATION -->
  <div class="card" id="verificationCard" style="display:none">
    <div class="card-title">
      <span class="card-icon">✅</span>
      Verification
    </div>
    <div class="verify-grid">
      <div class="verify-item">
        <div class="verify-label">Variant Media Assigned</div>
        <div class="verify-value" id="verifyVariantMedia">-</div>
      </div>
      <div class="verify-item">
        <div class="verify-label">Metafield Confirmed</div>
        <div class="verify-value" id="verifyMetafield">-</div>
      </div>
    </div>
    <div class="verify-url-label">Saved Metafield Value</div>
    <div class="verify-block" id="verifyMetafieldValue">-</div>
  </div>

  <!-- MEDIA MANAGEMENT -->
  <div class="card">
    <div class="card-title">
      <span class="card-icon">🗑️</span>
      Media Management
    </div>
    <button class="btn btn-danger" onclick="confirmDeleteMedia()">
      Delete Existing Media
    </button>
  </div>

  <!-- VARIANT URL EDITOR -->
  <div class="card">
    <div class="card-title">
      <span class="card-icon">🧩</span>
      Variant URL Editor
    </div>

    <div class="field-group">
      <label>Current Main Variant Image URL</label>
      <input type="text" id="currentVariantImageUrl" placeholder="Variant image URL will appear here" readonly />
    </div>

    <div class="editor-header">
      <div class="editor-header-title">Metafield URLs (Images &amp; Videos combined)</div>
      <button class="btn btn-secondary btn-sm" onclick="loadVariantEditorData()">↺ Refresh</button>
    </div>

    <div id="metafieldUrlFields" class="metafield-fields"></div>

    <div class="editor-actions">
      <button class="btn btn-primary" onclick="updateMetafieldOnly()">
        💾 Update Metafield
      </button>
    </div>
  </div>

</div>

<div id="toast-container"></div>

