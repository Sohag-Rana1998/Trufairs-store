<script>
  const API = {{ section.settings.api_url | default: 'http://localhost:5000' | json }};

  // SSE listeners
  let imageEventSource = null;
  let videoEventSource = null;

  // Pending serial results for merge (null = still in progress, [] = done/skipped)
  let pendingImageSerials = null;
  let pendingVideoSerials = null;
  let uploadAllDone = false; // prevents double-fire if both SSE and XHR fallback resolve

  /* ---- Toast ---- */
  function showToast(message, type = "info") {
    const container = document.getElementById("toast-container");
    const toast = document.createElement("div");
    toast.className = `toast ${type}`;
    toast.innerText = message;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  }

  /* ---- Upload button ---- */
  function setUploadButtonState(disabled) {
    document.getElementById("uploadBtn").disabled = disabled;
  }

  /* ---- Log ---- */
  function addLog(message, type = "") {
    const logBox = document.getElementById("logBox");
    const item = document.createElement("div");
    item.className = `log-item${type ? " log-item--" + type : ""}`;
    const time = new Date().toLocaleTimeString();
    item.textContent = `[${time}] ${message}`;
    logBox.prepend(item);
  }

  /* ---- XSS-safe HTML escape ---- */
  function escapeHtml(str) {
    return String(str || "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  /* ---- Serial extraction ---- */
  function extractFileNumber(filename) {
    const base = String(filename || "").split("/").pop();
    const match = base.match(/(\d+)/);
    return match ? parseInt(match[1], 10) : Number.MAX_SAFE_INTEGER;
  }

  // Video: first integer before first "-"
  function extractVideoSerial(filename) {
    const base = String(filename || "").split(/[\/\\]/).pop().replace(/\.[^/.]+$/, "");
    const beforeDash = base.split("-")[0];
    const match = beforeDash.match(/^(\d+)/);
    return match ? parseInt(match[1], 10) : Number.MAX_SAFE_INTEGER;
  }

  /* ---- UUID ---- */
  function generateUploadId() {
    if (window.crypto && crypto.randomUUID) return crypto.randomUUID();
    return "upload_" + Date.now() + "_" + Math.random().toString(36).slice(2);
  }

  /* ---- File count display ---- */
  function updateSelectedImageCount() {
    const files = document.getElementById("images").files;
    const el = document.getElementById("selectedImageCount");
    el.textContent = files && files.length
      ? `${files.length} file(s) selected`
      : "No files selected";
  }

  function updateSelectedVideoCount() {
    const files = document.getElementById("videos").files;
    const el = document.getElementById("selectedVideoCount");
    el.textContent = files && files.length
      ? `${files.length} file(s) selected`
      : "No files selected";
  }

  /* ---- Progress UI ---- */
  function setImageProgress(percent, message) {
    document.getElementById("imageProgressBar").style.width = `${Math.max(0, Math.min(100, percent))}%`;
    document.getElementById("imageProgressPercent").textContent = `${Math.round(percent)}%`;
    if (message !== undefined) {
      document.getElementById("imageProgressMessage").textContent = message;
    }
  }

  function setVideoProgress(percent, message) {
    document.getElementById("videoProgressBar").style.width = `${Math.max(0, Math.min(100, percent))}%`;
    document.getElementById("videoProgressPercent").textContent = `${Math.round(percent)}%`;
    if (message !== undefined) {
      document.getElementById("videoProgressMessage").textContent = message;
    }
  }

  /* ---- SSE listeners ---- */
  function closeImageProgressListener() {
    if (imageEventSource) { imageEventSource.close(); imageEventSource = null; }
  }

  function closeVideoProgressListener() {
    if (videoEventSource) { videoEventSource.close(); videoEventSource = null; }
  }

  function startImageProgressListener(uploadId) {
    closeImageProgressListener();
    imageEventSource = new EventSource(`${API}/progress/${encodeURIComponent(uploadId)}`);

    imageEventSource.onmessage = (event) => {
      try {
        const data = JSON.parse(event.data);
        setImageProgress(data.percent || 0, data.message || "");
        if (data.message) addLog(`[Images] ${data.message}`, "image");

        if (data.done) {
          closeImageProgressListener();

          if (data.error) {
            showToast(`Image upload failed: ${data.message}`, "error");
            pendingImageSerials = [];
          } else {
            const serials = (data.meta?.imageSerialFields || [])
              .filter(s => s.serial !== undefined && s.url)
              .map(s => ({ serial: Number(s.serial), url: s.url, type: "image" }));
            pendingImageSerials = serials;
            showToast(`Images uploaded (${serials.length} file(s))`, "success");

            // Update verification panel
            if (data.meta) {
              document.getElementById("verificationCard").style.display = "block";
              document.getElementById("verifyVariantMedia").textContent =
                data.meta.variantMediaConfirmed === true ? "✅ Yes" :
                data.meta.variantMediaConfirmed === false ? "❌ No" : "-";
              document.getElementById("verifyMetafield").textContent =
                data.meta.metafieldConfirmed === true ? "✅ Yes" :
                data.meta.metafieldConfirmed === false ? "❌ No" : "-";
              document.getElementById("verifyMetafieldValue").textContent =
                data.meta.confirmedValue || data.meta.metafieldValue || "-";
            }
          }

          checkBothDone();
        }
      } catch (err) {
        console.error("Image SSE parse error:", err);
      }
    };

    imageEventSource.onerror = () => console.warn("Image SSE interrupted");
  }

  function startVideoProgressListener(videoUploadId) {
    closeVideoProgressListener();
    videoEventSource = new EventSource(`${API}/progress/${encodeURIComponent(videoUploadId)}`);

    videoEventSource.onmessage = (event) => {
      try {
        const data = JSON.parse(event.data);
        setVideoProgress(data.percent || 0, data.message || "");
        if (data.message) addLog(`[Videos] ${data.message}`, "video");

        if (data.done) {
          closeVideoProgressListener();

          if (data.error) {
            showToast(`Video upload failed: ${data.message}`, "error");
            pendingVideoSerials = [];
          } else {
            const videos = data.meta?.videos || [];
            const serials = videos
              .filter(v => v.hasSerial && v.url)
              .map(v => ({ serial: Number(v.serial), url: v.url, type: "video" }));
            pendingVideoSerials = serials;

            const noSerial = videos.filter(v => !v.hasSerial).length;
            if (noSerial) {
              showToast(`${noSerial} video(s) have no serial number before "-" — skipped from serial ordering`, "warning");
            }
            showToast(`Videos uploaded to Bunny.net (${serials.length} serialised)`, "success");
          }

          checkBothDone();
        }
      } catch (err) {
        console.error("Video SSE parse error:", err);
      }
    };

    videoEventSource.onerror = () => console.warn("Video SSE interrupted");
  }

  /* ---- Merge serial results (videos take priority at collision) ---- */
  function mergeSerialResults(imageSerials, videoSerials) {
    const merged = new Map();

    // Images first (lower priority)
    for (const item of (imageSerials || [])) {
      if (item.serial !== Number.MAX_SAFE_INTEGER && item.url) {
        merged.set(item.serial, item);
      }
    }

    // Videos override images at same serial
    for (const item of (videoSerials || [])) {
      if (item.serial !== Number.MAX_SAFE_INTEGER && item.url) {
        merged.set(item.serial, item);
      }
    }

    return [...merged.entries()]
      .sort((a, b) => a[0] - b[0])
      .map(([, item]) => item);
  }

  /* ---- Check if both uploads finished; then merge + render ---- */
  function checkBothDone() {
    if (uploadAllDone) return;
    if (pendingImageSerials === null || pendingVideoSerials === null) return;

    uploadAllDone = true;

    const merged = mergeSerialResults(pendingImageSerials, pendingVideoSerials);
    const serialFields = merged.map(item => ({ serial: item.serial, url: item.url }));
    renderMetafieldFields(serialFields);

    setUploadButtonState(false);

    if (merged.length > 0) {
      showToast("All uploads complete — review URLs below before saving", "success");
    }
  }

  /* ---- Render URL editor fields (dynamic, not fixed 10) ---- */
  function renderMetafieldFields(serialFields = [], extraEmptySlots = 3) {
    const container = document.getElementById("metafieldUrlFields");
    container.innerHTML = "";

    const fieldMap = new Map();
    serialFields.forEach(item => {
      fieldMap.set(Number(item.serial), item.url || "");
    });

    const maxSerial = serialFields.length > 0
      ? Math.max(...serialFields.map(f => Number(f.serial)))
      : 0;

    const totalSlots = Math.min(Math.max(maxSerial, 1) + extraEmptySlots, 100);

    for (let i = 1; i <= totalSlots; i++) {
      const row = document.createElement("div");
      row.className = "url-row";
      row.innerHTML = `
        <div class="url-badge">No.${i}</div>
        <input
          type="text"
          class="metafield-url-input"
          data-serial="${i}"
          placeholder="Image or video URL for position ${i}"
          value="${escapeHtml(fieldMap.get(i) || "")}"
        />
      `;
      container.appendChild(row);
    }
  }

  /* ---- Reset UI ---- */
  function resetProgressUI(clearFiles = false) {
    document.getElementById("progressSection").style.display = "none";
    document.getElementById("imageProgressBlock").style.display = "none";
    document.getElementById("videoProgressBlock").style.display = "none";
    document.getElementById("verificationCard").style.display = "none";

    setImageProgress(0, "Waiting...");
    setVideoProgress(0, "Waiting...");
    document.getElementById("logBox").innerHTML = "";
    document.getElementById("verifyVariantMedia").textContent = "-";
    document.getElementById("verifyMetafield").textContent = "-";
    document.getElementById("verifyMetafieldValue").textContent = "-";

    if (clearFiles) {
      document.getElementById("images").value = "";
      document.getElementById("videos").value = "";
      updateSelectedImageCount();
      updateSelectedVideoCount();
    }

    setUploadButtonState(false);
    closeImageProgressListener();
    closeVideoProgressListener();
    uploadAllDone = false;
    pendingImageSerials = null;
    pendingVideoSerials = null;
  }

  /* ---- Product search ---- */
  async function searchProduct() {
    const q = document.getElementById("search").value.trim();
    if (!q) { showToast("Please enter a search term", "error"); return; }

    showToast("Searching products...", "info");

    try {
      const res = await fetch(`${API}/products?q=${encodeURIComponent(q)}`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data = await res.json();
      const productSelect = document.getElementById("products");
      const variantSelect = document.getElementById("variants");

      productSelect.innerHTML = "";
      variantSelect.innerHTML = "";

      if (!data.success || !Array.isArray(data.products) || !data.products.length) {
        resetProgressUI(true);
        document.getElementById("currentVariantImageUrl").value = "";
        renderMetafieldFields([]);
        showToast("No products found", "error");
        return;
      }

      data.products.forEach(product => {
        const option = document.createElement("option");
        option.value = product.id;
        option.textContent = product.title;
        option.dataset.variants = JSON.stringify(product.variants?.edges || []);
        productSelect.appendChild(option);
      });

      resetProgressUI(true);
      loadVariants();
      await loadVariantEditorData();
      showToast(`${data.products.length} product(s) found`, "success");
    } catch (err) {
      console.error("Search error:", err);
      showToast("Failed to fetch products", "error");
    }
  }

  /* ---- Load variants dropdown ---- */
  function loadVariants() {
    const product = document.getElementById("products").selectedOptions[0];
    if (!product) return;

    const variants = JSON.parse(product.dataset.variants || "[]");
    const variantSelect = document.getElementById("variants");
    variantSelect.innerHTML = "";

    if (!variants.length) {
      const option = document.createElement("option");
      option.value = "";
      option.textContent = "No variants found";
      variantSelect.appendChild(option);
      return;
    }

    variants.forEach(v => {
      const option = document.createElement("option");
      option.value = v.node.id;
      option.textContent = v.node.title;
      variantSelect.appendChild(option);
    });
  }

  /* ---- Delete media ---- */
  function confirmDeleteMedia() {
    const confirmed = confirm(
      "Are you sure you want to delete the existing Shopify media? This action cannot be undone."
    );
    if (confirmed) deleteMedia();
  }

  async function deleteMedia() {
    const productId = document.getElementById("products").value;
    const variantId = document.getElementById("variants").value;

    if (!productId) { showToast("Select a product first", "error"); return; }

    showToast("Deleting media...", "info");

    try {
      const res = await fetch(`${API}/delete-media`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ productId, variantId }),
      });

      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.details || data.error || "Delete failed");

      showToast(`Deleted ${data.deletedCount || 0} media item(s)`, "success");
      resetProgressUI(true);
      await loadVariantEditorData();
    } catch (err) {
      console.error("Delete media error:", err);
      showToast(err.message || "Failed to delete media", "error");
    }
  }

  /* ---- Image XHR upload ---- */
  function doImageUpload(uploadId, productId, variantId, files) {
    return new Promise((resolve, reject) => {
      const formData = new FormData();
      formData.append("uploadId", uploadId);
      formData.append("productId", productId);
      formData.append("variantId", variantId);
      for (const file of files) formData.append("images", file);

      addLog("Image upload started...", "image");

      const xhr = new XMLHttpRequest();
      xhr.open("POST", `${API}/upload`);

      xhr.upload.onprogress = (e) => {
        if (e.lengthComputable) {
          const pct = Math.round((e.loaded / e.total) * 100);
          setImageProgress(pct * 0.35, `Uploading images from browser... ${pct}%`);
        }
      };

      xhr.onload = () => {
        let data = {};
        try { data = JSON.parse(xhr.responseText || "{}"); } catch {}
        if (xhr.status >= 200 && xhr.status < 300 && data.success) {
          // Fallback: populate serials from XHR response if SSE hasn't done it yet
          if (pendingImageSerials === null) {
            pendingImageSerials = (data.imageSerialFields || [])
              .filter(s => s.url)
              .map(s => ({ serial: Number(s.serial), url: s.url, type: "image" }));
            checkBothDone();
          }
          resolve(data);
        } else {
          const msg = data.details || data.error || "Image upload error";
          addLog(`Image upload failed: ${msg}`, "error");
          if (pendingImageSerials === null) { pendingImageSerials = []; checkBothDone(); }
          reject(new Error(msg));
        }
      };

      xhr.onerror = () => {
        addLog("Image upload: network error", "error");
        if (pendingImageSerials === null) { pendingImageSerials = []; checkBothDone(); }
        reject(new Error("Network error during image upload"));
      };

      xhr.send(formData);
    });
  }

  /* ---- Video XHR upload ---- */
  function doVideoUpload(videoUploadId, files) {
    return new Promise((resolve, reject) => {
      const formData = new FormData();
      formData.append("videoUploadId", videoUploadId);
      for (const file of files) formData.append("videos", file);

      addLog("Video upload started...", "video");

      const xhr = new XMLHttpRequest();
      xhr.open("POST", `${API}/upload-videos`);

      xhr.upload.onprogress = (e) => {
        if (e.lengthComputable) {
          const pct = Math.round((e.loaded / e.total) * 100);
          setVideoProgress(pct * 0.35, `Uploading videos from browser... ${pct}%`);
        }
      };

      xhr.onload = () => {
        let data = {};
        try { data = JSON.parse(xhr.responseText || "{}"); } catch {}
        if (xhr.status >= 200 && xhr.status < 300 && data.success) {
          // Fallback: populate serials from XHR response if SSE hasn't done it yet
          if (pendingVideoSerials === null) {
            pendingVideoSerials = (data.videos || [])
              .filter(v => v.hasSerial && v.url)
              .map(v => ({ serial: Number(v.serial), url: v.url, type: "video" }));
            checkBothDone();
          }
          resolve(data);
        } else {
          const msg = data.details || data.error || "Video upload error";
          addLog(`Video upload failed: ${msg}`, "error");
          if (pendingVideoSerials === null) { pendingVideoSerials = []; checkBothDone(); }
          reject(new Error(msg));
        }
      };

      xhr.onerror = () => {
        addLog("Video upload: network error", "error");
        if (pendingVideoSerials === null) { pendingVideoSerials = []; checkBothDone(); }
        reject(new Error("Network error during video upload"));
      };

      xhr.send(formData);
    });
  }

  /* ---- Main upload orchestrator ---- */
  function uploadAll() {
    const imageFiles = document.getElementById("images").files;
    const videoFiles = document.getElementById("videos").files;
    const productId = document.getElementById("products").value;
    const variantId = document.getElementById("variants").value;

    if (!productId) { showToast("Select a product first", "error"); return; }
    if (!variantId) { showToast("Select a variant first", "error"); return; }
    if (!imageFiles.length && !videoFiles.length) {
      showToast("Select at least one image or video to upload", "error");
      return;
    }

    // Reset state for new upload
    uploadAllDone = false;
    pendingImageSerials = imageFiles.length ? null : [];
    pendingVideoSerials = videoFiles.length ? null : [];

    setUploadButtonState(true);

    // Show progress section
    const progressSection = document.getElementById("progressSection");
    progressSection.style.display = "block";
    document.getElementById("logBox").innerHTML = "";

    const imageBlock = document.getElementById("imageProgressBlock");
    const videoBlock = document.getElementById("videoProgressBlock");

    if (imageFiles.length) {
      imageBlock.style.display = "block";
      setImageProgress(0, "Starting...");
    } else {
      imageBlock.style.display = "none";
    }

    if (videoFiles.length) {
      videoBlock.style.display = "block";
      setVideoProgress(0, "Starting...");
    } else {
      videoBlock.style.display = "none";
    }

    // Fire both uploads simultaneously
    if (imageFiles.length) {
      const uploadId = generateUploadId();
      startImageProgressListener(uploadId);
      doImageUpload(uploadId, productId, variantId, imageFiles).catch(err => {
        // SSE done handler will set pendingImageSerials = [] and call checkBothDone
        console.error("Image upload XHR error:", err.message);
        // Fallback: if SSE never fires a done event, force resolve
        if (pendingImageSerials === null) {
          pendingImageSerials = [];
          checkBothDone();
        }
      });
    }

    if (videoFiles.length) {
      const videoUploadId = generateUploadId();
      startVideoProgressListener(videoUploadId);
      doVideoUpload(videoUploadId, videoFiles).catch(err => {
        console.error("Video upload XHR error:", err.message);
        if (pendingVideoSerials === null) {
          pendingVideoSerials = [];
          checkBothDone();
        }
      });
    }
  }

  /* ---- Load variant editor data (on variant change / refresh) ---- */
  async function loadVariantEditorData() {
    const variantId = document.getElementById("variants").value;

    if (!variantId) {
      document.getElementById("currentVariantImageUrl").value = "";
      renderMetafieldFields([]);
      return;
    }

    try {
      const res = await fetch(`${API}/variant-editor-data?variantId=${encodeURIComponent(variantId)}`);
      const data = await res.json();

      if (!res.ok || !data.success) {
        throw new Error(data.details || data.error || "Failed to load variant editor data");
      }

      document.getElementById("currentVariantImageUrl").value =
        data.currentVariantImageUrl || "";

      renderMetafieldFields(data.serialFields || []);
    } catch (err) {
      console.error("Variant editor data error:", err);
      showToast(err.message || "Failed to load variant URLs", "error");
    }
  }

  /* ---- Update metafield only ---- */
  async function updateMetafieldOnly() {
    const variantId = document.getElementById("variants").value;
    if (!variantId) { showToast("Select a variant first", "error"); return; }

    const inputs = [...document.querySelectorAll(".metafield-url-input")];
    const urls = inputs
      .sort((a, b) => Number(a.dataset.serial) - Number(b.dataset.serial))
      .map(input => input.value.trim())
      .filter(Boolean);

    try {
      const res = await fetch(`${API}/update-variant-metafield`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ variantId, urls }),
      });

      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.details || data.error || "Failed to update metafield");

      document.getElementById("verificationCard").style.display = "block";
      document.getElementById("verifyMetafield").textContent =
        data.metafieldConfirmed ? "✅ Yes" : "❌ No";
      document.getElementById("verifyMetafieldValue").textContent =
        data.confirmedValue || data.metafieldValue || "-";

      renderMetafieldFields(data.serialFields || []);
      showToast("Metafield updated successfully", "success");
    } catch (err) {
      console.error("Update metafield error:", err);
      showToast(err.message || "Failed to update metafield", "error");
    }
  }

  /* ---- Event listeners ---- */
  document.getElementById("products").addEventListener("change", async () => {
    resetProgressUI(true);
    loadVariants();
    await loadVariantEditorData();
  });

  document.getElementById("variants").addEventListener("change", async () => {
    resetProgressUI(true);
    await loadVariantEditorData();
  });

  // Image drop zone
  const imageDropZone = document.getElementById("imageDropZone");
  const imageInput = document.getElementById("images");

  ["dragenter", "dragover"].forEach(evt => {
    imageDropZone.addEventListener(evt, e => {
      e.preventDefault(); e.stopPropagation();
      imageDropZone.classList.add("dragover");
    });
  });
  ["dragleave", "drop"].forEach(evt => {
    imageDropZone.addEventListener(evt, e => {
      e.preventDefault(); e.stopPropagation();
      imageDropZone.classList.remove("dragover");
    });
  });
  imageDropZone.addEventListener("drop", e => {
    const files = e.dataTransfer.files;
    if (files && files.length) {
      imageInput.files = files;
      updateSelectedImageCount();
    }
  });
  imageInput.addEventListener("change", updateSelectedImageCount);

  // Video drop zone
  const videoDropZone = document.getElementById("videoDropZone");
  const videoInput = document.getElementById("videos");

  ["dragenter", "dragover"].forEach(evt => {
    videoDropZone.addEventListener(evt, e => {
      e.preventDefault(); e.stopPropagation();
      videoDropZone.classList.add("dragover");
    });
  });
  ["dragleave", "drop"].forEach(evt => {
    videoDropZone.addEventListener(evt, e => {
      e.preventDefault(); e.stopPropagation();
      videoDropZone.classList.remove("dragover");
    });
  });
  videoDropZone.addEventListener("drop", e => {
    const files = e.dataTransfer.files;
    if (files && files.length) {
      videoInput.files = files;
      updateSelectedVideoCount();
    }
  });
  videoInput.addEventListener("change", updateSelectedVideoCount);

  // Init
  renderMetafieldFields([]);
  resetProgressUI(true);
</script>
 


