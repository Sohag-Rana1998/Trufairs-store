      "label": "API Base URL",
      "default": "https://variant-image-uploader-trufairs.vercel.app",
      "info": "The base URL of your upload server. No trailing slash."
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Variant Media Uploader"
    },
    {
      "type": "text",
      "id": "section_subtitle",
      "label": "Section Subtitle",
      "default": "Upload images to Shopify · Upload videos to Bunny.net"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 600,
      "max": 1400,
      "step": 20,
