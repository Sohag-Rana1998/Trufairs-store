{% comment %}
  ** Promo Grid Section **
  - A responsive grid of promotional cards.
  - Customizable text and links for each card.
  - Background image with text overlay.
  - Control over the number of cards per row on desktop.
{% endcomment %}

<style>
  .promo-grid-section-{{ section.id }} {
    --cards-per-row: {{ section.settings.cards_per_row }};
    --grid-gap: 1.5rem; /* 24px */
  }

  .promo-grid-wrapper {
    padding: 2rem 1rem;
    max-width: 1440px;
    margin: 0 auto;
  }

  .promo-grid {
    display: grid;
    gap: var(--grid-gap);
    /* Mobile-first: 1 column by default */
    grid-template-columns: 1fr;
  }

  .promo-card {
    position: relative;
    border-radius: 1rem; /* 16px */
    overflow: hidden;
    text-decoration: none;
    color: white;
    display: flex;
    flex-direction: column;
    min-height: 300px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background-color: #f0f8ff; /* Fallback color */
  }

  .promo-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
  }

  .promo-card__background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .promo-card__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.2) 100%);
    z-index: 2;
  }

  .promo-card__content {
    position: relative;
    padding: 1.5rem; /* 24px */
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 3;
    text-align: center;
  }

  .promo-card__discount {
    font-size: 2.25rem; /* 36px */
    font-weight: 700;
    color: #ffffff;
    line-height: 1.1;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
  }

  .promo-card__title {
    font-size: 1.125rem; /* 18px */
    margin-top: 0.5rem;
    font-weight: 600;
    color: #ffffff;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
  }

  .promo-card__subtitle {
    font-size: 0.875rem; /* 14px */
    color: #f0f0f0;
    margin-top: 0.25rem;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
  }

  /* Responsive Grid - Tablet */
  @media (min-width: 768px) {
    .promo-grid {
      /* 2 columns for tablets */
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Responsive Grid - Desktop */
  @media (min-width: 1024px) {
    .promo-grid {
      /* Use the setting from the theme editor for desktops */
      grid-template-columns: repeat(var(--cards-per-row), 1fr);
    }
    .promo-grid-wrapper {
        padding: 3rem 2rem;
    }
    .promo-card {
      min-height: 350px;
    }
  }
</style>

<div class="promo-grid-section-{{ section.id }}" >
  <div class="promo-grid-wrapper">
    <div class="promo-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign card_link = block.settings.link
          assign card_tag = 'div'
          if card_link != blank
            assign card_tag = 'a'
          endif
        -%}

        <{{ card_tag }}
          href="{{ card_link | default: '#' }}"
          class="promo-card"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.background_image != blank %}
            <img
              src="{{ block.settings.background_image | image_url: width: 600 }}"
              alt="{{ block.settings.background_image.alt | default: block.settings.title }}"
              class="promo-card__background"
             
            >
          {% endif %}
          
          <div class="promo-card__overlay"></div>
          
          <div class="promo-card__content">
            {% if block.settings.discount_text != blank %}
              <div class="promo-card__discount">{{ block.settings.discount_text }}</div>
            {% endif %}
            {% if block.settings.title != blank %}
              <p class="promo-card__title">{{ block.settings.title }}</p>
            {% endif %}
            {% if block.settings.subtitle != blank %}
              <p class="promo-card__subtitle">{{ block.settings.subtitle }}</p>
            {% endif %}
          </div>
        </{{ card_tag }}>
      {% endfor %}
    </div>
  </div>
</div>

{% if section.blocks.size == 0 %}
  <div style="text-align: center; padding: 4rem;">
    <p>Add promo cards to this section in the theme editor.</p>
  </div>
{% endif %}


{% schema %}
{
  "name": "Promo Grid",
  "tag": "section",
  "class": "promo-grid-section",
  "settings": [
    {
      "type": "range",
      "id": "cards_per_row",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Cards per row (Desktop)",
      "info": "Controls how many cards are shown in a single row on large screens."
    }
  ],
  "blocks": [
    {
      "type": "promo_card",
      "name": "Promo Card",
      "limit": 10,
      "settings": [
        {
          "type": "header",
          "content": "Card Content"
        },
        {
          "type": "text",
          "id": "discount_text",
          "label": "Discount Text",
          "default": "20% off"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Promo Card Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Ends Saturday, 7/5"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Make the entire card clickable."
        },
        {
          "type": "header",
          "content": "Card Image"
        },
        {
          "type": "image_picker",
          "id": "background_image",
          "label": "Background Image",
          "info": "This image will be used as the card background with text overlay."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Grid Custom",
      "blocks": [
        { "type": "promo_card" },
        { "type": "promo_card" },
        { "type": "promo_card" },
        { "type": "promo_card" }
      ]
    }
  ]
}
{% endschema %}