{% style %}
  #shopify-section-{{ section.id }} .trufairs-process {
    background:
      radial-gradient(circle at top left, {{ section.settings.accent_color }}14 0, transparent 32%),
      linear-gradient(180deg, {{ section.settings.background_color }} 0%, {{ section.settings.background_color }} 100%);
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .trufairs-process__container {
    max-width: 1180px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .trufairs-process__header {
    max-width: 800px;
    margin: 0 auto 54px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .trufairs-process__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 16px;
    padding: 8px 14px;
    border-radius: 999px;
    background: {{ section.settings.accent_color }}14;
    color: {{ section.settings.accent_color }};
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .trufairs-process__heading {
    margin: 0 0 18px;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.045em;
  }

  #shopify-section-{{ section.id }} .trufairs-process__text {
    max-width: 720px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 1.75;
    color: {{ section.settings.muted_text_color }};
  }

  #shopify-section-{{ section.id }} .trufairs-process__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  #shopify-section-{{ section.id }} .trufairs-process__card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 420px;
    padding: 30px;
    border-radius: {{ section.settings.card_radius }}px;
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.border_color }};
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  #shopify-section-{{ section.id }} .trufairs-process__card:hover {
    transform: translateY(-6px);
    border-color: {{ section.settings.accent_color }}66;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.09);
  }

  /* #shopify-section-{{ section.id }} .trufairs-process__card::before {
    content: "";
    position: absolute;
    top: -90px;
    right: -90px;
    width: 190px;
    height: 190px;
    border-radius: 999px;
    background: {{ section.settings.accent_color }};
    opacity: 0.08;
  } */

  #shopify-section-{{ section.id }} .trufairs-process__card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(255,255,255,0.7), transparent 45%);
    opacity: 0.55;
  }

  #shopify-section-{{ section.id }} .trufairs-process__card-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .trufairs-process__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 28px;
  }

  #shopify-section-{{ section.id }} .trufairs-process__step-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    background: {{ section.settings.icon_background }};
    color: {{ section.settings.text_color }};
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .trufairs-process__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 28px;
    padding: 0 8px;
    border-radius: 999px;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_text_color }};
    font-size: 12px;
    font-weight: 800;
  }

  #shopify-section-{{ section.id }} .trufairs-process__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 58px;
    height: 58px;
    border-radius: 20px;
    background: {{ section.settings.icon_background }};
    color:#D2B57A;
  }

  #shopify-section-{{ section.id }} .trufairs-process__icon svg {
    width: 28px;
    height: 28px;
  }

  #shopify-section-{{ section.id }} .trufairs-process__icon img {
    display: block;
    width: 34px;
    height: 34px;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .trufairs-process__card-heading {
    margin: 0 0 12px;
    font-size: 23px;
    line-height: 1.22;
    font-weight: 800;
    letter-spacing: -0.025em;
  }

  #shopify-section-{{ section.id }} .trufairs-process__card-text {
    margin: 0 0 24px;
    font-size: 15.5px;
    line-height: 1.7;
    color: {{ section.settings.muted_text_color }};
  }

  #shopify-section-{{ section.id }} .trufairs-process__details {
    margin-top: auto;
    padding-top: 22px;
    border-top: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .trufairs-process__details-title {
    margin: 0 0 14px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .trufairs-process__list {
    display: grid;
    gap: 10px;
    margin: 0 0 20px;
    padding: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .trufairs-process__list-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 0;
    color: {{ section.settings.muted_text_color }};
    font-size: 14.5px;
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .trufairs-process__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 20px;
    height: 20px;
    margin-top: 1px;
    border-radius: 50%;
    background: {{ section.settings.accent_color }}18;
    color: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .trufairs-process__check svg {
    width: 12px;
    height: 12px;
  }

  #shopify-section-{{ section.id }} .trufairs-process__outcome {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    padding: 9px 13px;
    border-radius: 999px;
    background: {{ section.settings.accent_color }}12;
    color: {{ section.settings.text_color }};
    font-size: 13.5px;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .trufairs-process__outcome-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .trufairs-process__footer {
    max-width: 900px;
    margin: 46px auto 0;
    padding: 24px 28px;
    border-radius: {{ section.settings.card_radius }}px;
    background: {{ section.settings.note_background }};
    border: 1px solid {{ section.settings.border_color }};
    text-align: center;
    box-shadow: 0 14px 38px rgba(0, 0, 0, 0.04);
  }

  #shopify-section-{{ section.id }} .trufairs-process__footer p {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.75;
    color: {{ section.settings.muted_text_color }};
  }

  #shopify-section-{{ section.id }} .trufairs-process__footer strong {
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .trufairs-process__footer a {
    color: {{ section.settings.text_color }};
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media screen and (max-width: 990px) {
    #shopify-section-{{ section.id }} .trufairs-process__grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    #shopify-section-{{ section.id }} .trufairs-process__card {
      min-height: auto;
    }
  }

  @media screen and (max-width: 600px) {
    #shopify-section-{{ section.id }} .trufairs-process {
      padding: {{ section.settings.mobile_padding_top }}px 16px {{ section.settings.mobile_padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .trufairs-process__header {
      margin-bottom: 34px;
    }

    #shopify-section-{{ section.id }} .trufairs-process__heading {
      font-size: 34px;
    }

    #shopify-section-{{ section.id }} .trufairs-process__text {
      font-size: 16px;
    }

    #shopify-section-{{ section.id }} .trufairs-process__card {
      padding: 24px;
      border-radius: 22px;
    }

    #shopify-section-{{ section.id }} .trufairs-process__top {
      align-items: flex-start;
      margin-bottom: 24px;
    }

    #shopify-section-{{ section.id }} .trufairs-process__icon {
      width: 52px;
      height: 52px;
      border-radius: 18px;
    }

    #shopify-section-{{ section.id }} .trufairs-process__footer {
      padding: 22px;
      text-align: left;
    }
  }
{% endstyle %}

<section class="trufairs-process" aria-labelledby="trufairs-process-heading-{{ section.id }}">
  <div class="trufairs-process__container">

    <div class="trufairs-process__header">
      {% if section.settings.eyebrow != blank %}
        <p class="trufairs-process__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 id="trufairs-process-heading-{{ section.id }}" class="trufairs-process__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="trufairs-process__text">
          {{ section.settings.description }}
        </p>
      {% endif %}
    </div>

    <div class="trufairs-process__grid">
      {% for block in section.blocks %}
        <article class="trufairs-process__card" {{ block.shopify_attributes }}>
          <div class="trufairs-process__card-inner">

            <div class="trufairs-process__top">

<div class="trufairs-process__icon" aria-hidden="true">
                {% case block.settings.icon %}
                  {% when 'filter' %}
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M4 6h16M7 12h10M10 18h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>

                  {% when 'test' %}
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M9 3h6M10 3v6l-4.8 8.4A2.4 2.4 0 0 0 7.3 21h9.4a2.4 2.4 0 0 0 2.1-3.6L14 9V3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M8 16h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                    </svg>

                  {% when 'select' %}
                    <img
                      src="https://cdn.shopify.com/s/files/1/0859/6992/8495/files/Verified_logo_67e7060b-e85b-4d29-b7ba-5a380279e3e8.png?v=1777097300"
                      alt=""
                      width="34"
                      height="34"
                      loading="lazy"
                    >

                  {% else %}
                    <svg viewBox="0 0 24 24" fill="none">
                      <path d="M12 3l7 4v5c0 4.5-2.9 7.8-7 9-4.1-1.2-7-4.5-7-9V7l7-4z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                      <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                {% endcase %}
              </div>

              <div class="trufairs-process__step-label">
                 <span>{{ block.settings.step_label }}</span>
                <span class="trufairs-process__number">
                  {{ forloop.index   }}
                </span>
              
              </div>

              
            </div>

            {% if block.settings.title != blank %}
              <h3 class="trufairs-process__card-heading">
                {{ block.settings.title }}
              </h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p class="trufairs-process__card-text">
                {{ block.settings.text }}
              </p>
            {% endif %}

            <div class="trufairs-process__details">
              {% if block.settings.details_title != blank %}
                <p class="trufairs-process__details-title">
                  {{ block.settings.details_title }}
                </p>
              {% endif %}

              {% if block.settings.point_1 != blank or block.settings.point_2 != blank or block.settings.point_3 != blank %}
                <ul class="trufairs-process__list">
                  {% if block.settings.point_1 != blank %}
                    <li class="trufairs-process__list-item">
                      <span class="trufairs-process__check" aria-hidden="true">
                        <svg viewBox="0 0 16 16" fill="none">
                          <path d="M3.5 8.2l2.8 2.8 6.2-6.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span>{{ block.settings.point_1 }}</span>
                    </li>
                  {% endif %}

                  {% if block.settings.point_2 != blank %}
                    <li class="trufairs-process__list-item">
                      <span class="trufairs-process__check" aria-hidden="true">
                        <svg viewBox="0 0 16 16" fill="none">
                          <path d="M3.5 8.2l2.8 2.8 6.2-6.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span>{{ block.settings.point_2 }}</span>
                    </li>
                  {% endif %}

                  {% if block.settings.point_3 != blank %}
                    <li class="trufairs-process__list-item">
                      <span class="trufairs-process__check" aria-hidden="true">
                        <svg viewBox="0 0 16 16" fill="none">
                          <path d="M3.5 8.2l2.8 2.8 6.2-6.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span>{{ block.settings.point_3 }}</span>
                    </li>
                  {% endif %}
                </ul>
              {% endif %}

              {% if block.settings.outcome != blank %}
                <div class="trufairs-process__outcome">
                  <span class="trufairs-process__outcome-dot" aria-hidden="true"></span>
                  <span>{{ block.settings.outcome }}</span>
                </div>
              {% endif %}
            </div>

          </div>
        </article>
      {% endfor %}
    </div>

    {% if section.settings.note != blank %}
      <div class="trufairs-process__footer">
        {{ section.settings.note }}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "How Trufairs Works",
  "tag": "section",
  "class": "section-how-trufairs-works",
  "max_blocks": 3,
  "settings": [
