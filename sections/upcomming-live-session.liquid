{% comment %}
  Upcoming Live Session Section
  - A customizable section for showing upcoming product sessions with countdown timer
  - Features customizable title, session details, and countdown functionality
  - Countdown date/time is set through schema settings in the editor
{% endcomment %}

{{ 'section-upcoming-live-session.css' | asset_url | stylesheet_tag }}

<div class="upcoming-session-container page-width" id="upcoming-live-session-{{ section.id }}">
  {% if section.settings.title != blank %}
    <div class="upcoming-session-title">{{ section.settings.title }}</div>
  {% endif %}

  <div class="upcoming-session-content">
    <div class="session-details">
      {% if section.settings.badge_text != blank %}
        <span class="session-badge">{{ section.settings.badge_text }}</span>
      {% endif %}

      {% if section.settings.session_title != blank %}
        <h3 class="session-title">{{ section.settings.session_title }}</h3>
      {% endif %}
      
      {% if section.settings.session_description != blank %}
        <p class="session-description">{{ section.settings.session_description }}</p>
      {% endif %}

      <div class="session-meta">
        <div class="meta-item">
          <div class="meta-icon">
 
