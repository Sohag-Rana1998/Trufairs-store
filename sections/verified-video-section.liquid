  /* Custom Play/Pause Overlay for Hosted Videos */
.vq-custom-play-overlay {
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  user-select: none;
  -webkit-user-select: none;
}

.vq-overlay-button {
  pointer-events: none;
}

.vq-overlay-button svg {
  margin-left: 4px;
}

/* Ensure video container is positioned for overlay */
.vq-video-container[data-video-type="hosted"],
.vq-video-container[data-video-type="shopify"] {
  position: relative;
}

/* Hide native controls initially on custom overlay videos */
.vq-hosted-video {
  -webkit-tap-highlight-color: transparent;
}

/* Mobile touch improvements */
@media (hover: none) and (pointer: coarse) {
  .vq-overlay-button {
    opacity: 1 !important;
  }
  
  .vq-custom-play-overlay:active .vq-overlay-button {
    transform: scale(0.95);
  }
}

/* Ensure proper stacking on iOS */
@supports (-webkit-touch-callout: none) {
  .vq-custom-play-overlay {
    -webkit-tap-highlight-color: rgba(0,0,0,0);
  }
  
  .vq-hosted-video {
    -webkit-playsinline: true;
  }
}

</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // ============================================
    // VIDEO PLAYER FUNCTIONALITY - MOBILE OPTIMIZED
    // ============================================
    
    var videoContainers = document.querySelectorAll('.vq-video-container');

    videoContainers.forEach(function(container) {
      var videoType = container.dataset.videoType;
      var thumbnail = container.querySelector('.vq-video-thumbnail');
      var iframeContainer = container.querySelector('.vq-video-iframe');
      var playButton = container.querySelector('.vq-play-button');

      // ============================================
      // YOUTUBE & VIMEO HANDLING
      // ============================================
      if (thumbnail && (videoType === 'youtube' || videoType === 'vimeo')) {
        
        function loadVideo(e) {
          if (e) {
            e.preventDefault();
            e.stopPropagation();
          }
          
          var videoId = thumbnail.dataset.videoId;
          var iframeSrc = '';

          if (videoType === 'youtube') {
            iframeSrc = 'https://www.youtube.com/embed/' + videoId + '?autoplay=1&rel=0&modestbranding=1&playsinline=1';
          } else if (videoType === 'vimeo') {
            iframeSrc = 'https://player.vimeo.com/video/' + videoId + '?autoplay=1&title=0&byline=0&portrait=0&playsinline=1';
          }

          if (iframeSrc && iframeContainer) {
            var iframe = document.createElement('iframe');
            iframe.src = iframeSrc;
            iframe.width = '100%';
            iframe.height = '100%';
            iframe.style.aspectRatio = '16/9';
            iframe.style.border = 'none';
            iframe.style.borderRadius = '16px';
            iframe.style.position = 'absolute';
            iframe.style.top = '0';
            iframe.style.left = '0';
            iframe.setAttribute('allowfullscreen', '');
            iframe.setAttribute('webkitallowfullscreen', '');
            iframe.setAttribute('mozallowfullscreen', '');
            iframe.setAttribute('playsinline', '');
            iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');

            iframeContainer.innerHTML = '';
            iframeContainer.appendChild(iframe);
            iframeContainer.style.display = 'block';
            iframeContainer.style.position = 'relative';
            iframeContainer.style.paddingBottom = '56.25%';
            iframeContainer.style.height = '0';
            iframeContainer.style.overflow = 'hidden';
            thumbnail.style.display = 'none';
          }
        }

        // Click events
        thumbnail.addEventListener('click', loadVideo);
        if (playButton) {
          playButton.addEventListener('click', loadVideo);
        }

        // Touch events with scroll detection
        var touchStartY = 0;
        var touchStartX = 0;
        var touchStartTime = 0;

        function handleTouchStart(e) {
          touchStartY = e.touches[0].clientY;
          touchStartX = e.touches[0].clientX;
          touchStartTime = Date.now();
        }

        function handleTouchEnd(e) {
          var touchEndY = e.changedTouches[0].clientY;
          var touchEndX = e.changedTouches[0].clientX;
          var touchEndTime = Date.now();
          
          var deltaY = Math.abs(touchEndY - touchStartY);
          var deltaX = Math.abs(touchEndX - touchStartX);
          var deltaTime = touchEndTime - touchStartTime;
          
          // Tap detection: small movement and quick touch
          if (deltaY < 15 && deltaX < 15 && deltaTime < 300) {
            e.preventDefault();
            loadVideo(e);
          }
        }

        thumbnail.addEventListener('touchstart', handleTouchStart, { passive: true });
        thumbnail.addEventListener('touchend', handleTouchEnd, { passive: false });
        
        if (playButton) {
          playButton.addEventListener('touchstart', handleTouchStart, { passive: true });
          playButton.addEventListener('touchend', handleTouchEnd, { passive: false });
        }
      }

      // ============================================
      // HOSTED & SHOPIFY VIDEO HANDLING (PLAY/PAUSE TOGGLE)
      // ============================================
      if (videoType === 'hosted' || videoType === 'shopify') {
        var hostedVideo = container.querySelector('.vq-hosted-video');
        
        if (hostedVideo) {
          // Add required attributes for iOS
          hostedVideo.setAttribute('playsinline', '');
          hostedVideo.setAttribute('webkit-playsinline', '');
          
          // Create custom play/pause overlay
          var playOverlay = document.createElement('div');
          playOverlay.className = 'vq-custom-play-overlay';
          playOverlay.innerHTML = '<div class="vq-overlay-button"><svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path class="play-icon" d="M8 5v14l11-7z"/><path class="pause-icon" d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" style="display:none;"/></svg></div>';
          playOverlay.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:72%;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:5;background:transparent;transition:background 0.2s ease;';
          
          var overlayButton = playOverlay.querySelector('.vq-overlay-button');
          overlayButton.style.cssText = 'width:70px;height:70px;background:rgba(255,255,255,0.95);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#5C4033;box-shadow:0 4px 20px rgba(0,0,0,0.3);transition:transform 0.2s ease, opacity 0.2s ease;';
          
          var playIcon = playOverlay.querySelector('.play-icon');
          var pauseIcon = playOverlay.querySelector('.pause-icon');
          
          // Make container position relative for overlay positioning
          container.style.position = 'relative';
          container.appendChild(playOverlay);
          
          // Track playing state
          var isPlaying = false;
          
          function updateOverlayIcon() {
            if (hostedVideo.paused) {
              playIcon.style.display = 'block';
              pauseIcon.style.display = 'none';
              overlayButton.style.opacity = '1';
            } else {
              playIcon.style.display = 'none';
              pauseIcon.style.display = 'block';
              // Hide overlay button after short delay when playing
              setTimeout(function() {
                if (!hostedVideo.paused) {
                  overlayButton.style.opacity = '0';
                }
              }, 1500);
            }
          }
          
          function togglePlayPause(e) {
            if (e) {
              e.preventDefault();
              e.stopPropagation();
            }
            
            if (hostedVideo.paused) {
              var playPromise = hostedVideo.play();
              if (playPromise !== undefined) {
                playPromise.then(function() {
                  isPlaying = true;
                  updateOverlayIcon();
                }).catch(function(error) {
                  console.log('Video play failed:', error);
                  // On iOS, user interaction is required - show controls
                  hostedVideo.controls = true;
                });
              }
            } else {
              hostedVideo.pause();
              isPlaying = false;
              updateOverlayIcon();
            }
          }
          
          // Show overlay button on hover/touch
          playOverlay.addEventListener('mouseenter', function() {
            overlayButton.style.opacity = '1';
          });
          
          playOverlay.addEventListener('mouseleave', function() {
            if (!hostedVideo.paused) {
              overlayButton.style.opacity = '0';
            }
          });
          
          // Click handler
          playOverlay.addEventListener('click', togglePlayPause);
          
          // Touch handlers with tap detection
          var touchStartY = 0;
          var touchStartX = 0;
          var touchStartTime = 0;
          
          playOverlay.addEventListener('touchstart', function(e) {
            touchStartY = e.touches[0].clientY;
            touchStartX = e.touches[0].clientX;
            touchStartTime = Date.now();
            overlayButton.style.opacity = '1';
            overlayButton.style.transform = 'scale(0.95)';
          }, { passive: true });
          
          playOverlay.addEventListener('touchend', function(e) {
            var touchEndY = e.changedTouches[0].clientY;
            var touchEndX = e.changedTouches[0].clientX;
            var touchEndTime = Date.now();
            
            var deltaY = Math.abs(touchEndY - touchStartY);
            var deltaX = Math.abs(touchEndX - touchStartX);
            var deltaTime = touchEndTime - touchStartTime;
            
            overlayButton.style.transform = 'scale(1)';
            
            // Tap detection
            if (deltaY < 15 && deltaX < 15 && deltaTime < 300) {
              e.preventDefault();
              togglePlayPause(e);
            }
          }, { passive: false });
          
          playOverlay.addEventListener('touchcancel', function() {
            overlayButton.style.transform = 'scale(1)';
          });
          
          // Sync with native video events
          hostedVideo.addEventListener('play', function() {
            isPlaying = true;
            updateOverlayIcon();
          });
          
          hostedVideo.addEventListener('pause', function() {
            isPlaying = false;
            updateOverlayIcon();
          });
          
          hostedVideo.addEventListener('ended', function() {
            isPlaying = false;
            updateOverlayIcon();
          });
          
          // Double-tap to toggle fullscreen (optional)
          var lastTap = 0;
          playOverlay.addEventListener('touchend', function(e) {
            var currentTime = new Date().getTime();
            var tapLength = currentTime - lastTap;
            
            if (tapLength < 300 && tapLength > 0) {
              // Double tap detected - toggle fullscreen
              if (hostedVideo.requestFullscreen) {
                hostedVideo.requestFullscreen();
              } else if (hostedVideo.webkitRequestFullscreen) {
                hostedVideo.webkitRequestFullscreen();
              } else if (hostedVideo.webkitEnterFullscreen) {
                // iOS Safari
                hostedVideo.webkitEnterFullscreen();
              }
            }
            lastTap = currentTime;
          }, { passive: true });
          
          // Initialize overlay state
          updateOverlayIcon();
        }
      }
    });

    // ============================================
    // INTERSECTION OBSERVER FOR ANIMATIONS
    // ============================================
    var animatedElements = document.querySelectorAll('.vq-checklist-item, .vq-trust-stat');
    
    if ('IntersectionObserver' in window) {
      var observerOptions = {
        threshold: 0.2,
        rootMargin: '0px 0px -50px 0px'
      };

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry, index) {
          if (entry.isIntersecting) {
            setTimeout(function() {
              entry.target.style.opacity = '1';
              entry.target.style.transform = 'translateY(0)';
            }, index * 100);
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      animatedElements.forEach(function(el) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
        observer.observe(el);
      });
    } else {
      // Fallback for browsers without IntersectionObserver
      animatedElements.forEach(function(el) {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      });
    }
  });
</script>



