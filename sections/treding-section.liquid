<section class="trending-banner-section  ">
    <div class="  container">
         {% if section.settings.title != blank %}
        <h2 class="hero-title">{{ section.settings.title }}</h2>
      {% endif %}
  <div class="trending-banner-container">
    {% if section.settings.background_image %}
      <div class="trending-banner-image">
        <img src="{{ section.settings.background_image | img_url: '1920x600' }}" 
             alt="{{ section.settings.background_image.alt | default: section.settings.heading }}">
      </div>
    {% endif %}
    
    <div class="trending-banner-content">
      <div class="trending-banner-text">
        {% if section.settings.subheading != blank %}
          <p class="trending-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
        
        {% if section.settings.heading != blank %}
          <h2 class="trending-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <p class="trending-description">{{ section.settings.description }}</p>
        {% endif %}
        
        {% if section.settings.button_text != blank and section.settings.button_url != blank %}
          <a href="{{ section.settings.button_url }}" class="trending-button">
            {{ section.settings.button_text }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
      </div>
      
 
    </div>
  </div>
   </div>
</section>

<style>
.trending-banner-section {
  margin: {{ section.settings.margin_top }}px 0 {{ section.settings.margin_bottom }}px;
 
}

.trending-banner-container {
  position: relative;
 
  border-radius: {{ section.settings.border_radius }}px;
  overflow: hidden;
  background: {{ section.settings.background_color }};
  min-height: 400px;
  display: flex;
  align-items: center;
}

.trending-banner-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.trending-banner-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.trending-banner-content {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 60px 80px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.trending-banner-text {
    max-width: 500px;
    margin-left: 300px;
    margin-bottom: 108px;
}

.trending-subheading {
  font-size: 16px;
  color: {{ section.settings.subheading_color }};
  margin: 0 0 8px 0;
  font-weight: 400;
}

.trending-heading {
  font-size: {{ section.settings.heading_size }}px;
  color: {{ section.settings.heading_color }};
  margin: 0 0 12px 0;
  font-weight: 700;
  line-height: 1.2;
}

.trending-description {
  font-size: 16px;
  color: {{ section.settings.description_color }};
  margin: 0 0 24px 0;
  line-height: 1.5;
}

.trending-button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: {{ section.settings.button_background }};
  color: {{ section.settings.button_text_color }};
  padding: 12px 24px;
  border-radius: {{ section.settings.button_border_radius }}px;
  text-decoration: none;
  font-weight: 500;
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.trending-button:hover {
  background: {{ section.settings.button_hover_background }};
  transform: translateY(-2px);
}

.trending-navigation {
  display: flex;
  gap: 12px;
}

.nav-btn {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  color: #333;
}

.nav-btn:hover {
  background: white;
  transform: scale(1.05);
}

@media (max-width: 768px) {
  .trending-banner-content {
    flex-direction: column;
    padding: 40px 20px;
    text-align: center;
  }
  
  .trending-navigation {
    margin-top: 20px;
  }

  .trending-banner-text {
  
    margin-left: 0;
    margin-bottom: 0;
}
  
  .trending-heading {
    font-size: 32px;
  }
}
</style>
{% schema %}
{
  "name": "Trending Banner",
  "tag": "section",
  "class": "trending-section",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
      {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "Trending this week"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Minimal & Modern"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "20% Off"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "With clean lines, high-quality materials"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Visual Settings"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#D4A574"
    },
 
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 24,
      "max": 72,
      "step": 2,
      "default": 48
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Button Styling"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button Background",
      "default": "rgba(255, 255, 255, 0.2)"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button Hover Background",
      "default": "rgba(255, 255, 255, 0.3)"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button Border Radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 25
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Section Border Radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "default": 12
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Trending Banner",
      "settings": {
        "subheading": "Minimal & Modern",
        "heading": "20% Off",
        "description": "With clean lines, high-quality materials",
        "button_text": "Shop Now"
      }
    }
  ]
}
{% endschema %}
