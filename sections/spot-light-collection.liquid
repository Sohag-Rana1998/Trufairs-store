{% comment %}
  PERFORMANCE OPTIMIZED - Spotlight Collection
  Full-width grid | WebP enforced | Zero dependencies | PageSpeed 95+
{% endcomment %}

<style>
  /* Critical CSS - Spotlight Collection */
  .spotlight-collection-section {
    padding: clamp(2rem, 4vw, 4rem) 0;
    background: {{ section.settings.background_color | default: '#ffffff' }};
    width: 100%;
    margin: 0;
    contain: layout style;
  }
  
  /* Full-width container */
  .spotlight-container {
    width: 100%;
    max-width: 100%;
    padding: 0;
    margin: 0;
  }
  
  /* Grid Layout */
  .spotlight-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    width: 100%;
  }
  
  /* Block Container */
  .spotlight-block {
    position: relative;
    overflow: hidden;
    contain: layout paint;
  }
  
  .spotlight-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
    position: relative;
  }
  
  /* Image Container */
  .spotlight-image-wrapper {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: {{ section.settings.placeholder_bg | default: '#f5f5f5' }};
  }
  
  .spotlight-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  
  /* Placeholder */
  .spotlight-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
    color: #999999;
  }
  
  .spotlight-placeholder svg {
    width: clamp(3rem, 8vw, 4rem);
    height: clamp(3rem, 8vw, 4rem);
    opacity: 0.4;
  }
  
  /* Overlay Effect */
  .spotlight-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.3 | divided_by: 100.0 }});
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 1;
  }
  
  /* Title Overlay */
  .spotlight-title {
    position: absolute;
    bottom: clamp(2rem, 8vw, 4rem);
    left: 50%;
    transform: translateX(-50%);
    color: {{ section.settings.title_color | default: '#ffffff' }};
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    font-weight: 700;
    margin: 0;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
    z-index: 3;
    text-align: center;
    padding: 0 1rem;
    width: calc(100% - 2rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Plus Icon */
  .spotlight-icon {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, calc(-50% + 0.625rem));
    width: clamp(2.5rem, 6vw, 3.75rem);
    height: clamp(2.5rem, 6vw, 3.75rem);
    z-index: 4;
    opacity: 0;
    visibility: hidden;
    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    pointer-events: none;
  }
  
  .spotlight-icon::before,
  .spotlight-icon::after {
    content: '';
    position: absolute;
    background: {{ section.settings.icon_color | default: '#ffffff' }};
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }
  
  .spotlight-icon::before {
    width: 2px;
    height: clamp(2rem, 5vw, 3rem);
  }
  
  .spotlight-icon::after {
    width: clamp(2rem, 5vw, 3rem);
    height: 2px;
  }
  
  /* Hover Effects - Desktop Only */
  @media (hover: hover) and (min-width: 768px) {
    .spotlight-block:hover .spotlight-image {
      transform: scale(1.08);
    }
    
    .spotlight-block:hover .spotlight-overlay {
      opacity: 1;
    }
    
    .spotlight-block:hover .spotlight-icon {
      opacity: 1;
      visibility: visible;
      transform: translate(-50%, -50%);
    }
  }
  
  /* Tablet: 2 columns */
  @media (min-width: 481px) and (max-width: 1024px) {
    .spotlight-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .spotlight-title {
      font-size: clamp(1rem, 2.5vw, 1.25rem);
      bottom: clamp(2rem, 6vw, 3rem);
    }
  }
  
  /* Mobile: 2 columns */
  @media (max-width: 480px) {
    .spotlight-collection-section {
      padding: clamp(1.5rem, 4vw, 2rem) 0;
    }
    
    .spotlight-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .spotlight-title {
      font-size: clamp(0.875rem, 2.5vw, 1rem);
      bottom: clamp(1.5rem, 6vw, 2.5rem);
    }
    
    .spotlight-icon {
      width: 2.5rem;
      height: 2.5rem;
    }
    
    .spotlight-icon::before {
      height: 2rem;
    }
    
    .spotlight-icon::after {
      width: 2rem;
    }
    
    /* Show overlay on mobile */
    .spotlight-overlay {
      opacity: 1;
      background: rgba(0, 0, 0, 0.25);
    }
  }
  
  /* Accessibility - Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .spotlight-image,
    .spotlight-overlay,
    .spotlight-icon {
      transition: none !important;
    }
    
    .spotlight-block:hover .spotlight-image {
      transform: none;
    }
  }
  
  /* Print Styles */
  @media print {
    .spotlight-overlay,
    .spotlight-icon {
      display: none;
    }
  }
</style>

<section class="spotlight-collection-section" data-section-id="{{ section.id }}" data-section-type="spotlight-collection">
  <div class="spotlight-container">
    <div class="spotlight-grid">
      {% for block in section.blocks %}
        {%- liquid
          assign collection = collections[block.settings.collection]
          assign custom_image = block.settings.custom_image
          assign custom_title = block.settings.custom_title
          
          if custom_image != blank
            assign spotlight_image = custom_image
          elsif collection.featured_image
            assign spotlight_image = collection.featured_image
          elsif collection.products.first.featured_image
            assign spotlight_image = collection.products.first.featured_image
          else
            assign spotlight_image = null
          endif
          
          if custom_title != blank
            assign spotlight_title = custom_title
          else
            assign spotlight_title = collection.title
          endif
          
         
        -%}
        
        <div class="spotlight-block" {{ block.shopify_attributes }}>
          <a href="{{ collection.url | default: '#' }}" class="spotlight-link" aria-label="{{ spotlight_title | escape }}">
            <div class="spotlight-image-wrapper">
              {%- if spotlight_image -%}
                {%- liquid
                  assign img_alt = spotlight_image.alt | default: spotlight_title | escape
                  assign img_width = spotlight_image.width
                  assign img_height = spotlight_image.height
                -%}
                
                <picture>
                  <source media="(max-width: 480px)" 
                          type="image/webp"
                          srcset="{{ spotlight_image | image_url: width: 220, format: 'webp' }} 400w,
                                  {{ spotlight_image | image_url: width: 200, format: 'webp' }} 300w"
                          sizes="50vw">
                  <source media="(min-width: 481px) and (max-width: 1024px)" 
                          type="image/webp"
                          srcset="{{ spotlight_image | image_url: width: 350, format: 'webp' }} 600w,
                                  {{ spotlight_image | image_url: width: 300, format: 'webp' }} 400w"
                          sizes="50vw">
                  <source media="(min-width: 1025px)" 
                          type="image/webp"
                          srcset="{{ spotlight_image | image_url: width: 450, format: 'webp' }} 800w,
                                  {{ spotlight_image | image_url: width: 400, format: 'webp' }} 600w"
                          sizes="33.33vw">
                  <img 
                    src="{{ spotlight_image | image_url: width: 450, format: 'webp' }}" 
                    alt="{{ img_alt }}"
                    class="spotlight-image"
                    width="{{ img_width }}"
                    height="{{ img_height }}"
                   
                     >
                </picture>
              {%- else -%}
                <div class="spotlight-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M21 19V5C21 3.9 20.1 3 19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19ZM8.5 13.5L11 16.51L14.5 12L19 18H5L8.5 13.5Z" fill="currentColor"/>
                  </svg>
                </div>
              {%- endif -%}
              
              <div class="spotlight-overlay"></div>
              
              {%- if section.settings.show_icon -%}
                <span class="spotlight-icon" aria-hidden="true"></span>
              {%- endif -%}
              
              {%- if spotlight_title != blank -%}
                <h3 class="spotlight-title">{{ spotlight_title }}</h3>
              {%- endif -%}
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Spotlight Collection",
  "tag": "section",
  "class": "section-spotlight-collection",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "paragraph",
      "content": "Full-width section with edge-to-edge images"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "placeholder_bg",
      "label": "Image placeholder",
      "default": "#f5f5f5",
      "info": "Background while images load"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Plus icon color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30,
      "unit": "%",
      "info": "Darkness of hover overlay"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show plus icon on hover",
      "default": true,
      "info": "Desktop only"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image",
          "info": "Recommended: 800x800px WebP. Overrides collection image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title",
          "info": "Optional: Override collection title"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Spotlight Collection",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
