{% schema %}
{
  "name": "Live Session Experience",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Live Session Experience"
    },
   
    {
      "type": "header",
      "content": "YouTube Video Settings"
    },
    {
      "type": "text",
      "id": "youtube_video_url",
      "label": "YouTube Video url",
      "info": "https://www.youtube.com/embed/l5eGPr2MML4?si=4NJboe53Khhwjysv",
      "default": "https://www.youtube.com/embed/l5eGPr2MML4?si=4NJboe53Khhwjysv"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": false,
      "info": "Note: Autoplay may not work on mobile devices due to browser restrictions"
    },
    {
      "type": "checkbox",
      "id": "mute",
      "label": "Mute video",
      "default": true,
      "info": "Video must be muted for autoplay to work"
    },
    {
      "type": "header",
      "content": "Live Chat Preview Settings"
    },
    {
      "type": "image_picker",
      "id": "chat_preview_image",
      "label": "Chat Preview Image",
      "info": "Upload a screenshot of your live chat interface"
    },
    {
      "type": "text",
      "id": "chat_preview_alt",
      "label": "Image Alt Text (for SEO)",
      "default": "Live chat preview with customers"
    }
  ],
  "presets": [
    {
      "name": "Live Session Experience"
    }
  ]
}
{% endschema %}

<div class="page-width live-session-section" id="live-session-{{ section.id }}">
  <div style="text-align:center; width:100%;" class="section-header-experience text-center">
    {{ section.settings.heading }}
  </div>

  <div class="live-session-container">
    <div class="live-session-video">
      <div class="video-container">
        {% assign autoplay_param = section.settings.autoplay | default: false %}
        {% assign mute_param = section.settings.mute | default: true %}
        {% assign youtube_params = "rel=0&showinfo=0" %}
        {% if autoplay_param %}
          {% assign youtube_params = youtube_params | append: "&autoplay=1" %}
        {% endif %}
        {% if mute_param %}
          {% assign youtube_params = youtube_params | append: "&mute=1" %}
        {% endif %}
        
        <iframe 
          src="{{ section.settings.youtube_video_url }}"
          title="YouTube video player"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
         
          class="youtube-iframe">
        </iframe>
      </div>
    </div>
    <div class="live-session-chat">
      <div class="chat-preview-container">
        {% if section.settings.chat_preview_image %}
          <div class="chat-image-wrapper">
            <img
              src="{{ section.settings.chat_preview_image | img_url: '800x' }}"
             
              alt="{{ section.settings.chat_preview_alt | escape }}"
              class="chat-preview-image"
            >
          </div>
        {% else %}
          <div class="chat-preview-placeholder">
            <div class="chat-preview-header">Live Chat</div>
            <div class="chat-preview-message">
              Upload a chat screenshot in the theme editor
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .live-session-section {
    padding: 0px 20px;

     background:#f9f9f9;
    padding-top:50px;
    margin-top:-30px;
  }
  
  .section-header-experience {
    margin-bottom: 40px;
    font-size: 2.6rem;
    font-weight: 600;
    color: #333;
    text-align:center;
    text-transform:capitalize;
  }
  
  .live-session-container {
     max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
    justify-content: center;
    align-items: stretch;
  }
  
  .live-session-video,
  .live-session-chat {
    flex: 1;
    min-width: 300px;
    display: flex;
    flex-direction: column;
  }
  
.live-session-video {
    max-width: 70%;
}
  
  .live-session-chat {
    max-width: 380px;
  }
  
  .video-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
    height: 0;
    overflow: hidden;
    background-color: #f6f6f6;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  
  .youtube-iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  
  .chat-preview-container {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    background-color: #ffffff;
    height: 100%;
  }
  
.chat-image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    padding-bottom: 0;
    overflow: hidden;
}
  
.chat-preview-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
}
  
  .chat-preview-placeholder {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  
  .chat-preview-header {
    padding: 15px 20px;
    background-color: #f8f8f8;
    font-weight: 600;
    border-bottom: 1px solid #eaeaea;
  }
  
  .chat-preview-message {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-grow: 1;
    padding: 20px;
    text-align: center;
    color: #777;
    font-size: 0.9rem;
  }
  
  @media screen and (max-width: 992px) {
    .live-session-video,
    .live-session-chat {
      min-width: 45%;
    }
     .section-header {
      font-size: 2.2rem;
    }
  }
  
  @media screen and (max-width: 768px) {
    .live-session-container {
      flex-direction: column;
      align-items: center;
    }
    
    .live-session-video,
    .live-session-chat {
      width: 100%;
      max-width: 600px;
    }
    
    .section-header {
      font-size: 2rem;
    }
    .chat-image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    padding-bottom: 98%;
    overflow: hidden;
}
  }
  
  @media screen and (max-width: 480px) {

.chat-image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    padding-bottom: 98%;
    overflow: hidden;
}

    
    .live-session-section {
      padding: 40px 15px;
      padding-bottom:0;
    }
    
    .section-header {
      font-size: 2rem;
      margin-bottom: 30px;
    }
    
    .live-session-container {
      gap: 20px;
    }
  }
</style>