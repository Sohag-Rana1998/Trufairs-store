                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.pinterest_url != blank %}
              <a href="{{ section.settings.pinterest_url }}" class="social-icon" target="_blank" rel="noopener" aria-label="Pinterest">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 0c-6.627 0-12 5.373-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.youtube_url != blank %}
              <a href="{{ section.settings.youtube_url }}" class="social-icon" target="_blank" rel="noopener" aria-label="YouTube">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
                
  </div>
</div>




                    
<!-- Book Seat Modal Popup -->
<div class="weekly-live-modal" id="bookingModal">
  <div class="modal-content">
    <span class="close-modal" id="closeModal">&times;</span>
    <h3 class="modal-title">{{ section.settings.form_title }}</h3>
    <p class="modal-subtitle">{{ section.settings.form_subtitle }}</p>
    <div class="klaviyo-form-SRtgaZ"></div>
  </div>
</div>

<!-- Google Meet Modal Popup -->
<div class="weekly-live-modal" id="meetModal">
  <div class="modal-content">
    <span class="close-modal" id="closeMeetModal">&times;</span>
    <h3 class="modal-title">{{ section.settings.meet_form_title }}</h3>
    <p class="modal-subtitle">{{ section.settings.meet_form_subtitle }}</p>
<div class="klaviyo-form-XxyszG"></div>
  </div>
</div>

<script>
/**
 * Enhanced Website Functionality
 * - Modal handling for booking seats and Google Meet
 * - Button state management based on time (Wednesdays 5:30 PM - 7:00 PM EST)
 * - Klaviyo form integration
 */

document.addEventListener('DOMContentLoaded', function() {
  // Unified button and modal initialization
  initializeModalSystem();
  initializeButtonManager();
});

/**
 * Modal system initialization and event handling
 */
function initializeModalSystem() {
  // Modal configuration objects
  const modalConfigs = [
    {
      buttonId: 'bookSeatButton',
      buttonSelector: '.weekly-live-button',
      modalId: 'bookingModal',
      closeId: 'closeModal'
    },
    {
      buttonId: 'googleMeetButton',
      buttonSelector: '.google-meet-button',
      modalId: 'meetModal',
      closeId: 'closeMeetModal'
    }
  ];

  // Initialize each modal
  modalConfigs.forEach(config => {
    const button = document.getElementById(config.buttonId) || 
                  document.querySelector(config.buttonSelector);
    const modal = document.getElementById(config.modalId);
    const closeBtn = document.getElementById(config.closeId);
    
    if (button && modal && closeBtn) {
      // Always setup the modal regardless of button state
      // We'll handle button state separately
      
      // Open modal
      button.addEventListener('click', function(e) {
        // Only open if button is not disabled
        if (!button.disabled && !button.classList.contains('disabled')) {
          e.preventDefault();
          modal.classList.add('active');
          document.body.style.overflow = 'hidden'; // Prevent background scrolling
          
          // Ensure Klaviyo form is properly loaded if it exists
          if (window._klOnsite && typeof window._klOnsite.revalidateRecaptcha === 'function') {
            window._klOnsite.revalidateRecaptcha();
          }
        }
      });
      
      // Close modal with X button
      closeBtn.addEventListener('click', function() {
        modal.classList.remove('active');
        document.body.style.overflow = '';
      });
      
      // Close modal when clicking outside
      modal.addEventListener('click', function(e) {
        if (e.target === modal) {
          modal.classList.remove('active');
          document.body.style.overflow = '';
        }
      });
    } else {
      console.warn(`Could not set up modal for ${config.buttonId || config.buttonSelector}: missing elements`);
    }
  });

  // Listen for Klaviyo form submission success
  document.addEventListener('klaviyoForms', function(event) {
    if (event.detail && event.detail.type === 'submit' && event.detail.formId) {
      // Close all modals after successful form submission
      const modals = document.querySelectorAll('.weekly-live-modal');
      setTimeout(function() {
        modals.forEach(modal => {
          if (modal.classList.contains('active')) {
            modal.classList.remove('active');
          }
        });
        document.body.style.overflow = '';
      }, 2000); // 2 second delay to show success message
    }
  });
}

/**
 * Button manager to control button states based on time
 */
function initializeButtonManager() {
  // Find buttons with a retry mechanism
  let attempts = 0;
  const maxAttempts = 5;
  const retryInterval = 500;
  
  function findButtons() {
    const bookSeatButton = document.getElementById('bookSeatButton') || 
                          document.querySelector('.weekly-live-button');
    const googleMeetButton = document.getElementById('googleMeetButton') || 
                            document.querySelector('.google-meet-button');
    
    if ((!bookSeatButton && !googleMeetButton) && attempts < maxAttempts) {
      console.log(`Buttons not found yet, attempt ${attempts + 1}/${maxAttempts}`);
      attempts++;
      setTimeout(findButtons, retryInterval);
      return;
    }

    if (bookSeatButton || googleMeetButton) {
      console.log('Button manager initialized successfully');
      setupButtonManager(bookSeatButton, googleMeetButton);
    } else {
      console.log('Button manager initialization failed: buttons not found');
    }
  }
  
  findButtons();
}

/**
 * Sets up button state management based on time
 */
function setupButtonManager(bookSeatButton, googleMeetButton) {
  // Check if current time is Wednesday between 5:30 PM and 7:00 PM EST
  function isMeetingTimeNow() {
    // Get the current date/time in user's local timezone
    const now = new Date();
    
    // Convert to EST/EDT (UTC-5 or UTC-4 depending on daylight saving)
    // We need to account for daylight saving time
    const estNow = new Date(now.toLocaleString('en-US', { timeZone: 'America/New_York' }));
    
    // Get day of week (0 = Sunday, 1 = Monday, ..., 3 = Wednesday, ..., 6 = Saturday)
    const dayOfWeek = estNow.getDay();
    
    // Get hours and minutes in EST
    const hours = estNow.getHours();      // Hours in EST (0-23)
    const minutes = estNow.getMinutes();  // Minutes in EST (0-59)
    
    // Convert to total minutes since midnight
    const currentMinutes = hours * 60 + minutes;
    
    // Define meeting time window (Wednesday 5:30 PM - 7:00 PM)
    const isWednesday = dayOfWeek === 3;
    const startTime = 17 * 60 + 30;  // 5:30 PM = 17:30 = 17*60 + 30 minutes
    const endTime = 19 * 60;         // 7:00 PM = 19:00 = 19*60 minutes
    
    // For testing - you can temporarily override with this:
    // return true;
    console.log(isWednesday)
    console.log(startTime)
    console.log(currentMinutes)
  
    // Check if it's Wednesday AND within the time window
    return isWednesday && (currentMinutes >= startTime && currentMinutes < endTime);
  }

  function updateButtonStates() {
    const isMeetingActive = isMeetingTimeNow();
    
    // Log current state for debugging
    console.log('Meeting active:', isMeetingActive, new Date().toLocaleString('en-US', { timeZone: 'America/New_York' }));
    
    if (googleMeetButton) {
      if (isMeetingActive) {
        // Enable Google Meet button during meeting time
        googleMeetButton.disabled = false;
        googleMeetButton.removeAttribute('disabled');
        googleMeetButton.classList.remove('disabled');
        googleMeetButton.style.opacity = '1';
        googleMeetButton.style.cursor = 'pointer';
        googleMeetButton.style.pointerEvents = 'auto';
        
        // Find and fix parent element with pointer-events: none
        fixParentPointerEvents(googleMeetButton, true);
      } else {
        // Disable Google Meet button outside meeting time
        googleMeetButton.disabled = true;
        googleMeetButton.setAttribute('disabled', 'disabled');
        googleMeetButton.classList.add('disabled');
        googleMeetButton.style.opacity = '0.5';
        googleMeetButton.style.cursor = 'not-allowed';
        googleMeetButton.style.pointerEvents = 'none';
        
        // Restore parent pointer-events
        fixParentPointerEvents(googleMeetButton, false);
      }
    }

    if (bookSeatButton) {
      // Show booking button only outside meeting time
      bookSeatButton.style.display = isMeetingActive ? 'none' : '';
    }
  }

  // Fix pointer-events on parent elements that might interfere with button clicks
  function fixParentPointerEvents(button, enable) {
    if (!button) return;
    
    let parent = button.parentElement;
    let fixed = false;
    
    while (parent && !fixed) {
      if (window.getComputedStyle(parent).pointerEvents === 'none') {
        if (!parent.hasAttribute('data-original-pointer-events')) {
          parent.setAttribute('data-original-pointer-events', parent.style.pointerEvents || 'none');
        }
        
        parent.style.pointerEvents = enable ? 'auto' : parent.getAttribute('data-original-pointer-events');
        fixed = true;
      }
      parent = parent.parentElement;
    }
  }

  // Initialize button states and set up interval for updates
  updateButtonStates();
  setInterval(updateButtonStates, 30000); // Check every 30 seconds

  // Add additional one-time check for immediate testing (helpful during development)
  setTimeout(updateButtonStates, 3000);
}

