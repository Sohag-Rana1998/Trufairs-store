{% schema %}
{
  "name": "Weekly Live Sessions",
  "tag": "section",
  "class": "weekly-live-sessions-section",
  "settings": [
    {
      "type": "header",
      "content": "Left Content"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Weekly Live Sessions with Jennifer"
    },
    {
      "type": "richtext",
      "id": "main_description",
      "label": "Description",
      "default": "<p>Join our founder Jennifer every week for an interactive live session where she discusses product insights, answers your questions, and provides solutions to your concerns.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "BOOK YOUR SEAT"
    },
    {
      "type": "header",
      "content": "Google Meet Button Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_meet_button",
      "label": "Enable Google Meet Button",
      "default": false
    },
    {
      "type": "text",
      "id": "meet_button_text",
      "label": "Meet Button Text",
      "default": "Join Now Our Session"
    },
    {
      "type": "url",
      "id": "meet_url",
      "label": "Google Meet URL"
    },
    {
      "type": "header",
      "content": "Right Content"
    },
    {
      "type": "image_picker",
      "id": "presenter_image",
      "label": "Presenter Image"
    },
    {
      "type": "text",
      "id": "meet_text",
      "label": "Meet Text",
      "default": "Meet Jennifer"
    },
    {
      "type": "text",
      "id": "position_text",
      "label": "Position Text",
      "default": "Co-Founder"
    },
    {
      "type": "text",
      "id": "company_website",
      "label": "Company Website",
      "default": "of Trufairs.com"
    },
    {
      "type": "richtext",
      "id": "presenter_description",
      "label": "Presenter Description",
      "default": "<p>Jennifer is passionate about answering your questions and helping you get the most out of Trufairs products. Join her live sessions to connect directly!</p>"
    },
    {
      "type": "header",
      "content": "Social Media Links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form Title",
      "default": "Book Your Seat for the Next Session"
    },
    {
      "type": "text",
      "id": "form_subtitle",
      "label": "Form Subtitle",
      "default": "Fill in your details below to secure your spot"
    },
    {
      "type": "text",
      "id": "submit_button_text",
      "label": "Submit Button Text",
      "default": "Secure My Spot"
    },
    {
      "type": "header",
      "content": "Google Meet Form Settings"
    },
    {
      "type": "text",
      "id": "meet_form_title",
      "label": "Meet Form Title",
      "default": "Join Our Live Google Meet Session"
    },
    {
      "type": "text",
      "id": "meet_form_subtitle",
      "label": "Meet Form Subtitle",
      "default": "Enter your details to join the live session"
    },
    {
      "type": "text",
      "id": "meet_submit_button_text",
      "label": "Meet Continue Button Text",
      "default": "Continue"
    }
  ],
  "presets": [
    {
      "name": "Weekly Live Sessions",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}

<style>
  .weekly-live-sessions-section {
    padding: 50px 0px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    background:#f9f9f9;
    padding-bottom:30px;
  }
  
  .weekly-live-sessions-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 30px;
     padding: 0px 20px;
     
  }
  
  .weekly-live-left-content {
    flex: 1;
    min-width: 300px;
    padding-right: 20px;
  }
  
  .weekly-live-heading {
    font-size: 2.6rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    background:linear-gradient(135deg, #1a1a1a, #e74c6b);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1.2;
    text-transform:capitalize !important;
  }
  
  .weekly-live-description {
    font-size: 18px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 30px;
  }
  
  .button-container {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
  }
  
  .weekly-live-button {
    background-color: #e94a64;
    color: white;
    font-size: 16px;
    font-weight: 600;
    padding: 15px 30px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
    text-align: center;
    text-decoration: none;
  }
  
  .weekly-live-button:hover {
    background-color: #d03652;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(233, 74, 100, 0.2);
  }
  
  .google-meet-button {
    background-color: #4285F4;
    color: white;
    font-size: 16px;
    font-weight: 600;
    padding: 10px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    position: relative;
    text-align: center;
    text-decoration: none;
  }
  
  .google-meet-button:hover {
    background-color: #3367D6;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(66, 133, 244, 0.2);
  }
  
  .google-meet-button.disabled {
    background-color: #cccccc;
    color: #888888;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }
  
  .google-meet-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
  }
  
  .weekly-live-right-content {
    flex: 1;
    max-width: 450px;
    position: relative;
  }
  
  .weekly-live-card {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    background-color: #f5f5f5;
    position: relative;
  }
  
  .weekly-live-join-text {
    font-weight: 600;
    font-size: 16px;
  }
  
  .weekly-live-platform {
    font-weight: 500;
    color: #555;
    font-size: 14px;
  }
  
  .weekly-live-image-container {
    width: 100%;
    position: relative;
    height: 250px;
    overflow: hidden;
  }
  
  .weekly-live-image {
    width: 100%;
    height: auto;
    display: block;
  }
 
  .weekly-live-presenter-info {
    padding: 25px;
    background-color: white;
  }
  
  .weekly-live-meet {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 3px;
  }
  
  .meet-text {
    font-size: 24px;
    color: #333;
  }
  
  .presenter-name {
    font-size: 32px;
    font-weight: 700;
    color: #333;
  }
  
  .presenter-position {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 5px;
    font-size: 16px;
    color: #e74c6b;
  }
  
  .presenter-description {
    font-size: 16px;
    line-height: 1.6;
    color: #555;
    margin-bottom: 20px;
  }

  .presenter-description p{
    margin-top: 0px;
  }
  
  .weekly-live-social {
    display: flex;
    gap: 15px;
  }
  
  .social-icon {
    color: #333;
    transition: all 0.3s ease;
  }

  .social-icon svg {
    stroke: unset !important;
    width: 2rem;
    height: 2rem;
  }
  
  .social-icon:hover {
    color: #e94a64;
    transform: translateY(-2px);
  }

  /* Modal Styles */
  .weekly-live-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 1000;
    justify-content: center;
    align-items: center;
  }
  
  .weekly-live-modal.active {
    display: flex;
    background-color:transparent !important;
  }
  
  .modal-content {
    background-color: white;
    border-radius: 10px;
    padding: 30px;
    width: 90%;
    max-width: 500px;
    position: relative;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    animation: modalFadeIn 0.4s ease-out;
  }
  
  .close-modal {
    position: absolute;
    top: 15px;
    right: 15px;
    font-size: 24px;
    font-weight: bold;
    color: #999;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .close-modal:hover {
    color: #333;
  }
  
.modal-title {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 10px;
    color: #333;
    text-align: center;
}


  
.modal-subtitle {
    font-size: 16px;
    color: #666;
    margin-bottom: 25px;
    text-align: center;
}
  
  .form-group {
    margin-bottom: 20px;
  }
  
  .form-label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 8px;
    color: #555;
  }
  
  .form-input {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 16px;
    transition: all 0.3s ease;
  }
  
  .form-input:focus {
    border-color: #e94a64;
    outline: none;
    box-shadow: 0 0 0 3px rgba(233, 74, 100, 0.1);
  }
  
  .form-submit {
    background-color: #e94a64;
    color: white;
    font-size: 16px;
    font-weight: 600;
    padding: 14px 20px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
    margin-top: 10px;
  }

#meetModal svg, #bookingModal svg {
  
    width: 2rem !important;
    height: 2rem !important;
 
}

  
  .form-submit:hover {
    background-color: #d03652;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(233, 74, 100, 0.2);
  }
  
  .meet-form-submit {
    background-color: #4285F4;
    color: white;
    font-size: 16px;
    font-weight: 600;
    padding: 14px 20px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
    margin-top: 10px;
  }
  
  .meet-form-submit:hover {
    background-color: #3367D6;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(66, 133, 244, 0.2);
  }


  

   .google-meet-button svg {
    display: inline-block;
    vertical-align: middle;
    fill: currentColor;
    stroke: unset;
    width: 3rem;
    height: 3rem;
    transition: var(--anchor-transition);
}

  .google-meet-button  {
  
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
}
  
  @keyframes modalFadeIn {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* Responsive Styles */
  @media (max-width: 991px) {
    .weekly-live-sessions-container {
      flex-direction: column;
    }
    
    .weekly-live-left-content,
    .weekly-live-right-content {
      width: 100%;
      padding: 0;
    }
    
    .weekly-live-heading {
      font-size: 2.2rem;
    }
  }
  
  @media (max-width: 767px) {
    .weekly-live-sessions-section {
      padding: 20px 10px;
    }
    .weekly-live-sessions-container {
  
    padding: 0px 0px;
}
    .weekly-live-heading {
      font-size: 2rem;
    }
    
    .weekly-live-description {
      font-size: 16px;
    }
    
    .weekly-live-overlay {
      width: 75%;
    }
    
    .button-container {
      flex-direction: column;
    }


    
  }
</style>

<div class="weekly-live-sessions-section">
  <div class="weekly-live-sessions-container">
    <div class="weekly-live-left-content">
      <h2 class="weekly-live-heading">{{ section.settings.main_heading }}</h2>
      <div class="weekly-live-description">{{ section.settings.main_description }}</div>
      <div class="button-container">
          {% unless section.settings.enable_meet_button %}
        <button class="weekly-live-button" id="bookSeatButton">{{ section.settings.button_text }}</button>
        {% endunless %}
       
         
       
          <button id="googleMeetButton" class="google-meet-button disabled"    {% if section.settings.enable_meet_button %} disabled {% endif %} >
            <?xml version="1.0" ?><svg height="48px" viewBox="0 0 48 48" width="48px" xmlns="http://www.w3.org/2000/svg"><rect fill="#fff" height="16" transform="rotate(-90 20 24)" width="16" x="12" y="16"/><polygon fill="#1e88e5" points="3,17 3,31 8,32 13,31 13,17 8,16"/><path d="M37,24v14c0,1.657-1.343,3-3,3H13l-1-5l1-5h14v-7l5-1L37,24z" fill="#4caf50"/><path d="M37,10v14H27v-7H13l-1-5l1-5h21C35.657,7,37,8.343,37,10z" fill="#fbc02d"/><path d="M13,31v10H6c-1.657,0-3-1.343-3-3v-7H13z" fill="#1565c0"/><polygon fill="#e53935" points="13,7 13,17 3,17"/><polygon fill="#2e7d32" points="38,24 37,32.45 27,24 37,15.55"/><path d="M46,10.11v27.78c0,0.84-0.98,1.31-1.63,0.78L37,32.45v-16.9l7.37-6.22C45.02,8.8,46,9.27,46,10.11z" fill="#4caf50"/></svg>
            {{ section.settings.meet_button_text }}
          </button>
       
      </div>
    </div>
    
    <div class="weekly-live-right-content">
      <div class="weekly-live-card">
        <div class="weekly-live-image-container">
          {% if section.settings.presenter_image %}
            {{ section.settings.presenter_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'weekly-live-image', alt: section.settings.meet_text }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'weekly-live-image placeholder' }}
          {% endif %}
        </div>
        
        <div class="weekly-live-presenter-info">
          <div class="weekly-live-meet">
            <div class="meet-text">{{ section.settings.meet_text }}</div>
            <div class="presenter-name">{{ section.settings.main_heading | split: ' with ' | last }}</div>
          </div>
          
          <div class="presenter-position">
            <span>{{ section.settings.position_text }}</span>
            <span>{{ section.settings.company_website }}</span>
          </div>
          
          <div class="presenter-description">{{ section.settings.presenter_description }}</div>
          
          <div class="weekly-live-social">
            {% if section.settings.instagram_url != blank %}
              <a href="{{ section.settings.instagram_url }}" class="social-icon" target="_blank" rel="noopener" aria-label="Instagram">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
