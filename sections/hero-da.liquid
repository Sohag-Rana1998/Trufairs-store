{% style %}
.hero-positioning {
  position: relative;
  overflow: hidden;
  background: {{ section.settings.bg_color }};
  color: {{ section.settings.text_color }};
}

.hero-positioning__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 80px 20px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 75vh;
}

.hero-positioning__content {
  max-width: 720px;
}

.hero-positioning__heading {
  font-size: 42px;
  line-height: 1.2;
  font-weight: 600;
  margin-bottom: 16px;
}

.hero-positioning__subheading {
  font-size: 18px;
  line-height: 1.6;
  opacity: 0.9;
  margin-bottom: 28px;
}

.hero-positioning__cta {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.hero-positioning__btn {
  display: inline-block;
  padding: 14px 24px;
  font-size: 15px;
  font-weight: 500;
  border-radius: 4px;
  text-decoration: none;
  transition: all 0.25s ease;
}

.hero-positioning__btn--primary {
  background: {{ section.settings.primary_color }};
  color: #fff;
}

.hero-positioning__btn--primary:hover {
  opacity: 0.9;
}

.hero-positioning__btn--secondary {
  background: transparent;
  border: 1px solid {{ section.settings.text_color }};
  color: {{ section.settings.text_color }};
}

.hero-positioning__btn--secondary:hover {
  background: {{ section.settings.text_color }};
  color: {{ section.settings.bg_color }};
}

/* Background */
.hero-positioning__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
}

.hero-positioning__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.hero-positioning__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,{{ section.settings.overlay_opacity }});
}

.hero-positioning__inner {
  position: relative;
  z-index: 2;
}

/* Mobile */
@media (max-width: 768px) {
  .hero-positioning__container {
    padding: 60px 16px 40px;
    min-height: auto;
  }

  .hero-positioning__heading {
    font-size: 28px;
  }

  .hero-positioning__subheading {
    font-size: 16px;
  }
}
{% endstyle %}

<section class="hero-positioning" role="banner">

  {% if section.settings.bg_image != blank or section.settings.mobile_bg_image != blank %}
    <div class="hero-positioning__bg">
      <picture>

        {% if section.settings.mobile_bg_image != blank %}
          <source
            media="(max-width: 767px)"
            srcset="
              {{ section.settings.mobile_bg_image | image_url: width: 480 }} 480w,
              {{ section.settings.mobile_bg_image | image_url: width: 750 }} 750w
            "
            sizes="100vw"
          >
        {% endif %}

        {% assign desktop_image = section.settings.bg_image | default: section.settings.mobile_bg_image %}

        <img
          src="{{ desktop_image | image_url: width: 1600 }}"
          srcset="
            {{ desktop_image | image_url: width: 900 }} 900w,
            {{ desktop_image | image_url: width: 1400 }} 1400w,
            {{ desktop_image | image_url: width: 1800 }} 1800w
          "
          sizes="100vw"
          alt="{{ desktop_image.alt | escape }}"
          loading="eager"
          fetchpriority="high"
          width="{{ desktop_image.width }}"
          height="{{ desktop_image.height }}"
        >
      </picture>

      <div class="hero-positioning__overlay"></div>
    </div>
  {% endif %}

  <div class="hero-positioning__container hero-positioning__inner">
    <div class="hero-positioning__content">

      {% if section.settings.heading != blank %}
        <h1 class="hero-positioning__heading">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="hero-positioning__subheading">
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      <div class="hero-positioning__cta">

        {% if section.settings.primary_label != blank %}
          <a href="{{ section.settings.primary_link }}" class="hero-positioning__btn hero-positioning__btn--primary">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank %}
          <a href="{{ section.settings.secondary_link }}" class="hero-positioning__btn hero-positioning__btn--secondary">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero – Positioning",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop Home Products You Don’t Have to Second-Guess"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We test, compare, and select what actually works — so you don’t waste time or money on the wrong choice."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary Button Label",
      "default": "Shop Verified Picks"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary Button Label",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Desktop Background Image (Optional)"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg_image",
      "label": "Mobile Background Image (Optional)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 0.8,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Button Color",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Hero – Positioning"
    }
  ]
}
{% endschema %}