{%- liquid
  assign section_id = 'hero-section-' | append: section.id
  assign bg_color = section.settings.background_color | default: '#8B4513'
  assign text_color = section.settings.text_color | default: '#ffffff'
-%}

<style>
  #{{ section_id }} {
    position: relative;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  /* Split background */
  #{{ section_id }}::before {
    content: "";
    position: absolute;
    inset: 0;
    background: {{ bg_color }};
    width: 60%;
    z-index: 1;
  }

  #{{ section_id }}::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 40%;
    height: 100%;
    background: url({{ section.settings.background_image | img_url: '1200x' }}) no-repeat center center/cover;
    z-index: 1;
  }

  #{{ section_id }} .hero-container {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
 
    margin: 0 auto;
    padding: 0 20px;
    gap: 40px;
  }

  #{{ section_id }} .hero-content {
    flex: 1;
    color: {{ text_color }};
  }

  #{{ section_id }} .hero-subtitle {
    font-size: {{ section.settings.subtitle_font_size }}px;
    font-weight: {{ section.settings.subtitle_font_weight }};
    margin-bottom: 15px;
    text-transform: {{ section.settings.subtitle_text_transform }};
    letter-spacing: 1px;
    opacity: 0.9;
  }

  #{{ section_id }} .hero-title {
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: {{ section.settings.title_font_weight }};
    line-height: {{ section.settings.title_line_height }};
    margin-bottom: 20px;
    text-transform: {{ section.settings.title_text_transform }};
  }

  #{{ section_id }} .hero-description {
    font-size: {{ section.settings.description_font_size }}px;
    line-height: {{ section.settings.description_line_height }};
    margin-bottom: 30px;
    opacity: 0.9;
    max-width: 500px;
  }

  #{{ section_id }} .hero-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-bottom: 30px;
  }

  #{{ section_id }} .hero-feature {
    display: flex;
    align-items: center;
    font-size: {{ section.settings.features_font_size }}px;
  }

  #{{ section_id }}  .hero-feature::before {
    content: '✓';
    display: inline-block;
    width: 20px;
    height: 20px;
  
    color: #ffffff;
    border-radius: 50%;
    text-align: center;
    line-height: 20px;
    font-size: 12px;
    margin-right: 10px;
    flex-shrink: 0;
    border: 1px solid white;
}

  #{{ section_id }} .hero-button {
    display: inline-flex;
    align-items: center;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_font_weight }};
    border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
    transition: all 0.3s ease;
  }

  #{{ section_id }} .hero-button:hover {
    background-color: {{ section.settings.button_hover_bg_color }};
    color: {{ section.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  #{{ section_id }} .hero-button::after {
    content: '→';
    margin-left: 8px;
    transition: transform 0.3s ease;
  }

  #{{ section_id }} .hero-button:hover::after {
    transform: translateX(3px);
  }

  /* Hero Image */
  #{{ section_id }} .hero-image {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 460px;
}

  #{{ section_id }}  .hero-image img {
    width: 100%;
    max-width: 400px;
    object-fit: cover;
    border-radius: 80px;
    height: 100%;
    display: block;
    margin-right: auto;
}

  @media (max-width: 768px) {

  #{{ section_id }} {
  
    padding-bottom: 300px;
   
  }


    #{{ section_id }} .hero-title {
      font-size: 1.8rem;
    }


    #{{ section_id }}::before,
    #{{ section_id }}::after {
      width: 100%;
    }

    #{{ section_id }}::before{
  
    min-height: 910px;
}

  #{{ section_id }}::after{
 
    max-height: 290px !important;
}

    #{{ section_id }}::before {
      height: 50%;
    }
    #{{ section_id }}::after {
      height: 50%;
      top: auto;
      bottom: 0;
    }
    #{{ section_id }} .hero-container {
      flex-direction: column;
       
      gap: 30px;
    }
  
    #{{ section_id }} .hero-description {
      margin-left: auto;
      margin-right: auto;
    }
    #{{ section_id }} .hero-features {
      grid-template-columns: 1fr;
    }
    #{{ section_id }} .hero-image img {
      max-width: 330px;
    }
  }
</style>

<section id="{{ section_id }}" class="hero-section">
  <div class="hero-container container">
    <div class="hero-content">
      {% if section.settings.subtitle != blank %}
        <div class="hero-subtitle">{{ section.settings.subtitle }}</div>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="hero-title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="hero-description">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="hero-features">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'feature' %}
                <div class="hero-feature" {{ block.shopify_attributes }}>
                  {{ block.settings.feature_text }}
                </div>
            {% endcase %}
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.button_text != blank and section.settings.button_url != blank %}
        <a href="{{ section.settings.button_url }}" class="hero-button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    {% if section.settings.hero_image != blank %}
      <div class="hero-image">
        <img src="{{ section.settings.hero_image | img_url: '600x600' }}" 
             alt="{{ section.settings.hero_image.alt | default: section.settings.title }}"
            >
      </div>
    {% endif %}
  </div>
</section>

