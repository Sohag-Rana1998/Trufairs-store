{% schema %}
{
"name": "Deals Icon Grid",
"tag": "section",
"class": "deal-icons-grid",
"settings": [
{
"type": "range",
"id": "columns",
"min": 2,
"max": 9,
"step": 1,
"default": 4,
"label": "Icons per row (desktop)"
}
],
"blocks": [
{
"type": "deal_item",
"name": "Deal Item",
"settings": [
{
"type": "image_picker",
"id": "icon",
"label": "Deal Icon Image"
},
{
"type": "text",
"id": "label",
"label": "Deal Title",
"default": "Home Deals"
},
{
"type": "url",
"id": "link",
"label": "Link"
}
]
}
],
"presets": [
{
"name": "Deals Icon Grid",
"category": "Custom",
"blocks": [
{ "type": "deal_item" },
{ "type": "deal_item" },
{ "type": "deal_item" },
{ "type": "deal_item" }
]
}
]
}
{% endschema %}

{% style %}
  .deal-icons-grid-wrapper {
  display: grid;
  gap: 1rem;
  justify-items: center;
  padding: 2rem 1rem;
  max-width:1440px;
  margin:0 auto;
  }

  .deal-icons-grid-wrapper.columns-2 {
  grid-template-columns: repeat(2, 1fr);
  }
  .deal-icons-grid-wrapper.columns-3 {
  grid-template-columns: repeat(3, 1fr);
  }
  .deal-icons-grid-wrapper.columns-4 {
  grid-template-columns: repeat(4, 1fr);
  }
  .deal-icons-grid-wrapper.columns-5 {
  grid-template-columns: repeat(5, 1fr);
  }
  .deal-icons-grid-wrapper.columns-6 {
  grid-template-columns: repeat(6, 1fr);
  }
    .deal-icons-grid-wrapper.columns-7 {
  grid-template-columns: repeat(7, 1fr);
  }
  .deal-icons-grid-wrapper.columns-8 {
  grid-template-columns: repeat(8, 1fr);
  }

    .deal-icons-grid-wrapper.columns-9 {
  grid-template-columns: repeat(9, 1fr);
  }


  .deal-icon-item {
  text-align: center;
  max-width: 270px;
  }

  .deal-icon-image {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 50%;
  object-fit: cover;
  margin-bottom: 0.5rem;
  border: 4px solid transparent;
  transition: transform 0.3s ease;
  }

  .deal-icon-item:hover .deal-icon-image {
  transform: scale(1.05);
  border-color: #ddd;
  }

  .deal-icon-label {
  font-size: 0.95rem;
  font-weight: 500;
  color: #333;
  }

  @media screen and (max-width: 749px) {
  .deal-icons-grid-wrapper {
  grid-template-columns: repeat(3, 1fr) !important;
  gap: .5rem;
  }
  .deal-icon-item {
  text-align: center;
  max-width: 180px;
  }
  }
{% endstyle %}

<div class="deal-icons-grid-wrapper container container-lg columns-{{ section.settings.columns }}">
  {% for block in section.blocks %}
    {% assign icon = block.settings.icon %}
    <div class="deal-icon-item">
      {% if block.settings.link != blank %}
        <a href="{{ block.settings.link }}" aria-label="{{ block.settings.label }}">
      {% endif %}
      {% if icon != blank %}
        <img
          src="{{ icon | image_url: width: 300 }}"
         
          class="deal-icon-image"
          alt="{{ block.settings.label }}"
          width="300"
          height="300"
        >
      {% endif %}
      {% if block.settings.label != blank %}
        <div class="deal-icon-label">{{ block.settings.label }}</div>
      {% endif %}

      {% if block.settings.link != blank %}
        </a>
      {% endif %}
    </div>
  {% endfor %}
</div>
