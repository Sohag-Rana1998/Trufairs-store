      </div>
         <div class="trufairs-border-green trufairs-section-border">
      <p class="trufairs-section-text">{{ settings.warranty_text }}</p>
      <p class="trufairs-section-text">{{ settings.warranty_contact }}</p>
    </div>
    </div>
    <!-- Shipping Section -->
    <div class="trufairs-section">
      <div class="trufairs-section-header">
         
