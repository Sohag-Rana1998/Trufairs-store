        <a href="{{ settings.return_policy_link }}" class="trufairs-policy-link" target="_blank">
        {{ settings.return_policy_text }}
      </a>  
    </div>
  
    </div>
  </div>
</div>

 


<!-- JavaScript -->
<script defer>
document.addEventListener('DOMContentLoaded', function() {
  // Define a reusable function to initialize popup logic
  function initTrufairsPopup(scope = document) {
    const modals = scope.querySelectorAll('.trufairs-modal');
    const openButtons = scope.querySelectorAll('[data-popup-open="true"]');
    const closeButtons = scope.querySelectorAll('[data-popup-close="true"]');
    const overlays = scope.querySelectorAll('.trufairs-modal-overlay');

    openButtons.forEach((btn, index) => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const modal = modals[index] || document.querySelector('.trufairs-modal');
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    closeButtons.forEach((btn) => {
      btn.addEventListener('click', function() {
        const modal = btn.closest('.trufairs-modal');
        modal.classList.remove('active');
        document.body.style.overflow = 'auto';
      });
    });

    overlays.forEach((overlay) => {
      overlay.addEventListener('click', function() {
        const modal = overlay.closest('.trufairs-modal');
        modal.classList.remove('active');
        document.body.style.overflow = 'auto';
      });
    });
  }

  // Initialize popup for the main page
  initTrufairsPopup();

  // Observe for dynamically added Quick View modals
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      mutation.addedNodes.forEach((node) => {
        if (node.nodeType === 1 && node.querySelector('.trufairs-popup-btn')) {
          // Reinitialize popup inside dynamically added content
          initTrufairsPopup(node);
        }
      });
    });
  });

  // Watch for added elements in the whole document body
  observer.observe(document.body, { childList: true, subtree: true });
});
</script>


