 <div class="viewer-container">
 
  {% assign current_time = 'now' | date: '%s' %}
  {% assign today_6am = 'today 06:00' | date: '%s' %}
  {% assign tomorrow_6am = today_6am | plus: 86400 %}

  {%- comment -%} Use metafields for bought count, with fallback defaults {%- endcomment -%}
  {% assign min_count = product.metafields.custom.min_bought_count | default: 25 %}
  {% assign max_count = product.metafields.custom.max_bought_count | default: 50 %}
  {% assign range = max_count | minus: min_count %}

  {%- comment -%} Use metafields for viewer count, with fallback defaults {%- endcomment -%}
  {% assign min_viewers = product.metafields.custom.min_view_count | default: 10 %}
  {% assign max_viewers = product.metafields.custom.max_view_count | default: 30 %}

  {% if current_time < today_6am %}
    {% assign fake_bought = min_count %}
  {% else %}
    {% assign elapsed_time = current_time | minus: today_6am %}
    {% assign total_time = tomorrow_6am | minus: today_6am %}
