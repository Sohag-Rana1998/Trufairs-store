<script>
(function () {
  'use strict';

  // Utilities
  function safePostMessage(iframe, message) {
    try {
      iframe.contentWindow.postMessage(
        typeof message === 'string' ? message : JSON.stringify(message),
        '*'
      );
    } catch (e) {}
  }

  /* ------------------------------
     1. NATIVE <video> FIX
     ------------------------------ */
  function processNativeVideo(video) {
    try {
      video.controls = true;
      video.muted = false;
      video.removeAttribute && video.removeAttribute('muted');
      if (typeof video.volume !== 'undefined') video.volume = 1;
      video.autoplay = false; // prevent autoplay
      video.pause();          // ensure stopped
    } catch (e) {}
  }

  /* ------------------------------
     2. YOUTUBE FIX
     ------------------------------ */
  function ensureYouTubeApiEnabled(iframe) {
    try {
      let src = iframe.getAttribute('src') || '';
      if (!/enablejsapi=1/.test(src)) {
        const sep = src.includes('?') ? '&' : '?';
        iframe.setAttribute('src', src + sep + 'enablejsapi=1');
      }

      // allow sound, do NOT autoplay
      let allow = iframe.getAttribute('allow') || '';
      iframe.setAttribute(
        'allow',
        (allow + '; encrypted-media').trim()
      );
    } catch (e) {}
  }

  function processYouTubeIframe(iframe) {
    try {
      ensureYouTubeApiEnabled(iframe);

      // only unmute — DO NOT PLAY
      const unmute = { event: 'command', func: 'unMute', args: [] };
      const setVol = { event: 'command', func: 'setVolume', args: [100] };

      const send = () => {
        safePostMessage(iframe, unmute);
        safePostMessage(iframe, setVol);
      };

      if (iframe.contentWindow) {
        setTimeout(send, 300);
        setTimeout(send, 1200);
      } else {
        iframe.addEventListener('load', () => {
          setTimeout(send, 300);
          setTimeout(send, 1200);
        });
      }
    } catch (e) {}
  }

  /* ------------------------------
     3. VIMEO FIX
     ------------------------------ */
  function processVimeoIframe(iframe) {
    try {
      // Allow audio, no autoplay
      const allow = iframe.getAttribute('allow') || '';
      iframe.setAttribute(
        'allow',
        (allow + '; encrypted-media').trim()
      );

      // Set volume only — DO NOT PLAY
      const sendVol = () =>
        safePostMessage(iframe, { method: 'setVolume', value: 1 });

      if (iframe.contentWindow) {
        setTimeout(sendVol, 300);
        setTimeout(sendVol, 1200);
      } else {
        iframe.addEventListener('load', () => {
          setTimeout(sendVol, 300);
          setTimeout(sendVol, 1200);
        });
      }
    } catch (e) {}
  }

  /* ------------------------------
     4. MAIN PROCESSOR
     ------------------------------ */
  function processIframe(iframe) {
    try {
      iframe.setAttribute('data-controls-forced', 'true');

      const src = (iframe.getAttribute('src') || '').toLowerCase();
      const dataSrc = (iframe.getAttribute('data-src') || '').toLowerCase();

      if (src.includes('youtube') || dataSrc.includes('youtube')) {
        processYouTubeIframe(iframe);
      } else if (src.includes('vimeo') || dataSrc.includes('vimeo')) {
        processVimeoIframe(iframe);
      }
    } catch (e) {}
  }

  /* ------------------------------
     5. SCANNER
     ------------------------------ */
  function scan(root) {
    root = root || document;

    root.querySelectorAll('video').forEach(processNativeVideo);
    root.querySelectorAll('iframe').forEach(processIframe);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => scan(document));
  } else {
    scan(document);
  }

  /* ------------------------------
     6. WATCH FOR NEW VIDEOS
     ------------------------------ */
  new MutationObserver(m => {
    m.forEach(item => {
      item.addedNodes.forEach(node => {
        if (node.nodeType !== 1) return;
        if (node.tagName === 'VIDEO') processNativeVideo(node);
        else if (node.tagName === 'IFRAME') processIframe(node);
        else scan(node);
      });
    });
  }).observe(document.body, { childList: true, subtree: true });

  window.addEventListener('load', () =>
    setTimeout(() => scan(document), 300)
  );
})();
</script> 
