{%- when 'zipcode_checker' -%}

{% unless isModal %}


  
  
  
  <div id="zipcode-checker-{{ block.id }}" class="zipcode-checker" style="background-color: {{ block.settings.bg_color }}; border-color: {{ block.settings.border_color }};" {{ block.shopify_attributes }}>
  <div class="zipcode-checker__container">
    <h5 class="zipcode-checker__title" style="font-family:Inter, sans-serif;text-transform:uppercase;">{{ block.settings.title }}</h5>
    <div class="zipcode-checker__form">
      <div class="zipcode-checker__input-group">
        <input 
          type="text" 
          id="zipcode-input-{{ block.id }}" 
          class="zipcode-checker__input" 
          placeholder="Enter your zipcode" 
          maxlength="10"
          aria-label="Enter your zipcode"
        >
        <button 
          id="check-zipcode-btn-{{ block.id }}" 
          class="zipcode-checker__button" 
          aria-label="Check delivery availability"
          style="background-color: {{ block.settings.button_color }};"
        >
          <span class="zipcode-checker__button-text">Check</span>
          <span class="zipcode-checker__spinner" style="display: none;"></span>
        </button>
      </div>
      <div id="zipcode-message-{{ block.id }}" class="zipcode-checker__message" aria-live="polite"></div>
    </div>
  </div>
</div>

 

 <script  > 
  document.addEventListener('DOMContentLoaded', function() {
  


    // Use block-specific IDs to prevent conflicts with multiple instances
    const blockId = "{{ block.id }}";
    const checkZipcodeBtn = document.getElementById('check-zipcode-btn-' + blockId);
    const zipcodeInput = document.getElementById('zipcode-input-' + blockId);
    const zipcodeMessage = document.getElementById('zipcode-message-' + blockId);
    const spinner = document.querySelector('#zipcode-checker-' + blockId + ' .zipcode-checker__spinner');
    const buttonText = document.querySelector('#zipcode-checker-' + blockId + ' .zipcode-checker__button-text');
    
    // Get eligible zipcodes from block settings
    const eligibleZipcodesString = "{{ block.settings.eligible_zipcodes }}";
    const eligibleZipcodes = eligibleZipcodesString.split(',').map(zip => zip.trim());
    
    // Success and error messages from settings
    const successMessage = "{{ block.settings.success_message }}";
    const errorMessage = "{{ block.settings.error_message}}";
    
    // Check zipcode function
    function checkZipcode() {
      const zipcode = zipcodeInput.value.trim();
      
      // Validate input
      if (!zipcode) {
        showMessage('Please enter a zipcode.', 'info');
        return;
      }
      
      // Show loading state
      showLoading(true);
      
      // Simulate network request (for a realistic user experience)
      setTimeout(() => {
        if (eligibleZipcodes.includes(zipcode)) {
          showMessage(successMessage, 'success');
        } else {
          showMessage(errorMessage, 'error');
        }
        showLoading(false);
      }, 800);
    }
    
    // Show loading state
    function showLoading(isLoading) {
      if (isLoading) {
        spinner.style.display = 'block';
        buttonText.style.display = 'none';
        checkZipcodeBtn.disabled = true;
      } else {
        spinner.style.display = 'none';
        buttonText.style.display = 'block';
        checkZipcodeBtn.disabled = false;
      }
    }
    
    // Show message
    function showMessage(message, type) {
      zipcodeMessage.textContent = message;
      zipcodeMessage.className = 'zipcode-checker__message ' + type;
    }
    
    // Event listeners
    if (checkZipcodeBtn) {
      checkZipcodeBtn.addEventListener('click', checkZipcode);
      
      if (zipcodeInput) {
        zipcodeInput.addEventListener('keypress', function(e) {
          if (e.key === 'Enter') {
            checkZipcode();
          }
        });
        
        // Clear message when input changes
        zipcodeInput.addEventListener('input', function() {
          zipcodeMessage.textContent = '';
          zipcodeMessage.className = 'zipcode-checker__message';
        });
      }
    }


 });

 </script>
  
  
  
 {% endunless %}

