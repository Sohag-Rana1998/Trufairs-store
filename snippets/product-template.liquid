{%- comment -%}
  ============================================================================
  Attachment Group Section (New Version)
  ============================================================================
  - Author: Gemini
  - Version: 3.0
  - Description: This file contains the product grid for attachments. It works
    with a separate, global order summary snippet.
  - Features:
    - Two-column layout on desktop.
    - Communicates with a global summary via custom browser events.
    - "Add to Order" button allows adding multiple variants of the same product.
    - First block opens by default
{%- endcomment -%}

{{ 'attachment_group.css' | asset_url | stylesheet_tag }}


{%- liquid
  assign collection = block.settings.collection
  assign heading = block.settings.heading | default: "Complete Your Order"
  assign products_to_show = block.settings.products_to_show | default: 8
  assign block_id = "attachment-group-" | append: block.id
  
  # Find the first attachment_group block to determine if this is the first one
  assign is_first_block = false
  assign first_attachment_block_id = ""
  
  for section_block in section.blocks
    if section_block.type == 'attachment_group'
      assign first_attachment_block_id = section_block.id
      break
    endif
  endfor
  
  if block.id == first_attachment_block_id
    assign is_first_block = true
  endif
-%}

{%- if collection != blank and collection.products_count > 0 -%}
<div id="{{ block_id }}" class="attachment-group-wrapper" data-block-id="{{ block.id }}" data-is-first="{{ is_first_block }}" {{ block.shopify_attributes }}>
  <div class="attachment-group-container">

    <div class="attachment-group-header">
      <button type="button" class="attachment-toggle-btn" aria-expanded="{% if is_first_block %}true{% else %}false{% endif %}" aria-controls="attachments-container-{{ block.id }}">
        <h3 class="attachment-group-heading">{{ heading }}</h3>
        <p class="attachment-subtitle">{{ block.settings.subtext_attachment }}</p>
        <span class="toggle-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </span>
      </button>
    </div>

    <div class="attachments-container{% if is_first_block %} expanded{% endif %}" id="attachments-container-{{ block.id }}">
      <div class="attachments-grid">
        {%- for attachment in collection.products limit: products_to_show -%}
          {%- if attachment.available -%}
            <div class="attachment-card" data-product-id="{{ attachment.id }}">
              <div class="attachment-card-image-wrapper">
                <a href="{{ attachment.url   }}" class="attachment-card-link">
                  {%- if attachment.featured_media -%}
                    <img
                      src="{{ attachment.featured_media | image_url: width: 400 }}"
                      alt="{{ attachment.featured_media.alt | escape }}"
                     
                      class="attachment-card-image">
                  {%- else -%}
                    <div class="no-image-placeholder">
                      <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </div>
                  {%- endif -%}
                </a>
              </div>

              <div class="attachment-card-details">
                <h4 class="attachment-card-title">
                  <a href="{{ attachment.url   }}">{{ attachment.title }}</a>
                </h4>

                <div class="attachment-price-display" data-price-container>
                  {{ attachment.price | money }}
                </div>

                {%- if attachment.variants.size > 1 -%}
                  <select class="attachment-variant-select" name="id" data-action="update-variant">
                    {%- for variant in attachment.variants -%}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-title="{{ variant.title | escape }}"
                        {% if variant == attachment.selected_or_first_available_variant %}selected="selected"{% endif %}>
                        {{ variant.title }}
                      </option>
                    {%- endfor -%}
                  </select>
                {%- else -%}
                  <input type="hidden" name="id" class="attachment-variant-select" value="{{ attachment.variants.first.id }}" data-price="{{ attachment.variants.first.price }}" data-title="{{ attachment.variants.first.title | escape }}">
                {%- endif -%}

                <div class="attachment-card-actions">
                  <div class="quantity-selector">
                    <button type="button" class="quantity-btn" data-action="decrease-qty" aria-label="Decrease quantity">
                      -
                    </button>
                    <input type="number" class="quantity-input" value="1" min="1" aria-label="Quantity" data-quantity-input>
                    <button type="button" class="quantity-btn" data-action="increase-qty" aria-label="Increase quantity">
                    +
                    </button>
                  </div>
                  <button type="button" class="btn attachment-select-btn" data-action="add-attachment"
                    data-product-title="{{ attachment.title | escape }}">
                    <span class="btn-text">Add</span>
                  </button>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>
{%- endif -%}




 


 



                  
                  {%- when 'buy_buttons' -%}
                 
 

 {% if block.settings.show_bundle_btn == 'true' %}
     {%- comment -%}
  This snippet should be included once in your main product template.
  It creates the global order summary and manages the state for all
  attachment blocks on the page.
{%- endcomment -%}

<div class="global-summary-wrapper" id="global-attachment-summary">
  <div class="order-summary-section">
    <div class="order-summary-header">
      <h4>Order Summary</h4>
      <span class="selected-count" data-summary-count>0 attachments selected</span>
    </div>

    <div class="summary-item main-product-item">
      <div class="item-info">
        <div class="item-title">{{ product.title }} (Main Product)</div>
        <div class="item-variant">{{ product.selected_or_first_available_variant.title }}</div>
        <div class="summary-item-controls">
          <div class="summary-quantity-selector">
            <button type="button" class="summary-quantity-btn" data-action="decrease-main-qty" aria-label="Decrease quantity">-</button>
            <input type="number" class="summary-quantity-input" value="1" min="1" data-action="update-main-qty" data-main-product="true" aria-label="Quantity">
            <button type="button" class="summary-quantity-btn" data-action="increase-main-qty" aria-label="Increase quantity">+</button>
          </div>
        </div>
      </div>
      <div class="item-price" data-main-product-price>{{ product.price | money }}</div>
    </div>

    <div class="selected-attachments-summary" data-summary-items-container>
      <p class="summary-placeholder" data-summary-placeholder>Select items above to add them here.</p>
    </div>

    <div class="checkout-section">
      <div class="total-price-display">
        <span class="total-label">Total:</span>
        <span class="total-amount" data-summary-total>{{ product.price | money }}</span>
      </div>
      <button type="button" class="btn main-add-to-cart-btn" data-action="add-all-to-cart">
        <span class="btn-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        </span>
        <span data-add-to-cart-text>Add to Cart</span>
      </button>
      <p class="checkout-note"><small>All selected items will be added to your cart.</small></p>
    </div>
  </div>
</div>

<script type="application/json" id="shopify-global-data">
{
  "mainProduct": {
    "variantId": {{ product.selected_or_first_available_variant.id }},
    "price": {{ product.price }}
  },
  "moneyFormat": {{ shop.money_format | json }}
}
</script>

 
<script src="{{ 'attachment_group.js' | asset_url }}" defer="defer"></script>

 

