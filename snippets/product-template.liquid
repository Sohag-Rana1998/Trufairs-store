{%- when 'video-reviews' -%}



{%- style -%}
  .video-reviews-block {
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }
  .video-reviews-block .section-header {
    text-align: center;
    margin-bottom: 16px;
  }
  .video-reviews-block .section-header h3 {
    margin: 0;
    font-size: 20px;
  }
.video-reviews-block .swiper-slide  {
    max-width: 350px;
}
  .video-reviews-swiper-{{ block.id }} {
    overflow: hidden;
  }
  .video-reviews-swiper-{{ block.id }} .swiper-slide {
    height: auto;
  }

  .video-item {
    width: 100%;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .video-item.vertical {
    aspect-ratio: 9 / 16;
  }
  .video-item iframe,
  .video-item video {
    width: 100%;
    height: 100%;
    display: block;
    border: 0;
    object-fit: cover;
    background: #000;
  }

  .video-reviews-swiper-{{ block.id }} .swiper-button-next,
  .video-reviews-swiper-{{ block.id }} .swiper-button-prev {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  .video-reviews-swiper-{{ block.id }} .swiper-button-next:after,
  .video-reviews-swiper-{{ block.id }} .swiper-button-prev:after {
    font-size: 14px;
    color: #333;
    font-weight: 700;
  }

  @media (max-width: 749px) {
    .video-reviews-swiper-{{ block.id }} .swiper-button-next,
    .video-reviews-swiper-{{ block.id }} .swiper-button-prev {
      display: none;
    }
  }
{%- endstyle -%}

<div class="video-reviews-block" {{ block.shopify_attributes }}>
  {% if block.settings.section_title != blank %}
    <div class="section-header">
      <h3>{{ block.settings.section_title }}</h3>
    </div>
  {% endif %}

  <div class="swiper video-reviews-swiper-{{ block.id }}">
    <div class="swiper-wrapper">
      {% for i in (1..6) %}
        {% liquid
          assign url_key = 'video_url_' | append: i
          assign orient_key = 'orientation_' | append: i

          assign video_url = block.settings[url_key]
          assign orientation = block.settings[orient_key]

          assign video_type = 'file'
          assign video_id = ''

          if video_url contains 'youtube.com' or video_url contains 'youtu.be'
            assign video_type = 'youtube'
            if video_url contains 'youtu.be/'
              assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
            else
              assign video_id = video_url | split: 'v=' | last | split: '&' | first
            endif
          elsif video_url contains 'vimeo.com'
            assign video_type = 'vimeo'
            assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first
          endif
        %}

        {% if video_url != blank %}
          <div class="swiper-slide">
            <div class="video-item {% if orientation == 'vertical' %}vertical{% endif %}">
              {% if video_type == 'youtube' %}
                <iframe
                  src="https://www.youtube.com/embed/{{ video_id }}?rel=0&modestbranding=1&playsinline=1"
                  title="Customer video review"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                 >
                </iframe>
              {% elsif video_type == 'vimeo' %}
                <iframe
                  src="https://player.vimeo.com/video/{{ video_id }}?title=0&byline=0&portrait=0"
                  title="Customer video review"
                  allow="autoplay; fullscreen; picture-in-picture"
                  allowfullscreen
                 >
                </iframe>
              {% else %}
                <video controls playsinline preload="metadata">
                  <source src="{{ video_url }}" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
    <div class="swiper-pagination"></div>
  </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.video-reviews-swiper-{{ block.id }}', {
      slidesPerView: {{ block.settings.mobile_slides }},
      spaceBetween: {{ block.settings.space_between }},
      pagination: {
        el: '.video-reviews-swiper-{{ block.id }} .swiper-pagination',
        clickable: true
      },
      navigation: {
        nextEl: '.video-reviews-swiper-{{ block.id }} .swiper-button-next',
        prevEl: '.video-reviews-swiper-{{ block.id }} .swiper-button-prev'
      },
      breakpoints: {
        750: {
          slidesPerView: {{ block.settings.tablet_slides }},
          spaceBetween: {{ block.settings.space_between }}
        },
        990: {
          slidesPerView: {{ block.settings.desktop_slides }},
          spaceBetween: {{ block.settings.space_between }}
        }
      }
    });
  });
</script>
 


 
