<script>
document.addEventListener("DOMContentLoaded", () => {

  /* Viewer count randomizer - using metafield values passed from Liquid */
  const minViewers = {{ min_viewers }};
  const maxViewers = {{ max_viewers }};
  const viewerEl = document.getElementById("viewer_count");

  function updateViewers() {
    viewerEl.textContent =
      Math.floor(Math.random() * (maxViewers - minViewers + 1)) + minViewers;
  }

  updateViewers();
  setInterval(updateViewers, 4000);

  /* Toggle sections */
  const viewerBox = document.getElementById("viewer-count");
  const boughtBox = document.getElementById("bought-count");

  function toggle() {
    const showViewer = viewerBox.style.display !== "none";
    viewerBox.style.display = showViewer ? "none" : "flex";
    boughtBox.style.display = showViewer ? "flex" : "none";
    setTimeout(toggle, 5000);
  }

  viewerBox.style.display = "flex";
  boughtBox.style.display = "none";
  setTimeout(toggle, 5000);
});
</script>

