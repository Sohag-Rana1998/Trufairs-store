 {%- when 'bundle-purchase' -%}                              
 
{% comment %} Bundle Drawer Full Implementation with Styles, Script, and Metafield Handling (Updated) {% endcomment %}

{% assign first_bundle_product = nil %}
{% assign bundle_items = '' %}
{% assign bundle_count = 0 %}
{% assign metafield_data = product.metafields.custom.bundle_products %}

{% if metafield_data %}
  {% assign metafield_type = metafield_data.type %}
  {% if metafield_type == 'list.product_reference' %}
    {% for bundle_item in metafield_data.value %}
      {% if bundle_item != blank and bundle_item.available %}
        {% assign bundle_count = bundle_count | plus: 1 %}
        {% assign bundle_items = bundle_items | append: bundle_item.id | append: ',' %}
        {% if first_bundle_product == nil %}
          {% assign first_bundle_product = bundle_item %}
        {% endif %}
      {% endif %}
    {% endfor %}
  {% elsif metafield_type == 'product_reference' %}
    {% assign single_bundle_product = metafield_data.value %}
    {% if single_bundle_product != blank and single_bundle_product.available %}
      {% assign first_bundle_product = single_bundle_product %}
      {% assign bundle_items = single_bundle_product.id | append: ',' %}
      {% assign bundle_count = 1 %}
    {% endif %}
  {% endif %}
{% endif %}

{% if first_bundle_product and first_bundle_product.available %}
 
<h3>Get Everything You Need:</h3>
  <div class="bundle-products">
    <div class="bundle-product">
      <img src="{{ product.featured_image | img_url: '300x200' }}" alt="{{ product.title }}" height="200" width="200">
      <p>{{ product.title | truncate: 45 }}</p>
      <p>{{ product.price | money }}</p>
    </div>
    <div class="bundle-plus">+</div>
       <a class="bundle-product" href="{{ first_bundle_product.url }}" >
     
      <img src="{{ first_bundle_product.featured_image | img_url: '300x200' }}" alt="{{ first_bundle_product.title }}" height="200" width="200">
      <p>{{ first_bundle_product.title | truncate: 45 }}</p>
      <p>{{ first_bundle_product.price | money }}</p>
   
       </a>
      <button class="drawer-toggle-btn" onclick="openDrawer()">
    Buy Both: {{ product.price | plus: first_bundle_product.price | money }}
  </button>
  </div>



  <div class="drawer-overlay" onclick="closeDrawer()"></div>

  <div class="bulk-purchase-drawer" id="bundleDrawer">
    <div class="drawer-header">
      <h3>Get Everything You May Need</h3>
      <button class="close-btn" onclick="closeDrawer()">&times;</button>
    </div>

    <div class="drawer-title-heading">Current Product</div>
    <div class="drawer-product">
      <img src="{{ product.featured_image | img_url: '200x200' }}" alt="{{ product.title }}" height="200" width="200">
      <div >
        <p style="margin-bottom:5px; font-size:14px">{{ product.title | truncate: 50 }}</p>
        <div class="price-quantity-container" style="margin-bottom:5px">
        <p style="margin-bottom:5px">{{ product.price | money }}</p>
<div class="quantity-controls"><button onclick="adjustQty('qty-main-{{ product.id }}', -1)">−</button>
          <input type="number" id="qty-main-{{ product.id }}" value="1" min="1">
          <button onclick="adjustQty('qty-main-{{ product.id }}', 1)">+</button></div>
        </div>
        <div >
          
          <button id="btn-main-{{ product.id }}" class="add-btn" onclick="addToCart({{ product.selected_or_first_available_variant.id }}, 'qty-main-{{ product.id }}', 'btn-main-{{ product.id }}')">
            <span class="add-btn-spinner"></span> Add to Cart
          </button>
        </div>
      </div>
    </div>

    {% if metafield_data and bundle_count > 0 %}
      <div class="drawer-title-heading">Compatible Items</div>
      {% assign first_skipped = false %}
      {% for bundle_item in metafield_data.value %}
        {% if bundle_item != blank and bundle_item.available %}
          {% unless first_skipped %}
            {% assign first_skipped = true %}
            {% continue %}
          {% endunless %}
            
          <div class="drawer-product">
               <a href="{{ bundle_item.url }}" class="drawer-img-container">
            <img src="{{ bundle_item.featured_image | img_url: '200x200' }}" alt="{{ bundle_item.title }}" height="200" width="200">
          </a>
          <div class="drawer-product-info">
            <a href="{{ bundle_item.url }}" >
              <p style="margin-bottom:5px; font-size:14px;">{{ bundle_item.title | truncate: 50 }}</p>
            </a>
              <p style="margin-bottom:5px">{{ bundle_item.price | money }}</p>
              <div >
                <div class="quantity-controls" style="margin-bottom:5px"><button onclick="adjustQty('qty-bundle-{{ bundle_item.id }}', -1)">−</button>
                <input type="number" id="qty-bundle-{{ bundle_item.id }}" value="1" min="1">
                <button onclick="adjustQty('qty-bundle-{{ bundle_item.id }}', 1)">+</button></div>
                <button id="btn-bundle-{{ bundle_item.id }}" class="add-btn" onclick="addToCart({{ bundle_item.selected_or_first_available_variant.id }}, 'qty-bundle-{{ bundle_item.id }}', 'btn-bundle-{{ bundle_item.id }}')">
                  <span class="add-btn-spinner"></span> Add to Cart
                </button>
              </div>
            </div>
          </div>
        {% endif %}
